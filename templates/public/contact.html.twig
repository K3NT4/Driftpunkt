{% extends 'base.html.twig' %}

{% set knowledgeBaseSettings = knowledgeBaseSettings|default({
    publicEnabled: false
}) %}

{% block title %}Driftpunkt | Kontakta Oss{% endblock %}

{% block page_shell_class %}home-shell contact-shell{% endblock %}
{% block body_class %}home-landing contact-page{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        :root {
            --home-text: #283474;
            --home-text-soft: #54618e;
            --home-line: rgba(177, 186, 241, 0.42);
            --home-surface: rgba(255, 255, 255, 0.78);
            --home-surface-strong: rgba(255, 255, 255, 0.9);
            --home-shadow: 0 24px 60px rgba(87, 101, 177, 0.16);
            --home-blue: #2f59df;
            --home-purple: #7f42df;
            --home-green: #3aa16b;
            --home-orange: #f59b41;
        }

        body.contact-page {
            background:
                radial-gradient(circle at 18% 14%, rgba(148, 162, 255, 0.48), transparent 28%),
                radial-gradient(circle at 86% 12%, rgba(255, 222, 212, 0.66), transparent 24%),
                radial-gradient(circle at 50% 100%, rgba(103, 110, 255, 0.3), transparent 24%),
                linear-gradient(180deg, #7785d6 0%, #a9aff0 16%, #cbc7f5 38%, #d8d0f7 52%, #c7c8f8 67%, #a4aff0 100%);
            color: var(--home-text);
        }

        body.contact-page::before {
            background:
                radial-gradient(ellipse at 18% 32%, rgba(255, 255, 255, 0.36), transparent 26%),
                radial-gradient(ellipse at 55% 46%, rgba(255, 255, 255, 0.4), transparent 34%),
                radial-gradient(ellipse at 82% 68%, rgba(255, 255, 255, 0.28), transparent 24%),
                linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0));
            mask-image: none;
            opacity: 1;
        }

        body.contact-page::after {
            content: "";
            position: fixed;
            inset: 0;
            pointer-events: none;
            background:
                radial-gradient(circle at 20% 18%, rgba(255, 255, 255, 0.95) 0 2px, transparent 3px),
                radial-gradient(circle at 82% 26%, rgba(255, 255, 255, 0.88) 0 2px, transparent 3px),
                radial-gradient(circle at 14% 74%, rgba(255, 255, 255, 0.7) 0 2px, transparent 3px),
                radial-gradient(circle at 74% 86%, rgba(255, 255, 255, 0.78) 0 2px, transparent 3px);
            opacity: 0.9;
        }

        .contact-shell {
            width: calc(100% - 2rem);
            padding: 0 0 2.5rem;
        }

        .home-topbar,
        .home-footer {
            margin: 0 calc(50% - 50vw);
        }

        .home-topbar {
            background:
                linear-gradient(180deg, rgba(79, 88, 170, 0.92), rgba(71, 80, 156, 0.88)),
                linear-gradient(90deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0));
            border-bottom: 1px solid rgba(255, 255, 255, 0.16);
            box-shadow: 0 14px 36px rgba(56, 63, 125, 0.18);
            backdrop-filter: blur(12px);
        }

        .home-topbar-inner,
        .home-statusbar-inner,
        .home-footer-inner {
            width: calc(100% - 2rem);
            margin: 0 auto;
        }

        .home-topbar-inner {
            min-height: 68px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1.25rem;
        }

        .home-brand {
            display: inline-flex;
            align-items: center;
            gap: 0.85rem;
            color: #fff;
            font-family: "Space Grotesk", "Manrope", sans-serif;
            font-size: 1.1rem;
            font-weight: 700;
            text-decoration: none;
            letter-spacing: -0.02em;
        }

        .home-brand-mark {
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .home-brand-logo {
            height: 2.55rem;
            width: auto;
            display: block;
            filter: drop-shadow(0 12px 20px rgba(14, 39, 119, 0.24));
        }

        .home-nav {
            display: flex;
            align-items: center;
            gap: 1.35rem;
            color: rgba(255, 255, 255, 0.9);
        }

        .home-nav-link,
        .home-search {
            color: inherit;
            text-decoration: none;
            font-size: 1rem;
            font-weight: 500;
        }

        .home-search-form {
            display: flex;
            align-items: center;
            gap: 0.55rem;
            min-width: min(340px, 40vw);
            margin-left: 0.2rem;
            padding-left: 1rem;
            border-left: 1px solid rgba(255, 255, 255, 0.18);
        }

        .home-search-input {
            width: 100%;
            min-width: 0;
            border: 0;
            outline: none;
            background: transparent;
            color: #fff;
            font: inherit;
        }

        .home-search-input::placeholder {
            color: rgba(255, 255, 255, 0.72);
        }

        .home-search {
            width: 2.25rem;
            height: 2.25rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: 0;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.14);
            font-size: 1.1rem;
            opacity: 0.92;
            cursor: pointer;
        }

        .home-login-button {
            min-width: 104px;
            padding: 0.74rem 1.28rem;
            border-radius: 11px;
            background: linear-gradient(180deg, #ffbf61 0%, #f49b3c 100%);
            color: #fff;
            border: 1px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 10px 22px rgba(228, 142, 48, 0.32);
        }

        .home-statusbar {
            background: rgba(236, 226, 255, 0.28);
            border-top: 1px solid rgba(255, 255, 255, 0.12);
            border-bottom: 1px solid rgba(113, 117, 195, 0.16);
        }

        .home-statusbar-inner {
            min-height: 38px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.7rem;
            color: #56628f;
            font-size: 0.93rem;
            text-align: center;
        }

        .status-ok-dot {
            width: 1rem;
            height: 1rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            background: rgba(92, 118, 230, 0.16);
            color: #4e63c7;
            font-size: 0.72rem;
            font-weight: 700;
        }

        .status-sep {
            opacity: 0.55;
        }

        .contact-hero {
            position: relative;
            padding: 4.2rem 0 1.2rem;
        }

        .contact-hero::before {
            content: "";
            position: absolute;
            left: 50%;
            top: 0.4rem;
            transform: translateX(-50%);
            width: 100vw;
            height: 240px;
            border-radius: 50%;
            background: radial-gradient(ellipse at center, rgba(255, 255, 255, 0.64) 0%, rgba(255, 255, 255, 0.18) 58%, transparent 78%);
            opacity: 0.95;
            pointer-events: none;
        }

        .contact-hero::after {
            content: "";
            position: absolute;
            inset: auto 6% 1.1rem auto;
            width: 13rem;
            height: 13rem;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(126, 87, 255, 0.18), transparent 68%);
            filter: blur(4px);
            pointer-events: none;
        }

        .contact-hero-card {
            position: relative;
            max-width: 940px;
            margin: 0 auto;
            padding: 2rem 2rem 2.2rem;
            text-align: center;
            border-radius: 34px;
            background:
                linear-gradient(135deg, rgba(255, 255, 255, 0.86), rgba(247, 249, 255, 0.68)),
                linear-gradient(180deg, rgba(72, 105, 230, 0.05), rgba(250, 170, 79, 0.05));
            border: 1px solid rgba(218, 223, 246, 0.9);
            box-shadow:
                0 24px 56px rgba(85, 96, 171, 0.16),
                inset 0 1px 0 rgba(255, 255, 255, 0.66);
            backdrop-filter: blur(16px);
            overflow: hidden;
        }

        .contact-hero-card::before {
            content: "";
            position: absolute;
            left: -4rem;
            top: -4rem;
            width: 12rem;
            height: 12rem;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(62, 103, 231, 0.14), transparent 72%);
            pointer-events: none;
        }

        .contact-hero-card::after {
            content: "";
            position: absolute;
            right: -3rem;
            bottom: -3rem;
            width: 11rem;
            height: 11rem;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(245, 155, 65, 0.16), transparent 70%);
            pointer-events: none;
        }

        .contact-pill {
            display: inline-flex;
            align-items: center;
            gap: 0.55rem;
            margin-bottom: 1rem;
            padding: 0.7rem 1rem;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.74);
            border: 1px solid rgba(255, 255, 255, 0.52);
            box-shadow: 0 16px 36px rgba(102, 111, 177, 0.16);
            color: #34427f;
            font-weight: 700;
        }

        .contact-title {
            margin: 0 0 1rem;
            font-size: clamp(2.7rem, 5vw, 4.8rem);
            color: #203060;
        }

        .contact-subtitle {
            margin: 0 auto;
            max-width: 54rem;
            color: #5a678f;
            font-size: 1.15rem;
            line-height: 1.75;
        }

        .contact-grid,
        .contact-split,
        .contact-stats {
            display: grid;
            gap: 1rem;
        }

        .contact-grid {
            grid-template-columns: 1.15fr 1fr 1fr;
            margin-top: 1.2rem;
        }

        .contact-split {
            grid-template-columns: minmax(0, 1.2fr) minmax(300px, 0.8fr);
            align-items: start;
        }

        .contact-stats {
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        }

        .contact-card,
        .contact-panel,
        .contact-feature {
            background: rgba(255, 255, 255, 0.82);
            border: 1px solid rgba(205, 213, 246, 0.85);
            border-radius: 26px;
            box-shadow: 0 20px 48px rgba(90, 103, 171, 0.14);
            backdrop-filter: blur(14px);
        }

        .contact-card,
        .contact-panel {
            padding: 1.45rem;
        }

        .contact-card {
            position: relative;
            min-height: 228px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            overflow: hidden;
        }

        .contact-card::after {
            content: "";
            position: absolute;
            right: -2.5rem;
            bottom: -2.5rem;
            width: 7rem;
            height: 7rem;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(91, 107, 223, 0.12), transparent 68%);
            pointer-events: none;
        }

        .contact-card h2,
        .contact-panel h2,
        .contact-panel h3,
        .contact-feature h3 {
            margin: 0 0 0.6rem;
            color: #24315f;
        }

        .contact-card p,
        .contact-panel p,
        .contact-feature p,
        .contact-feature li {
            color: #5f6d90;
            line-height: 1.7;
        }

        .contact-channel-icon,
        .contact-feature-icon {
            width: 3rem;
            height: 3rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1rem;
            border-radius: 18px;
            font-size: 1.2rem;
            font-weight: 800;
            color: #fff;
        }

        .contact-channel-icon.blue,
        .contact-feature-icon.blue {
            background: linear-gradient(180deg, #4a7bff, #2559d8);
        }

        .contact-channel-icon.green,
        .contact-feature-icon.green {
            background: linear-gradient(180deg, #4ec985, #2b9660);
        }

        .contact-channel-icon.orange,
        .contact-feature-icon.orange {
            background: linear-gradient(180deg, #ffbc6a, #f18b2c);
        }

        .contact-link {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            margin-top: 0.7rem;
            color: #2447b3;
            font-weight: 700;
            text-decoration: none;
        }

        .contact-link:hover {
            text-decoration: underline;
        }

        .contact-card-eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            margin-bottom: 0.65rem;
            color: #6b77a2;
            font-size: 0.83rem;
            font-weight: 800;
            letter-spacing: 0.04em;
            text-transform: uppercase;
        }

        .contact-highlight {
            position: relative;
            overflow: hidden;
            padding: 1.85rem;
            background:
                linear-gradient(135deg, rgba(255, 255, 255, 0.92), rgba(243, 247, 255, 0.8)),
                linear-gradient(180deg, rgba(51, 92, 204, 0.06), rgba(243, 157, 65, 0.05));
        }

        .contact-highlight::after {
            content: "";
            position: absolute;
            right: -3rem;
            bottom: -3rem;
            width: 12rem;
            height: 12rem;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(53, 102, 228, 0.16), transparent 70%);
            pointer-events: none;
        }

        .contact-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
            margin-top: 1.15rem;
        }

        .contact-button {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            padding: 0.9rem 1.25rem;
            border-radius: 999px;
            text-decoration: none;
            font-weight: 700;
        }

        .contact-button.primary {
            background: linear-gradient(180deg, #3367ea 0%, #2954ca 100%);
            color: #fff;
            box-shadow: 0 14px 30px rgba(41, 84, 202, 0.26);
        }

        .contact-button.secondary {
            background: rgba(255, 255, 255, 0.78);
            border: 1px solid rgba(190, 199, 238, 0.9);
            color: #24315f;
        }

        .contact-feature {
            padding: 1.15rem;
            background:
                linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(248, 250, 255, 0.82));
            min-height: 100%;
        }

        .contact-feature ul {
            margin: 0;
            padding-left: 1.2rem;
        }

        .contact-support-links {
            display: grid;
            gap: 0.75rem;
            margin-top: 1rem;
        }

        .contact-support-links a {
            display: flex;
            justify-content: space-between;
            gap: 1rem;
            padding: 0.95rem 1rem;
            border-radius: 18px;
            background: rgba(255, 255, 255, 0.74);
            border: 1px solid rgba(205, 213, 246, 0.85);
            color: #24315f;
            text-decoration: none;
            font-weight: 700;
        }

        .contact-support-links a:hover {
            transform: translateY(-1px);
            box-shadow: 0 12px 24px rgba(92, 103, 171, 0.12);
        }

        .contact-footer-note {
            margin-top: 1rem;
            color: #617095;
            font-size: 0.95rem;
        }

        .home-footer {
            margin-top: 2rem;
            padding: 1.35rem 0 2rem;
            background: rgba(62, 73, 150, 0.28);
            border-top: 1px solid rgba(255, 255, 255, 0.14);
        }

        .footer-links {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
            justify-content: center;
        }

        .footer-links a,
        .footer-links span {
            color: rgba(255, 255, 255, 0.9);
            text-decoration: none;
        }

        @media (max-width: 900px) {
            .contact-grid,
            .contact-split {
                grid-template-columns: 1fr;
            }

            .home-topbar-inner {
                flex-direction: column;
                justify-content: center;
                padding: 0.9rem 0;
            }
        }

        @media (max-width: 720px) {
            .home-nav {
                width: 100%;
                justify-content: center;
                flex-wrap: wrap;
                gap: 0.8rem;
            }

            .home-search-form {
                width: 100%;
                min-width: 0;
                margin-left: 0;
                padding-left: 0;
                border-left: 0;
            }

            .contact-title {
                font-size: 2.6rem;
            }
        }
    </style>
{% endblock %}

{% block topbar %}
    <header class="home-topbar">
        <div class="home-topbar-inner">
            <a class="home-brand" href="{{ path('app_home') }}">
                <span class="home-brand-mark">
                    <img class="home-brand-logo" src="/assets/branding/driftpunkt-logo-full.png" alt="Driftpunkt">
                </span>
            </a>
            <nav class="home-nav" aria-label="Huvudnavigering">
                <a class="home-nav-link" href="{{ path('app_home') }}">Startsida</a>
                <a class="home-nav-link" href="{{ path('app_news_index') }}">Nyheter</a>
                <a class="home-nav-link" href="{{ path('app_status_page') }}">Driftstatus</a>
                <a class="home-nav-link" href="{{ path('app_contact') }}">Kontakta oss</a>
                <form class="home-search-form" method="get" action="{{ path('app_public_search') }}">
                    <input class="home-search-input" type="search" name="q" value="{{ app.request.query.get('q') }}" placeholder="Sök på hela sajten">
                    <button class="home-search" type="submit" aria-label="Sök">⌕</button>
                </form>
                <a class="button home-login-button" href="{{ app.user ? path('app_portal_entry') : path('app_login') }}">Logga in</a>
            </nav>
        </div>
        <div class="home-statusbar">
            <div class="home-statusbar-inner">
                <span class="status-ok-dot" aria-hidden="true">✓</span>
                {% for line in contactPageSettings.statusLines %}
                    {% set statusParts = line|split(': ', 2) %}
                    <span>
                        {% if statusParts|length > 1 %}
                            {{ statusParts[0] }}: <strong>{{ statusParts[1] }}</strong>
                        {% else %}
                            {{ line }}
                        {% endif %}
                    </span>
                    {% if not loop.last %}
                        <span class="status-sep">•</span>
                    {% endif %}
                {% endfor %}
            </div>
        </div>
    </header>
{% endblock %}

{% block body %}
    {% set publicMaintenanceState = maintenance_mode.getState() %}
    {% set publicMaintenanceLocked = publicMaintenanceState.effectiveEnabled %}
    <section class="contact-hero">
        <div class="contact-hero-card">
            <div class="contact-pill">
                <span>◔</span>
                <span>{{ contactPageSettings.heroPill }}</span>
            </div>
            <h1 class="contact-title">{{ contactPageSettings.title }}</h1>
            <p class="contact-subtitle">
                {{ contactPageSettings.subtitle }}
                {% if publicMaintenanceLocked %}
                    Kund- och teknikerinloggning är just nu pausad, så använd gärna driftsidan eller kontakta supporten direkt.
                {% endif %}
            </p>
            <div class="contact-actions" style="justify-content: center; margin-top: 1.4rem;">
                <a class="contact-button primary" href="{{ publicMaintenanceLocked ? path('app_status_page') : contactPageSettings.primaryCtaUrl }}">
                    {{ publicMaintenanceLocked ? 'Öppna driftstatus' : contactPageSettings.primaryCtaLabel }}
                </a>
                {% if knowledgeBaseSettings.publicEnabled %}
                    <a class="contact-button secondary" href="{{ contactPageSettings.secondaryCtaUrl }}">{{ contactPageSettings.secondaryCtaLabel }}</a>
                {% endif %}
            </div>
        </div>
    </section>

    {% set cardIcons = [
        { class: 'blue', icon: '✉' },
        { class: 'green', icon: '☎' },
        { class: 'orange', icon: '⌂' }
    ] %}
    <section class="contact-grid" aria-label="Kontaktvägar">
        {% for card in contactPageSettings.channelCards|slice(0, 3) %}
            {% set iconTheme = cardIcons[loop.index0] %}
            {% if loop.index0 == 0 %}
                {% set cardHref = 'mailto:' ~ contactPageSettings.email %}
                {% set cardLinkLabel = card.linkLabel ?: contactPageSettings.email %}
            {% elseif loop.index0 == 1 %}
                {% set cardHref = 'tel:' ~ contactPageSettings.phoneHref %}
                {% set cardLinkLabel = card.linkLabel ?: contactPageSettings.phone %}
            {% else %}
                {% set cardHref = publicMaintenanceLocked ? path('app_status_page') : (app.user ? path('app_portal_entry') : path('app_login', {role: 'customer'})) %}
                {% set cardLinkLabel = publicMaintenanceLocked ? 'Se driftstatus' : (card.linkLabel ?: 'Öppna portalen') %}
            {% endif %}
            <article class="contact-card">
                <div class="contact-channel-icon {{ iconTheme.class }}">{{ iconTheme.icon }}</div>
                {% if card.eyebrow %}
                    <div class="contact-card-eyebrow">{{ card.eyebrow }}</div>
                {% endif %}
                <h2>{{ card.title }}</h2>
                <p>{{ card.description }}</p>
                <a class="contact-link" href="{{ cardHref }}">{{ cardLinkLabel }}</a>
            </article>
        {% endfor %}
    </section>

    <section class="contact-split" style="margin-top: 1rem;">
        <article class="contact-panel contact-highlight">
            <h2>{{ contactPageSettings.quickHelpTitle }}</h2>
            <p>{{ contactPageSettings.quickHelpIntro }}</p>

            <div class="contact-stats" style="margin-top: 1rem;">
                {% for item in contactPageSettings.quickHelpSteps %}
                    <div class="contact-feature">
                        <div class="contact-feature-icon {{ loop.index == 1 ? 'blue' : (loop.index == 2 ? 'green' : 'orange') }}">{{ item.badge }}</div>
                        <h3>{{ item.title }}</h3>
                        <p>{{ item.description }}</p>
                    </div>
                {% endfor %}
            </div>

            <div class="contact-footer-note" style="margin-top: 1.2rem;">{{ contactPageSettings.quickHelpNote }}</div>
        </article>

        <aside class="contact-panel">
            <h2>{{ contactPageSettings.priorityTitle }}</h2>
            <p>{{ contactPageSettings.priorityIntro }}</p>
            <div class="contact-support-links">
                <a href="mailto:{{ contactPageSettings.email }}">
                    <span>{{ contactPageSettings.priorityLinkLabels[0]|default('E-post för support') }}</span>
                    <span>›</span>
                </a>
                <a href="tel:{{ contactPageSettings.phoneHref }}">
                    <span>{{ contactPageSettings.priorityLinkLabels[1]|default('Ring supporten') }}</span>
                    <span>›</span>
                </a>
                <a href="{{ path('app_status_page') }}">
                    <span>{{ contactPageSettings.priorityLinkLabels[2]|default('Se driftnyheter') }}</span>
                    <span>›</span>
                </a>
            </div>
            <p class="contact-footer-note">{{ contactPageSettings.hours }}</p>
        </aside>
    </section>

    <section class="contact-split" style="margin-top: 1rem;">
        <article class="contact-panel">
            <h2>{{ contactPageSettings.whenTitle }}</h2>
            <div class="contact-stats">
                {% for item in contactPageSettings.whenItems %}
                    <div class="contact-feature">
                        <div class="contact-feature-icon {{ loop.index == 1 ? 'blue' : (loop.index == 2 ? 'green' : 'orange') }}">{{ item.badge }}</div>
                        <h3>{{ item.title }}</h3>
                        <p>{{ item.description }}</p>
                    </div>
                {% endfor %}
            </div>
        </article>

        {% if homeSupportWidget.links is not empty %}
            <aside class="contact-panel">
                <h2>{{ contactPageSettings.extraHelpTitle }}</h2>
                <p>{{ contactPageSettings.extraHelpIntro }}</p>
                <div class="contact-support-links">
                    {% for item in homeSupportWidget.links %}
                        <a href="{{ item.url }}">
                            <span>{{ item.title }}</span>
                            <span>›</span>
                        </a>
                    {% endfor %}
                </div>
            </aside>
        {% endif %}
    </section>
{% endblock %}

{% block page_footer %}
    <footer class="home-footer">
        <div class="home-footer-inner">
            <nav class="footer-links" aria-label="Sidfot">
                <a href="{{ path('app_home') }}">Startsida</a>
                <a href="{{ path('app_news_index') }}">Senaste Nytt</a>
