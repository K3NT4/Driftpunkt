{% extends 'base.html.twig' %}

{% block title %}Driftpunkt | Driftstatus{% endblock %}
{% block page_shell_class %}home-shell{% endblock %}
{% block body_class %}home-landing{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        :root {
            --home-text: #283474;
            --home-text-soft: #54618e;
            --home-line: rgba(177, 186, 241, 0.42);
            --home-surface: rgba(255, 255, 255, 0.78);
            --home-surface-strong: rgba(255, 255, 255, 0.9);
            --home-shadow: 0 24px 60px rgba(87, 101, 177, 0.16);
            --home-blue: #2f59df;
            --home-purple: #7f42df;
            --home-green: #3aa16b;
            --home-orange: #f59b41;
        }

        body.home-landing {
            background:
                radial-gradient(circle at 18% 14%, rgba(148, 162, 255, 0.48), transparent 28%),
                radial-gradient(circle at 86% 12%, rgba(255, 222, 212, 0.66), transparent 24%),
                radial-gradient(circle at 50% 100%, rgba(103, 110, 255, 0.3), transparent 24%),
                linear-gradient(180deg, #7785d6 0%, #a9aff0 16%, #cbc7f5 38%, #d8d0f7 52%, #c7c8f8 67%, #a4aff0 100%);
            color: var(--home-text);
        }

        body.home-landing::before {
            background:
                radial-gradient(ellipse at 18% 32%, rgba(255, 255, 255, 0.36), transparent 26%),
                radial-gradient(ellipse at 55% 46%, rgba(255, 255, 255, 0.4), transparent 34%),
                radial-gradient(ellipse at 82% 68%, rgba(255, 255, 255, 0.28), transparent 24%),
                linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0));
            mask-image: none;
            opacity: 1;
        }

        body.home-landing::after {
            content: "";
            position: fixed;
            inset: 0;
            pointer-events: none;
            background:
                radial-gradient(circle at 20% 18%, rgba(255, 255, 255, 0.95) 0 2px, transparent 3px),
                radial-gradient(circle at 82% 26%, rgba(255, 255, 255, 0.88) 0 2px, transparent 3px),
                radial-gradient(circle at 14% 74%, rgba(255, 255, 255, 0.7) 0 2px, transparent 3px),
                radial-gradient(circle at 74% 86%, rgba(255, 255, 255, 0.78) 0 2px, transparent 3px);
            opacity: 0.9;
        }

        .home-shell {
            width: calc(100% - 2rem);
            padding: 0 0 2.5rem;
        }

        .home-topbar,
        .home-footer {
            margin: 0 calc(50% - 50vw);
        }

        .home-topbar {
            background:
                linear-gradient(180deg, rgba(79, 88, 170, 0.92), rgba(71, 80, 156, 0.88)),
                linear-gradient(90deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0));
            border-bottom: 1px solid rgba(255, 255, 255, 0.16);
            box-shadow: 0 14px 36px rgba(56, 63, 125, 0.18);
            backdrop-filter: blur(12px);
        }

        .home-topbar-inner,
        .home-statusbar-inner,
        .home-footer-inner {
            width: calc(100% - 2rem);
            margin: 0 auto;
        }

        .home-topbar-inner {
            min-height: 68px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1.25rem;
        }

        .home-brand {
            display: inline-flex;
            align-items: center;
            gap: 0.85rem;
            color: #fff;
            font-family: "Space Grotesk", "Manrope", sans-serif;
            font-size: 1.1rem;
            font-weight: 700;
            text-decoration: none;
            letter-spacing: -0.02em;
        }

        .home-brand-mark {
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .home-brand-logo {
            height: 2.55rem;
            width: auto;
            display: block;
            filter: drop-shadow(0 12px 20px rgba(14, 39, 119, 0.24));
        }

        .home-nav {
            display: flex;
            align-items: center;
            gap: 1.35rem;
            color: rgba(255, 255, 255, 0.9);
        }

        .home-nav-link {
            color: inherit;
            text-decoration: none;
            font-size: 1rem;
            font-weight: 500;
        }

        .home-login-button {
            background: linear-gradient(180deg, #ffbf61 0%, #f5a332 100%);
            box-shadow: 0 18px 34px rgba(245, 163, 50, 0.28);
        }

        .home-statusbar {
            background: rgba(108, 117, 203, 0.34);
            border-top: 1px solid rgba(255, 255, 255, 0.08);
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        }

        .home-statusbar-inner {
            min-height: 42px;
            display: flex;
            align-items: center;
            gap: 0.8rem;
            color: rgba(255, 255, 255, 0.92);
            font-size: 0.95rem;
            flex-wrap: wrap;
        }

        .status-sep {
            opacity: 0.58;
        }

        .status-ok-dot {
            width: 1.35rem;
            height: 1.35rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.18);
            font-weight: 800;
        }

        .status-page {
            display: grid;
            gap: 1rem;
            margin-top: 1.35rem;
        }

        .status-hero,
        .status-panel,
        .system-card,
        .news-card {
            overflow: hidden;
            background: rgba(255, 255, 255, 0.72);
            border: 1px solid rgba(181, 190, 241, 0.42);
            border-radius: 24px;
            box-shadow: 0 24px 60px rgba(87, 101, 177, 0.14);
        }

        .status-hero {
            position: relative;
            padding: 2rem 2rem 1.7rem;
            background:
                linear-gradient(180deg, rgba(255, 255, 255, 0.9) 0%, rgba(248, 247, 255, 0.84) 100%);
        }

        .status-hero::after {
            content: "";
            position: absolute;
            inset: auto -3rem -4rem auto;
            width: 14rem;
            height: 14rem;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(102, 120, 245, 0.22), transparent 68%);
            pointer-events: none;
        }

        .status-eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            padding: 0.48rem 0.82rem;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.68);
            color: #39498c;
            font-size: 0.8rem;
            font-weight: 800;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .status-title {
            margin: 0.9rem 0 0.65rem;
            font-size: clamp(2.8rem, 5vw, 4.5rem);
            line-height: 0.98;
            letter-spacing: -0.04em;
            color: #243174;
        }

        .status-subtitle {
            max-width: 62ch;
            margin: 0;
            color: #4e5a86;
            font-size: 1.06rem;
            line-height: 1.7;
        }

        .status-hero-chips {
            display: flex;
            flex-wrap: wrap;
            gap: 0.7rem;
            margin-top: 1rem;
        }

        .status-hero-chip {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            padding: 0.52rem 0.82rem;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.72);
            border: 1px solid rgba(187, 196, 241, 0.52);
            color: #41518e;
            font-size: 0.92rem;
            font-weight: 700;
        }

        .status-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
            margin-top: 1.35rem;
        }

        .status-split {
            display: grid;
            gap: 1rem;
            grid-template-columns: minmax(0, 1.05fr) minmax(280px, 0.95fr);
        }

        .status-panel {
            padding: 1.2rem;
        }

        .status-panel h2 {
            margin: 0 0 0.7rem;
            color: #273372;
            font-size: 1.35rem;
        }

        .status-note {
            color: #4c5b86;
            line-height: 1.65;
        }

        .status-pill {
            display: inline-flex;
            width: fit-content;
            align-items: center;
            gap: 0.45rem;
            padding: 0.4rem 0.72rem;
            border-radius: 999px;
            font-weight: 800;
            font-size: 0.8rem;
        }

        .status-pill.active {
            color: #8d1d14;
            background: rgba(180, 35, 24, 0.1);
        }

        .status-pill.upcoming {
            color: #8a5d1c;
            background: rgba(239, 177, 84, 0.16);
        }

        .status-pill.ok {
            color: #257a52;
            background: rgba(52, 168, 108, 0.14);
        }

        .status-meta {
            display: grid;
            gap: 0.55rem;
            margin-top: 0.9rem;
            color: #59698e;
        }

        .section-heading {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 0.85rem;
        }

        .heading-icon {
            width: 2rem;
            height: 2rem;
            border-radius: 14px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(180deg, #6c8cff, #3e67e6);
            color: #fff;
            box-shadow: 0 14px 24px rgba(86, 113, 221, 0.24);
        }

        .section-heading h2 {
            margin: 0;
            color: #273372;
            font-size: 1.9rem;
        }

        .status-copy {
            margin: 0 0 0.9rem;
            color: #4c5b86;
            font-size: 0.98rem;
        }

        .status-overview-grid {
            display: grid;
            gap: 0.85rem;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        }

        .system-card-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.75rem;
            padding: 0.9rem 0.9rem 0.72rem;
        }

        .system-card-title {
            display: inline-flex;
            align-items: center;
            gap: 0.65rem;
            color: #2d397a;
            font-size: 1.02rem;
            font-weight: 700;
        }

        .system-icon {
            width: 1.6rem;
            height: 1.6rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 0.55rem;
            background: linear-gradient(180deg, #eef1ff, #dfe6ff);
            color: #3763db;
            font-size: 0.82rem;
        }

        .system-pill {
            padding: 0.28rem 0.56rem;
            border-radius: 999px;
            font-size: 0.76rem;
            color: #8c7034;
            background: #fbefc9;
        }

        .system-body {
            padding: 0 0.9rem 0.82rem;
            color: #495887;
        }

        .system-card-meta {
            display: grid;
            gap: 0.4rem;
            margin-top: 0.75rem;
            color: #5d6c91;
            font-size: 0.88rem;
        }

        .system-state {
            display: flex;
            align-items: center;
            gap: 0.65rem;
            font-size: 0.92rem;
        }

        .system-state .ok {
            color: #32a163;
            font-weight: 700;
        }

        .system-card-yellow .system-pill,
        .system-state-yellow .ok {
            color: #a76a12;
        }

        .system-card-red .system-pill,
        .system-state-red .ok {
            color: #b93f33;
        }

        .system-card-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            padding: 0.74rem 0.9rem;
            border-top: 1px solid rgba(191, 198, 239, 0.42);
            background: linear-gradient(180deg, rgba(241, 244, 255, 0.7), rgba(233, 238, 255, 0.9));
            color: #4166d8;
            font-size: 0.92rem;
        }

        .system-card-footer a,
        .status-link {
            color: inherit;
            text-decoration: none;
            font-weight: 700;
        }

        .impact-grid {
            display: grid;
            gap: 0.85rem;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        }

        .impact-card {
            padding: 1rem 1.05rem;
            border-radius: 18px;
            background: rgba(255, 255, 255, 0.78);
            border: 1px solid rgba(181, 190, 241, 0.42);
        }

        .impact-card-head {
            display: flex;
            justify-content: space-between;
            gap: 0.75rem;
            align-items: center;
        }

        .impact-card h3 {
            margin: 0;
            color: #2b3878;
            font-size: 1rem;
        }

        .impact-badge {
            display: inline-flex;
            align-items: center;
            padding: 0.3rem 0.62rem;
            border-radius: 999px;
            font-size: 0.78rem;
            font-weight: 800;
        }

        .impact-badge.ok {
            color: #257a52;
            background: rgba(52, 168, 108, 0.14);
        }

        .impact-badge.upcoming {
            color: #8a5d1c;
            background: rgba(239, 177, 84, 0.16);
        }

        .impact-badge.active {
            color: #8d1d14;
            background: rgba(180, 35, 24, 0.1);
        }

        .impact-card p {
            margin: 0.7rem 0 0;
            color: #5f6c90;
            line-height: 1.6;
        }

        .status-subscribe {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .status-subscribe-copy {
            display: grid;
            gap: 0.5rem;
            max-width: 60ch;
        }

        .status-subscribe-copy h2,
        .status-subscribe-copy p {
            margin: 0;
        }

        .timeline {
            display: grid;
            gap: 0.8rem;
            margin-top: 1rem;
        }

        .news-card {
            padding: 1rem 1.05rem;
            border-radius: 18px;
        }

        .news-item-head {
            display: flex;
            justify-content: space-between;
            gap: 1rem;
            flex-wrap: wrap;
            align-items: center;
            margin-bottom: 0.45rem;
        }

        .news-card h3 {
            margin: 0;
            color: #2b3878;
            font-size: 1.05rem;
        }

        .news-card p {
            margin: 0;
            color: #5f6c90;
            line-height: 1.65;
        }

        .timeline-status {
            padding: 0.28rem 0.62rem;
            border-radius: 999px;
            font-size: 0.78rem;
            font-weight: 800;
        }

        .timeline-status.active {
            color: #8d1d14;
            background: rgba(180, 35, 24, 0.1);
        }

        .timeline-status.upcoming {
            color: #8a5d1c;
            background: rgba(239, 177, 84, 0.16);
        }

        .timeline-status.completed {
            color: #55647f;
            background: rgba(119, 132, 178, 0.12);
        }

        .timeline-status.scheduled {
            color: #3d4f90;
            background: rgba(89, 111, 230, 0.12);
        }

        .home-footer {
            margin-top: 1.75rem;
            padding: 0.8rem 0 0;
            background:
                linear-gradient(180deg, rgba(90, 100, 186, 0.42), rgba(98, 110, 198, 0.38)),
                linear-gradient(90deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.02));
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.12);
        }

        .home-footer-inner {
            display: flex;
            align-items: center;
            justify-content: flex-start;
            gap: 0.9rem;
            min-height: 56px;
        }

        .footer-links {
            display: flex;
            align-items: center;
            gap: 1.2rem;
            flex-wrap: wrap;
            color: rgba(255, 255, 255, 0.9);
            font-size: 0.95rem;
        }

        .footer-links a {
            color: inherit;
            text-decoration: none;
        }

        .icon-display::before { content: "▣"; }
        .icon-db::before { content: "▤"; }
        .icon-api::before { content: "⌘"; font-size: 0.88rem; }
        .icon-gear::before { content: "⚙"; }
        .icon-spark::before { content: "✦"; }
        .icon-book::before { content: "⌂"; }
        .icon-check::before { content: "✓"; }

        .system-icon::before {
            line-height: 1;
        }

        @media (max-width: 980px) {
            .home-topbar-inner,
            .home-footer-inner,
            .status-split,
            .status-overview-grid {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 720px) {
            .home-shell {
                width: calc(100% - 1rem);
            }

            .home-topbar-inner {
                min-height: auto;
                padding: 1rem 0;
                flex-direction: column;
                align-items: stretch;
            }

            .home-nav {
                justify-content: space-between;
                flex-wrap: wrap;
                gap: 0.9rem;
            }

            .home-statusbar-inner {
                padding: 0.7rem 0;
                flex-wrap: wrap;
            }
        }
    </style>
{% endblock %}

{% block topbar %}
    <header class="home-topbar">
        <div class="home-topbar-inner">
            <a class="home-brand" href="{{ path('app_home') }}">
                <span class="home-brand-mark">
                    <img class="home-brand-logo" src="/assets/branding/driftpunkt-logo-full.png" alt="Driftpunkt">
                </span>
            </a>
            <nav class="home-nav" aria-label="Huvudnavigering">
                <a class="home-nav-link" href="{{ path('app_home') }}">Startsida</a>
                <a class="home-nav-link" href="{{ path('app_news_index') }}">Nyheter</a>
                <a class="home-nav-link" href="{{ path('app_status_page') }}">Driftstatus</a>
                <a class="home-nav-link" href="{{ path('app_contact') }}">Kontakta oss</a>
                <a class="button home-login-button" href="{{ app.user ? path('app_portal_entry') : path('app_login') }}">Logga in</a>
            </nav>
        </div>
        <div class="home-statusbar">
            <div class="home-statusbar-inner">
                <span class="status-ok-dot" aria-hidden="true">{{ maintenanceState.effectiveEnabled ? '!' : (maintenanceState.isUpcoming ? '•' : '✓') }}</span>
                <span>{{ maintenanceState.statusLabel }}</span>
                {% if maintenanceScheduleLabel %}
                    <span class="status-sep">•</span>
                    <span>Fönster: <strong>{{ maintenanceScheduleLabel }}</strong></span>
                {% endif %}
                <span class="status-sep">•</span>
                <a href="{{ path('app_news_index') }}" style="color: inherit; text-decoration: none;">Senaste driftinfo</a>
            </div>
        </div>
    </header>
{% endblock %}

{% block body %}
    <div class="status-page">
        <section class="status-hero">
            <span class="status-eyebrow">Publik driftstatus</span>
            <h1 class="status-title">{{ heroMaintenanceMeta.title }}</h1>
            <p class="status-subtitle">{{ heroMaintenanceMeta.summary }}</p>
            {% if heroMaintenanceMeta.chips is not empty %}
                <div class="status-hero-chips">
                    {% for chip in heroMaintenanceMeta.chips %}
                        <span class="status-hero-chip">{{ chip }}</span>
                    {% endfor %}
                </div>
            {% endif %}
            <div class="status-actions">
                <a class="button" href="{{ path('app_contact') }}">Kontakta support</a>
                <a class="button secondary" href="{{ path('app_news_index') }}">Se alla nyheter</a>
            </div>
        </section>

        <div class="status-split">
            <section class="status-panel">
                <div class="section-heading">
                    <span class="heading-icon" aria-hidden="true">✓</span>
                    <h2>Nuvarande läge</h2>
                </div>
                {% if maintenanceState.effectiveEnabled %}
                    <span class="status-pill active">Underhåll aktivt</span>
                {% elseif maintenanceState.isUpcoming %}
                    <span class="status-pill upcoming">Schemalagt underhåll</span>
                {% else %}
                    <span class="status-pill ok">Normal drift</span>
                {% endif %}

                <p class="status-note" style="margin-top: 0.9rem;">
                    {{ maintenanceState.message ?: 'Inga aktiva driftstopp är registrerade just nu. Planerade underhåll visas längre ner så att kunder och tekniker kan förbereda sig i tid.' }}
                </p>

                <div class="status-meta">
                    <span><strong>Status:</strong> {{ maintenanceState.statusLabel }}</span>
                    {% if maintenanceScheduleLabel %}
                        <span><strong>Underhållsfönster:</strong> {{ maintenanceScheduleLabel }}</span>
                    {% endif %}
                    {% if maintenanceState.updatedAt %}
                        <span><strong>Senast uppdaterad:</strong> {{ maintenanceState.updatedAt|date('Y-m-d H:i') }}</span>
                    {% endif %}
                </div>
            </section>

            <aside class="status-panel">
                <div class="section-heading">
                    <span class="heading-icon" style="background: linear-gradient(180deg, #ffb558, #ef9034);" aria-hidden="true">!</span>
                    <h2>Vad betyder det här?</h2>
                </div>
                <p class="status-note">
                    Under aktivt underhåll hålls status- och kontaktsidorna öppna, medan kund- och teknikerinloggning pausas tills arbetet är klart. Om underhåll bara är schemalagt kan ni fortsätta arbeta som vanligt fram till starttiden.
                </p>
                <div class="status-meta">
                    <span><strong>Kundlogin:</strong> {{ maintenanceState.effectiveEnabled ? 'Tillfälligt pausad' : 'Tillgänglig' }}</span>
                    <span><strong>Teknikerlogin:</strong> {{ maintenanceState.effectiveEnabled ? 'Tillfälligt pausad' : 'Tillgänglig' }}</span>
                    <span><strong>Admin:</strong> Tillgänglig för verifiering</span>
                </div>
            </aside>
        </div>

        <section class="status-panel">
            <div class="section-heading">
                <span class="heading-icon" aria-hidden="true">✓</span>
                <h2>Systemstatus</h2>
            </div>
            <p class="status-copy">Överblick över Driftpunkt och externa tjänster som admin valt att visa publikt.</p>
            <div class="status-overview-grid">
                {% for system in systemStatuses|default([]) %}
                    {% set systemSourceLabel = system.type == 'site'
                        ? 'Intern driftstatus'
                        : (system.type == 'url'
                            ? 'URL-kontroll'
                            : (system.type == 'host'
                                ? 'Host-kontroll'
                                : (system.type == 'downdetector'
                                    ? 'Downdetector'
                                    : (system.type == 'isitdownrightnow' ? 'IsItDownRightNow' : 'Manuell')))) %}
                    <article class="system-card system-card-{{ system.health|default('green') }}">
                        <div class="system-card-top">
                            <div class="system-card-title">
                                <span class="system-icon icon-{{ system.icon|default('display') }}" aria-hidden="true"></span>
                                {{ system.name }}
                            </div>
                            {% if system.pill %}
                                <span class="system-pill">{{ system.pill }}</span>
                            {% else %}
                                <span aria-hidden="true">›</span>
                            {% endif %}
                        </div>
                        <div class="system-body">
                            <div class="system-state system-state-{{ system.health|default('green') }}"><span class="ok">{{ system.statusSymbol|default('✓') }}</span> {{ system.status }}</div>
                            {% if statusPageSettings.showSystemCheckedAt or statusPageSettings.showSystemSource %}
                                <div class="system-card-meta">
                                    {% if statusPageSettings.showSystemCheckedAt and system.checkedAt is defined and system.checkedAt %}
                                        <span><strong>Senast kontrollerad:</strong> {{ system.checkedAt }}</span>
                                    {% endif %}
                                    {% if statusPageSettings.showSystemSource %}
                                        <span><strong>Källa:</strong> {{ systemSourceLabel }}</span>
                                    {% endif %}
                                </div>
                            {% endif %}
                        </div>
                        <div class="system-card-footer">
                            {% if system.url and system.linkLabel %}
                                <a href="{{ system.url }}">{{ system.linkLabel }}</a>
                            {% else %}
                                <span>{{ system.stateLabel|default('Operational') }}</span>
                            {% endif %}
                            <span aria-hidden="true">›</span>
                        </div>
                    </article>
                {% endfor %}
            </div>
        </section>

        {% if statusPageSettings.showImpact and impactStatuses is not empty %}
            <section class="status-panel">
                <div class="section-heading">
                    <span class="heading-icon" style="background: linear-gradient(180deg, #ffb558, #ef9034);" aria-hidden="true">!</span>
                    <h2>{{ statusPageSettings.impactTitle }}</h2>
                </div>
                <p class="status-copy">{{ statusPageSettings.impactIntro }}</p>
                <div class="impact-grid">
                    {% for item in impactStatuses %}
                        <article class="impact-card">
                            <div class="impact-card-head">
                                <h3>{{ item.name }}</h3>
                                <span class="impact-badge {{ item.tone }}">{{ item.label }}</span>
                            </div>
                            {% if item.description %}
                                <p>{{ item.description }}</p>
                            {% endif %}
                        </article>
                    {% endfor %}
                </div>
            </section>
        {% endif %}

        {% if statusPageSettings.showRecentUpdates %}
            <section class="status-panel">
                <div class="section-heading">
                    <span class="heading-icon" style="background: linear-gradient(180deg, #6c8cff, #3e67e6);" aria-hidden="true">◔</span>
                    <h2>{{ statusPageSettings.recentUpdatesTitle }}</h2>
                </div>
                <p class="status-copy">{{ statusPageSettings.recentUpdatesIntro }}</p>
                <div class="timeline">
                    {% if recentNews is not empty %}
                        {% for article in recentNews %}
                            {% set maintenance = maintenanceStatuses[article.id] ?? null %}
                            <article class="news-card">
                                <div class="news-item-head">
                                    <h3>{{ article.title }}</h3>
                                    {% if maintenance %}
                                        <span class="timeline-status {{ maintenance.status }}">{{ maintenance.label }}</span>
                                    {% else %}
                                        <span class="timeline-status scheduled">Publicerad</span>
                                    {% endif %}
                                </div>
                                <p>{{ article.summary }}</p>
                                <div class="status-meta" style="margin-top: 0.8rem;">
                                    <span><strong>Publicerad:</strong> {{ article.publishedAt ? article.publishedAt|date('Y-m-d H:i') : article.updatedAt|date('Y-m-d H:i') }}</span>
                                    <a class="status-link" href="{{ path('app_news_show', {id: article.id}) }}">Öppna uppdateringen</a>
                                </div>
                            </article>
                        {% endfor %}
                    {% else %}
                        <article class="news-card">
                            <div class="news-item-head">
                                <h3>Inga driftuppdateringar publicerade ännu</h3>
                                <span class="timeline-status scheduled">Lugnt</span>
                            </div>
                            <p>Nar nya driftmeddelanden och uppdateringar publiceras visas de har automatiskt.</p>
                        </article>
                    {% endif %}
                </div>
            </section>
        {% endif %}

        {% if statusPageSettings.showHistory %}
            <section class="status-panel">
                <div class="section-heading">
                    <span class="heading-icon" style="background: linear-gradient(180deg, #6c8cff, #3e67e6);" aria-hidden="true">◔</span>
                    <h2>Planerade underhåll och historik</h2>
                </div>
                <p class="status-copy">Här samlar vi publicerade driftfönster från nyhetsmodulen, tillsammans med deras aktuella status.</p>
                <div class="timeline">
                    {% if maintenanceArticles is not empty %}
                        {% for article in maintenanceArticles %}
                            {% set maintenance = maintenanceStatuses[article.id] ?? null %}
                            <article class="news-card">
                                <div class="news-item-head">
                                    <h3>{{ article.title }}</h3>
                                    {% if maintenance %}
                                        <span class="timeline-status {{ maintenance.status }}">{{ maintenance.label }}</span>
                                    {% endif %}
                                </div>
                                <p>{{ article.summary }}</p>
                                <div class="status-meta" style="margin-top: 0.8rem;">
                                    {% if maintenance and maintenance.schedule %}
                                        <span><strong>Tid:</strong> {{ maintenance.schedule }}</span>
                                    {% endif %}
                                    <a class="status-link" href="{{ path('app_news_show', {id: article.id}) }}">Öppna driftinformationen</a>
                                </div>
                            </article>
                        {% endfor %}
                    {% else %}
                        <article class="news-card">
                            <div class="news-item-head">
                                <h3>Inga planerade underhåll publicerade</h3>
                                <span class="timeline-status scheduled">Lugnt</span>
                            </div>
                            <p>Just nu finns inget publicerat driftfönster i nyhetsflödet.</p>
                        </article>
                    {% endif %}
                </div>
            </section>
        {% endif %}

        {% if statusPageSettings.showSubscribeBox %}
            <section class="status-panel status-subscribe">
                <div class="status-subscribe-copy">
                    <h2>{{ statusPageSettings.subscribeTitle }}</h2>
                    <p class="status-copy">{{ statusPageSettings.subscribeText }}</p>
                </div>
                {% if statusPageSettings.subscribeLinkUrl %}
                    <a class="button secondary" href="{{ statusPageSettings.subscribeLinkUrl }}">{{ statusPageSettings.subscribeLinkLabel }}</a>
                {% endif %}
            </section>
        {% endif %}
    </div>
{% endblock %}

{% block page_footer %}
    <footer class="home-footer">
        <div class="home-footer-inner">
            <nav class="footer-links" aria-label="Sidfot">
                <a href="{{ path('app_home') }}">Startsida</a>
                <a href="{{ path('app_news_index') }}">Senaste Nytt</a>
                <a href="{{ path('app_status_page') }}">Driftstatus</a>
                <a href="{{ path('app_contact') }}">Kontakta oss</a>
            </nav>
        </div>
    </footer>
{% endblock %}
