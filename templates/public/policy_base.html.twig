{% extends 'base.html.twig' %}

{% block title %}{{ site_branding.name }} | {{ policy.title }}{% endblock %}
{% block page_shell_class %}home-shell{% endblock %}
{% block body_class %}home-landing policy-page{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        :root {
            --home-text: #283474;
            --home-text-soft: #54618e;
            --home-line: rgba(177, 186, 241, 0.42);
            --home-surface: rgba(255, 255, 255, 0.78);
            --home-surface-strong: rgba(255, 255, 255, 0.9);
            --home-shadow: 0 24px 60px rgba(87, 101, 177, 0.16);
            --home-blue: #2f59df;
            --home-green: #3aa16b;
        }

        body.home-landing.policy-page {
            background:
                radial-gradient(circle at 18% 14%, rgba(148, 162, 255, 0.48), transparent 28%),
                radial-gradient(circle at 86% 12%, rgba(255, 222, 212, 0.66), transparent 24%),
                radial-gradient(circle at 50% 100%, rgba(103, 110, 255, 0.3), transparent 24%),
                linear-gradient(180deg, #7785d6 0%, #a9aff0 16%, #cbc7f5 38%, #d8d0f7 52%, #c7c8f8 67%, #a4aff0 100%);
            color: var(--home-text);
        }

        body.home-landing.policy-page::before {
            background:
                radial-gradient(ellipse at 18% 32%, rgba(255, 255, 255, 0.36), transparent 26%),
                radial-gradient(ellipse at 55% 46%, rgba(255, 255, 255, 0.4), transparent 34%),
                radial-gradient(ellipse at 82% 68%, rgba(255, 255, 255, 0.28), transparent 24%),
                linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0));
            mask-image: none;
            opacity: 1;
        }

        body.home-landing.policy-page::after {
            content: "";
            position: fixed;
            inset: 0;
            pointer-events: none;
            background:
                radial-gradient(circle at 20% 18%, rgba(255, 255, 255, 0.95) 0 2px, transparent 3px),
                radial-gradient(circle at 82% 26%, rgba(255, 255, 255, 0.88) 0 2px, transparent 3px),
                radial-gradient(circle at 14% 74%, rgba(255, 255, 255, 0.7) 0 2px, transparent 3px),
                radial-gradient(circle at 74% 86%, rgba(255, 255, 255, 0.78) 0 2px, transparent 3px);
            opacity: 0.9;
        }

        .home-shell {
            width: calc(100% - 2rem);
            padding: 0 0 2.5rem;
        }

        .home-topbar,
        .home-footer {
            margin: 0 calc(50% - 50vw);
        }

        .home-topbar {
            background:
                linear-gradient(180deg, rgba(79, 88, 170, 0.92), rgba(71, 80, 156, 0.88)),
                linear-gradient(90deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0));
            border-bottom: 1px solid rgba(255, 255, 255, 0.16);
            box-shadow: 0 14px 36px rgba(56, 63, 125, 0.18);
            backdrop-filter: blur(12px);
        }

        .home-topbar-inner,
        .home-statusbar-inner,
        .home-footer-inner {
            width: calc(100% - 2rem);
            margin: 0 auto;
        }

        .home-topbar-inner {
            min-height: 68px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1.25rem;
        }

        .home-brand {
            display: inline-flex;
            align-items: center;
            gap: 0.85rem;
            color: #fff;
            font-family: "Space Grotesk", "Manrope", sans-serif;
            font-size: 1.1rem;
            font-weight: 700;
            text-decoration: none;
            letter-spacing: -0.02em;
        }

        .home-brand-logo {
            height: 2.55rem;
            width: auto;
            display: block;
            filter: drop-shadow(0 12px 20px rgba(14, 39, 119, 0.24));
        }

        .home-nav {
            display: flex;
            align-items: center;
            gap: 1.35rem;
            color: rgba(255, 255, 255, 0.9);
        }

        .home-nav-link {
            color: inherit;
            text-decoration: none;
            font-size: 1rem;
            font-weight: 500;
        }

        .home-login-button {
            min-width: 104px;
            padding: 0.74rem 1.28rem;
            border-radius: 11px;
            background: linear-gradient(180deg, #ffbf61 0%, #f49b3c 100%);
            color: #fff;
            border: 1px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 10px 22px rgba(228, 142, 48, 0.32);
        }

        .home-statusbar {
            background: rgba(236, 226, 255, 0.28);
            border-top: 1px solid rgba(255, 255, 255, 0.12);
            border-bottom: 1px solid rgba(113, 117, 195, 0.16);
        }

        .home-statusbar-inner {
            min-height: 38px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.7rem;
            color: #56628f;
            font-size: 0.93rem;
            text-align: center;
        }

        .status-ok-dot {
            width: 1rem;
            height: 1rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            background: rgba(92, 118, 230, 0.16);
            color: #4e63c7;
            font-size: 0.72rem;
            font-weight: 700;
        }

        .status-sep {
            opacity: 0.55;
        }

        .policy-stage {
            max-width: 1180px;
            margin: 0 auto;
        }

        .policy-hero {
            position: relative;
            padding: 5.25rem 0 1.8rem;
            text-align: center;
        }

        .hero-wave {
            position: absolute;
            inset: 2.9rem 0 auto;
            height: 166px;
            overflow: hidden;
            pointer-events: none;
        }

        .hero-wave::before,
        .hero-wave::after {
            content: "";
            position: absolute;
            left: 50%;
            width: min(1100px, 120vw);
            transform: translateX(-50%);
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.24);
        }

        .hero-wave::before {
            top: 0;
            height: 124px;
            clip-path: polygon(0 58%, 10% 45%, 21% 50%, 33% 34%, 47% 44%, 62% 26%, 76% 38%, 100% 20%, 100% 100%, 0 100%);
        }

        .hero-wave::after {
            top: 20px;
            height: 114px;
            background: rgba(255, 255, 255, 0.18);
            clip-path: polygon(0 64%, 14% 48%, 27% 58%, 40% 40%, 58% 54%, 72% 34%, 87% 45%, 100% 30%, 100% 100%, 0 100%);
        }

        .policy-eyebrow {
            position: relative;
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            padding: 0.48rem 0.95rem;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.68);
            color: #4b5b96;
            font-size: 0.84rem;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            border: 1px solid rgba(188, 197, 244, 0.55);
            box-shadow: 0 16px 34px rgba(107, 121, 191, 0.12);
        }

        .policy-title {
            position: relative;
            margin: 1rem 0 0.8rem;
            font-size: clamp(2.8rem, 4.8vw, 4.2rem);
            line-height: 1.02;
            letter-spacing: -0.04em;
            color: #243174;
        }

        .policy-intro {
            position: relative;
            margin: 0 auto;
            max-width: 54rem;
            font-size: clamp(1.08rem, 1.7vw, 1.35rem);
            color: #44517e;
        }

        .policy-meta-row {
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            gap: 0.8rem;
            margin: 1.25rem 0 0;
            color: #49588f;
            font-size: 0.95rem;
        }

        .policy-meta-chip {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.55rem 0.9rem;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.72);
            border: 1px solid rgba(188, 197, 244, 0.48);
        }

        .policy-grid {
            display: grid;
            gap: 1rem;
            grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.72fr);
            align-items: start;
        }

        .policy-card,
        .policy-aside {
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.84) 0%, rgba(249, 247, 255, 0.76) 100%);
            border: 1px solid rgba(181, 190, 241, 0.38);
            border-radius: 20px;
            box-shadow: var(--home-shadow);
            backdrop-filter: blur(16px);
        }

        .policy-card {
            padding: 1.5rem;
        }

        .policy-body {
            display: grid;
            gap: 1rem;
            color: #4d5984;
            line-height: 1.72;
            font-size: 0.98rem;
        }

        .policy-body h2,
        .policy-body h3 {
            margin: 1.1rem 0 0.2rem;
            color: #2d3779;
            letter-spacing: -0.02em;
        }

        .policy-body p,
        .policy-body ul,
        .policy-body ol,
        .policy-body blockquote {
            margin: 0;
        }

        .policy-body ul,
        .policy-body ol {
            padding-left: 1.35rem;
        }

        .policy-body code {
            padding: 0.12rem 0.42rem;
            border-radius: 8px;
            background: rgba(72, 109, 236, 0.09);
            color: #32427c;
            font-size: 0.94em;
        }

        .policy-body a {
            color: #2f63e0;
            text-decoration: none;
            font-weight: 600;
        }

        .policy-aside {
            padding: 1.2rem;
            display: grid;
            gap: 0.85rem;
        }

        .policy-aside h2 {
            margin: 0;
            color: #2b3778;
            font-size: clamp(1.55rem, 2.2vw, 2rem);
            letter-spacing: -0.03em;
        }

        .policy-aside p {
            margin: 0;
            color: #4e5987;
            line-height: 1.56;
        }

        .policy-link-list {
            display: grid;
            gap: 0.6rem;
        }

        .policy-link {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            padding: 0.78rem 0.92rem;
            border-radius: 12px;
            border: 1px solid rgba(183, 192, 239, 0.58);
            background: rgba(255, 255, 255, 0.68);
            color: #44518a;
            text-decoration: none;
        }

        .policy-link strong {
            font-size: 0.95rem;
            font-weight: 600;
        }

        .policy-link span {
            color: #97a0cb;
            font-size: 1.15rem;
        }

        .home-footer {
            margin-top: 1.75rem;
            padding: 0.8rem 0 0;
            background:
                linear-gradient(180deg, rgba(90, 100, 186, 0.42), rgba(98, 110, 198, 0.38)),
                linear-gradient(90deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.02));
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.12);
        }

        .home-footer-inner {
            display: flex;
            align-items: center;
            justify-content: flex-start;
            gap: 0.9rem;
            min-height: 56px;
        }

        .footer-links {
            display: flex;
            align-items: center;
            gap: 1.2rem;
            flex-wrap: wrap;
            color: rgba(255, 255, 255, 0.9);
            font-size: 0.95rem;
        }

        .footer-links a {
            color: inherit;
            text-decoration: none;
        }

        .footer-links .active {
            font-weight: 700;
        }

        @media (max-width: 980px) {
            .policy-grid {
                grid-template-columns: 1fr;
            }

            .home-footer-inner {
                min-height: auto;
            }
        }

        @media (max-width: 720px) {
            .home-shell {
                width: calc(100% - 1rem);
            }

            .home-topbar-inner {
                min-height: auto;
                padding: 1rem 0;
                flex-direction: column;
                align-items: stretch;
            }

            .home-nav {
                justify-content: space-between;
                flex-wrap: wrap;
                gap: 0.9rem;
            }

            .home-statusbar-inner {
                padding: 0.55rem 0;
                flex-wrap: wrap;
            }

            .policy-hero {
                padding-top: 4.6rem;
            }

            .policy-card,
            .policy-aside {
                padding: 1.1rem;
            }
        }
    </style>
{% endblock %}

{% block topbar %}
    <header class="home-topbar">
        <div class="home-topbar-inner">
            <a class="home-brand" href="{{ path('app_home') }}">
                <img class="home-brand-logo" src="{{ site_branding.logoPath }}" alt="{{ site_branding.name }}">
                <span>{{ site_branding.name }}</span>
            </a>
            <nav class="home-nav" aria-label="{{ t('nav.search_main') }}">
                <a class="home-nav-link" href="{{ path('app_home') }}">{{ t('nav.home') }}</a>
                <a class="home-nav-link" href="{{ path('app_news_index') }}">{{ t('nav.news') }}</a>
                <a class="home-nav-link" href="{{ path('app_contact') }}">{{ t('nav.contact') }}</a>
                <a class="button home-login-button" href="{{ app.user ? path('app_portal_entry') : path('app_login', {role: 'customer'}) }}">{{ t('nav.login') }}</a>
            </nav>
        </div>
    </header>
    <div class="home-statusbar">
        <div class="home-statusbar-inner">
            <span class="status-ok-dot">✓</span>
            <span>{{ policy_status_text|default('Juridisk information och policyer') }}</span>
            <span class="status-sep">•</span>
            <a href="{{ path('app_status_page') }}" style="color: inherit; text-decoration: none;">Se driftstatus</a>
        </div>
    </div>
{% endblock %}

{% block body %}
    <section class="policy-stage">
        <header class="policy-hero">
            <div class="hero-wave" aria-hidden="true"></div>
            <span class="policy-eyebrow">{{ policy_eyebrow }}</span>
            <h1 class="policy-title">{{ policy.title }}</h1>
            <p class="policy-intro">{{ policy.intro }}</p>
            <div class="policy-meta-row">
                {% if policy.effectiveDate %}
                    <span class="policy-meta-chip">Senast uppdaterad: {{ policy.effectiveDate }}</span>
                {% endif %}
                {% if policy.contactEmail %}
                    <span class="policy-meta-chip">Kontakt: <a href="mailto:{{ policy.contactEmail }}">{{ policy.contactEmail }}</a></span>
                {% endif %}
            </div>
        </header>

        <section class="policy-grid">
            <article class="policy-card">
                <div class="policy-body">{{ policy.body|article_body }}</div>
            </article>

            <aside class="policy-aside">
                <h2>{{ aside_title|default('Snabbvägar') }}</h2>
                <p>{{ aside_copy|default('Här hittar du närliggande sidor och vägar vidare om du behöver mer hjälp eller vill läsa fler policyer.') }}</p>
                <div class="policy-link-list">
                    {% for item in policy_links %}
                        <a class="policy-link" href="{{ item.href }}"{% if item.external|default(false) %} target="_blank" rel="noopener noreferrer"{% endif %}>
                            <strong>{{ item.label }}</strong>
                            <span aria-hidden="true">›</span>
                        </a>
                    {% endfor %}
                </div>
            </aside>
        </section>
    </section>
{% endblock %}

{% block page_footer %}
    <footer class="home-footer">
        <div class="home-footer-inner">
            <nav class="footer-links" aria-label="Sidfot">
                <a href="{{ path('app_news_index') }}">Senaste Nytt</a>
                <a class="{{ app.request.attributes.get('_route') == 'app_privacy_policy' ? 'active' : '' }}" href="{{ path('app_privacy_policy') }}">Integritetspolicy</a>
                <a class="{{ app.request.attributes.get('_route') == 'app_terms_page' ? 'active' : '' }}" href="{{ path('app_terms_page') }}">Användarvillkor</a>
                <a class="{{ app.request.attributes.get('_route') == 'app_cookie_policy' ? 'active' : '' }}" href="{{ path('app_cookie_policy') }}">Cookiepolicy</a>
                <a href="{{ path('app_contact') }}">Kontakta oss</a>
                {% if site_branding.footerText %}
                    <span>{{ site_branding.footerText }}</span>
                {% endif %}
                <span>Version {{ site_branding.appVersion }}</span>
                <a href="{{ site_branding.githubUrl }}" target="_blank" rel="noopener noreferrer">{{ site_branding.copyrightLabel }}</a>
            </nav>
        </div>
    </footer>
{% endblock %}
