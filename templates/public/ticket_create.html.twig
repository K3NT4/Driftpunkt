{% extends 'base.html.twig' %}

{% block title %}{{ site_branding.name }} | Skapa ärende{% endblock %}
{% block page_shell_class %}home-shell public-ticket-shell{% endblock %}
{% block body_class %}home-landing public-ticket-page{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        body.public-ticket-page {
            background:
                radial-gradient(circle at 18% 14%, rgba(148, 162, 255, 0.48), transparent 28%),
                radial-gradient(circle at 86% 12%, rgba(255, 222, 212, 0.66), transparent 24%),
                linear-gradient(180deg, #7785d6 0%, #a9aff0 16%, #cbc7f5 42%, #a4aff0 100%);
            color: #283474;
        }

        .public-ticket-topbar,
        .public-ticket-footer {
            margin: 0 calc(50% - 50vw);
        }

        .public-ticket-topbar {
            background: linear-gradient(180deg, rgba(79, 88, 170, 0.92), rgba(71, 80, 156, 0.88));
            border-bottom: 1px solid rgba(255, 255, 255, 0.16);
            box-shadow: 0 14px 36px rgba(56, 63, 125, 0.18);
        }

        .public-ticket-topbar-inner,
        .public-ticket-footer-inner {
            width: calc(100% - 2rem);
            margin: 0 auto;
            min-height: 68px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
        }

        .public-ticket-brand img {
            height: 2.55rem;
            width: auto;
            display: block;
        }

        .public-ticket-nav {
            display: flex;
            align-items: center;
            gap: 1rem;
            color: rgba(255, 255, 255, 0.94);
            flex-wrap: wrap;
        }

        .public-ticket-nav a {
            color: inherit;
            text-decoration: none;
            font-weight: 700;
        }

        .public-ticket-main {
            display: grid;
            grid-template-columns: minmax(0, 1.1fr) minmax(280px, 0.55fr);
            gap: 1rem;
            padding: 2rem 0;
            align-items: start;
        }

        .public-ticket-card {
            padding: 1.35rem;
            border-radius: 8px;
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.88), rgba(249, 247, 255, 0.8));
            border: 1px solid rgba(181, 190, 241, 0.42);
            box-shadow: 0 24px 60px rgba(87, 101, 177, 0.16);
            backdrop-filter: blur(16px);
        }

        .public-ticket-card h1,
        .public-ticket-card h2 {
            margin: 0 0 0.65rem;
            color: #243174;
        }

        .public-ticket-copy {
            color: #54618e;
            line-height: 1.6;
        }

        .public-ticket-form {
            display: grid;
            gap: 0.9rem;
            margin-top: 1rem;
        }

        .public-ticket-grid {
            display: grid;
            gap: 0.9rem;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        }

        .public-ticket-field {
            display: grid;
            gap: 0.35rem;
            color: #2d397a;
            font-weight: 700;
        }

        .public-ticket-field input,
        .public-ticket-field select,
        .public-ticket-field textarea {
            width: 100%;
            padding: 0.86rem 1rem;
            border-radius: 8px;
            border: 1px solid rgba(177, 186, 241, 0.64);
            background: rgba(255, 255, 255, 0.92);
            color: #243174;
            font: inherit;
        }

        .public-ticket-field textarea {
            resize: vertical;
        }

        .public-ticket-hidden {
            position: absolute;
            left: -10000px;
            width: 1px;
            height: 1px;
            overflow: hidden;
        }

        .public-ticket-button {
            width: fit-content;
            padding: 0.82rem 1.25rem;
            border-radius: 8px;
            background: linear-gradient(180deg, #63b985 0%, #3b9c68 100%);
            color: #fff;
            border: 0;
            font-weight: 800;
            cursor: pointer;
            text-decoration: none;
        }

        .public-ticket-error {
            padding: 0.85rem 1rem;
            border-radius: 8px;
            background: rgba(180, 35, 24, 0.08);
            color: #9f2b22;
            border: 1px solid rgba(180, 35, 24, 0.2);
        }

        .public-ticket-success {
            display: grid;
            gap: 0.7rem;
        }

        .public-ticket-reference {
            width: fit-content;
            padding: 0.4rem 0.7rem;
            border-radius: 8px;
            background: rgba(58, 161, 107, 0.14);
            color: #28744d;
            font-weight: 900;
        }

        .public-ticket-footer {
            padding: 0.8rem 0 0;
            background: linear-gradient(180deg, rgba(90, 100, 186, 0.42), rgba(98, 110, 198, 0.38));
        }

        .public-ticket-footer-inner {
            min-height: 56px;
            justify-content: flex-start;
            color: rgba(255, 255, 255, 0.92);
            flex-wrap: wrap;
        }

        .public-ticket-footer-inner a {
            color: inherit;
            text-decoration: none;
        }

        @media (max-width: 840px) {
            .public-ticket-main {
                grid-template-columns: 1fr;
            }

            .public-ticket-topbar-inner {
                flex-direction: column;
                align-items: stretch;
                padding: 1rem 0;
            }
        }
    </style>
{% endblock %}

{% block topbar %}
    <header class="public-ticket-topbar">
        <div class="public-ticket-topbar-inner">
            <a class="public-ticket-brand" href="{{ path('app_home') }}">
                <img src="{{ site_branding.logoPath }}" alt="{{ site_branding.name }}">
            </a>
            <nav class="public-ticket-nav" aria-label="Publik navigation">
                <a href="{{ path('app_home') }}">Startsida</a>
                <a href="{{ path('app_status_page') }}">Driftstatus</a>
                <a href="{{ path('app_contact') }}">Kontakta oss</a>
                <a class="button home-login-button" href="{{ path('app_login') }}">Logga in</a>
            </nav>
        </div>
    </header>
{% endblock %}

{% block body %}
    <main class="public-ticket-main">
        <section class="public-ticket-card">
            {% if ticketCreated %}
                <div class="public-ticket-success">
                    <h1>Ärendet har skapats</h1>
                    <p class="public-ticket-copy">Vi har tagit emot din förfrågan och återkommer via kontaktuppgifterna du angav.</p>
                    <a class="public-ticket-button" href="{{ path('app_home') }}">Till startsidan</a>
                </div>
            {% else %}
                <h1>Skapa ärende</h1>
                <p class="public-ticket-copy">Beskriv vad du behöver hjälp med så skapar vi ett nytt supportärende.</p>
                {% if formError %}
                    <div class="public-ticket-error">{{ formError }}</div>
                {% endif %}
                <form method="post" action="{{ path('app_public_ticket_create') }}" class="public-ticket-form" enctype="multipart/form-data">
                    <input type="hidden" name="_token" value="{{ csrf_token('public_create_ticket') }}">
                    <label class="public-ticket-hidden">Webbplats <input type="text" name="website" value=""></label>
                    <div class="public-ticket-grid">
                        <label class="public-ticket-field">Namn <input type="text" name="name" value="{{ defaults.name }}" required></label>
                        <label class="public-ticket-field">E-post <input type="email" name="email" value="{{ defaults.email }}" required></label>
                        <label class="public-ticket-field">Telefon <input type="text" name="phone" value="{{ defaults.phone }}"></label>
                    </div>
                    <label class="public-ticket-field">Ämne <input type="text" name="subject" value="{{ defaults.subject }}" maxlength="180" required></label>
                    <label class="public-ticket-field">Beskrivning <textarea name="summary" rows="7" required>{{ defaults.summary }}</textarea></label>
                    <div class="public-ticket-grid">
                        <label class="public-ticket-field">Kategori
                            <select name="category_id">
                                <option value="">Ingen kategori</option>
                                {% for category in categories %}
                                    <option value="{{ category.id }}" {{ defaults.category_id == (category.id ~ '') ? 'selected' }}>{{ category.name }}</option>
                                {% endfor %}
                            </select>
                        </label>
                        <label class="public-ticket-field">Ärendetyp
                            <select name="request_type">
                                {% for requestType in ticketRequestTypes %}
                                    <option value="{{ requestType.value }}" {{ defaults.request_type == requestType.value ? 'selected' }}>{{ requestType.label }}</option>
                                {% endfor %}
                            </select>
                        </label>
                        <label class="public-ticket-field">Påverkan
                            <select name="impact_level">
                                {% for impactLevel in ticketImpactLevels %}
                                    <option value="{{ impactLevel.value }}" {{ defaults.impact_level == impactLevel.value ? 'selected' }}>{{ impactLevel.label }}</option>
                                {% endfor %}
                            </select>
                        </label>
                    </div>
                    {% if ticketAttachmentSettings.enabled %}
                        <div class="public-ticket-grid">
                            <label class="public-ticket-field">Bilaga
                                <input type="file" name="attachment">
                            </label>
                            {% if ticketAttachmentSettings.externalUploadsEnabled %}
                                <label class="public-ticket-field">Extern bilagelänk
                                    <input type="url" name="external_attachment_url" value="{{ defaults.external_attachment_url }}" maxlength="1000">
                                </label>
                                <label class="public-ticket-field">Namn på extern bilaga
                                    <input type="text" name="external_attachment_label" value="{{ defaults.external_attachment_label }}" maxlength="255">
                                </label>
                            {% endif %}
                        </div>
                    {% endif %}
                    <button class="public-ticket-button" type="submit">Skicka ärende</button>
                </form>
            {% endif %}
        </section>
        <aside class="public-ticket-card">
            <h2>Snabbare hjälp</h2>
            <p class="public-ticket-copy">Skriv vad som påverkas, när problemet började och vad du redan har testat. Har du redan ett konto kopplas ärendet automatiskt via din e-postadress.</p>
        </aside>
    </main>
{% endblock %}

{% block page_footer %}
    <footer class="public-ticket-footer">
        <div class="public-ticket-footer-inner">
            <a href="{{ path('app_privacy_policy') }}">Integritetspolicy</a>
            <a href="{{ path('app_terms_page') }}">Användarvillkor</a>
            <a href="{{ path('app_contact') }}">Kontakta oss</a>
            <span>Version {{ site_branding.appVersion }}</span>
            <a href="{{ site_branding.githubUrl }}" target="_blank" rel="noopener noreferrer">{{ site_branding.copyrightLabel }}</a>
        </div>
    </footer>
{% endblock %}
