<!DOCTYPE html>
<html lang="{{ app.request.locale|default('sv') }}">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}{{ site_branding.name }}{% endblock %}</title>
        <link rel="icon" href="{{ site_branding.iconPath }}">
        {% block stylesheets %}
            <style>
                @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap');

                :root {
                    color-scheme: light;
                    --bg: #f3efe6;
                    --bg-deep: #e5ded0;
                    --surface: rgba(255, 251, 245, 0.8);
                    --surface-strong: rgba(255, 255, 255, 0.92);
                    --surface-soft: rgba(255, 247, 238, 0.72);
                    --line: rgba(61, 53, 42, 0.12);
                    --line-strong: rgba(61, 53, 42, 0.22);
                    --text: #1d2430;
                    --muted: #66707d;
                    --brand: #0f766e;
                    --brand-dark: #115e59;
                    --accent: #c96f32;
                    --accent-soft: rgba(201, 111, 50, 0.12);
                    --ink-soft: rgba(17, 24, 39, 0.04);
                    --danger: #b42318;
                    --shadow: 0 24px 80px rgba(35, 30, 24, 0.08);
                    --shadow-soft: 0 12px 36px rgba(35, 30, 24, 0.06);
                    --radius-xl: 32px;
                    --radius-lg: 24px;
                    --radius-md: 18px;
                    --radius-sm: 14px;
                }

                * { box-sizing: border-box; }
                html { scroll-behavior: smooth; }
                body {
                    margin: 0;
                    min-height: 100vh;
                    font-family: "Manrope", "Segoe UI", sans-serif;
                    color: var(--text);
                    background:
                        radial-gradient(circle at top left, rgba(15, 118, 110, 0.14), transparent 30%),
                        radial-gradient(circle at 85% 0%, rgba(201, 111, 50, 0.16), transparent 25%),
                        radial-gradient(circle at 50% 100%, rgba(17, 24, 39, 0.06), transparent 30%),
                        linear-gradient(180deg, #fbf7f0 0%, var(--bg) 52%, var(--bg-deep) 100%);
                }
                body::before {
                    content: "";
                    position: fixed;
                    inset: 0;
                    pointer-events: none;
                    background-image:
                        linear-gradient(rgba(255, 255, 255, 0.08) 1px, transparent 1px),
                        linear-gradient(90deg, rgba(255, 255, 255, 0.08) 1px, transparent 1px);
                    background-size: 120px 120px;
                    mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.5), transparent 80%);
                    opacity: 0.32;
                }
                a { color: inherit; }
                h1, h2, h3, .brand {
                    font-family: "Space Grotesk", "Manrope", sans-serif;
                    letter-spacing: -0.03em;
                }
                h1, h2, h3, p {
                    margin-block-start: 0;
                }
                .page-shell {
                    width: calc(100% - 2rem);
                    margin: 0 auto;
                    padding: 2rem 0 4rem;
                }
                .topbar {
                    display: flex;
                    justify-content: space-between;
                    align-items: center;
                    gap: 1rem;
                    margin-bottom: 2rem;
                    padding: 1rem 1.2rem;
                    position: sticky;
                    top: 1rem;
                    z-index: 10;
                    background: rgba(251, 247, 240, 0.78);
                    border: 1px solid rgba(61, 53, 42, 0.08);
                    border-radius: 999px;
                    backdrop-filter: blur(18px);
                    box-shadow: var(--shadow-soft);
                }
                .brand {
                    font-weight: 700;
                    letter-spacing: 0.08em;
                    text-transform: uppercase;
                }
                .brand-mark {
                    display: inline-flex;
                    align-items: center;
                    gap: 0.85rem;
                }
                .brand-logo {
                    width: 2rem;
                    height: 2rem;
                    object-fit: contain;
                    border-radius: 999px;
                    filter: drop-shadow(0 8px 16px rgba(15, 118, 110, 0.14));
                }
                .surface {
                    background: var(--surface);
                    border: 1px solid var(--line);
                    border-radius: var(--radius-lg);
                    box-shadow: var(--shadow);
                    backdrop-filter: blur(16px);
                }
                .nav-links {
                    display: flex;
                    flex-wrap: wrap;
                    gap: 0.75rem;
                    align-items: center;
                }
                .button {
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    gap: 0.5rem;
                    padding: 0.8rem 1.2rem;
                    border-radius: 999px;
                    border: 1px solid transparent;
                    background: var(--brand);
                    color: #fff;
                    font-weight: 600;
                    text-decoration: none;
                    cursor: pointer;
                    transition: transform 140ms ease, box-shadow 140ms ease, background 140ms ease, border-color 140ms ease;
                    box-shadow: 0 12px 30px rgba(15, 118, 110, 0.16);
                }
                .button.secondary {
                    background: rgba(255, 255, 255, 0.56);
                    color: var(--text);
                    border: 1px solid var(--line);
                    box-shadow: none;
                }
                .button:hover {
                    transform: translateY(-1px);
                }
                .button.secondary:hover {
                    border-color: var(--line-strong);
                    background: rgba(255, 255, 255, 0.82);
                }
                .notice {
                    padding: 0.85rem 1rem;
                    border-radius: var(--radius-sm);
                    margin-bottom: 1rem;
                }
                .notice.error {
                    background: rgba(180, 35, 24, 0.08);
                    color: var(--danger);
                    border: 1px solid rgba(180, 35, 24, 0.2);
                }
                .notice.success {
                    background: rgba(15, 118, 110, 0.08);
                    color: var(--brand-dark);
                    border: 1px solid rgba(15, 118, 110, 0.2);
                }
                .notice.maintenance {
                    position: relative;
                    overflow: hidden;
                    padding: 1.15rem 1.2rem;
                    border-radius: var(--radius-md);
                    border: 1px solid rgba(54, 88, 199, 0.16);
                    background:
                        linear-gradient(135deg, rgba(255, 255, 255, 0.94), rgba(242, 244, 255, 0.92)),
                        radial-gradient(circle at right bottom, rgba(89, 114, 255, 0.12), transparent 55%);
                    box-shadow: 0 18px 42px rgba(82, 95, 160, 0.12);
                    color: #24315d;
                }
                .notice.maintenance::after {
                    content: "";
                    position: absolute;
                    inset: auto -2rem -2rem auto;
                    width: 8rem;
                    height: 8rem;
                    border-radius: 50%;
                    background: radial-gradient(circle, rgba(118, 136, 255, 0.18), transparent 70%);
                    pointer-events: none;
                }
                .maintenance-notice-row {
                    display: flex;
                    flex-wrap: wrap;
                    align-items: center;
                    justify-content: space-between;
                    gap: 1rem;
                }
                .maintenance-notice-copy {
                    display: grid;
                    gap: 0.35rem;
                    max-width: 62ch;
                }
                .maintenance-notice-eyebrow {
                    display: inline-flex;
                    width: fit-content;
                    align-items: center;
                    gap: 0.45rem;
                    padding: 0.4rem 0.72rem;
                    border-radius: 999px;
                    background: rgba(68, 92, 210, 0.1);
                    color: #334592;
                    font-size: 0.75rem;
                    font-weight: 800;
                    letter-spacing: 0.08em;
                    text-transform: uppercase;
                }
                .maintenance-notice-title {
                    font-size: 1.05rem;
                    font-weight: 800;
                }
                .maintenance-notice-summary,
                .maintenance-notice-schedule {
                    color: #54607e;
                    line-height: 1.6;
                }
                .maintenance-notice-action {
                    flex-shrink: 0;
                }
                .section-stack {
                    display: grid;
                    gap: 1.25rem;
                }
                .language-switcher {
                    position: fixed;
                    right: 1rem;
                    bottom: 1rem;
                    z-index: 50;
                    display: inline-flex;
                    align-items: center;
                    gap: 0.35rem;
                    padding: 0.45rem;
                    border-radius: 999px;
                    border: 1px solid rgba(61, 53, 42, 0.12);
                    background: rgba(255, 251, 245, 0.9);
                    box-shadow: 0 16px 40px rgba(35, 30, 24, 0.14);
                    backdrop-filter: blur(14px);
                }
                .language-switcher-label {
                    padding: 0 0.45rem 0 0.65rem;
                    color: var(--muted);
                    font-size: 0.85rem;
                    font-weight: 700;
                }
                .language-switcher-link {
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    min-width: 3rem;
                    padding: 0.55rem 0.9rem;
                    border-radius: 999px;
                    color: var(--text);
                    font-size: 0.9rem;
                    font-weight: 700;
                    text-decoration: none;
                    transition: background 140ms ease, color 140ms ease, transform 140ms ease;
                }
                .language-switcher-link:hover {
                    transform: translateY(-1px);
                    background: rgba(15, 118, 110, 0.08);
                }
                .language-switcher-link.active {
                    background: var(--brand);
                    color: #fff;
                    box-shadow: 0 12px 24px rgba(15, 118, 110, 0.18);
                }
                .hero-grid,
                .stats-grid,
                .card-grid,
                .split-grid {
                    display: grid;
                    gap: 1rem;
                }
                .hero-grid {
                    grid-template-columns: minmax(0, 1.4fr) minmax(320px, 0.9fr);
                    align-items: stretch;
                }
                .stats-grid {
                    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
                }
                .card-grid {
                    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
                }
                .split-grid {
                    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
                }
                .hero-panel,
                .content-panel,
                .metric-card,
                .mini-card,
                .info-card {
                    position: relative;
                    overflow: hidden;
                }
                .hero-panel {
                    padding: 2.2rem;
                    min-height: 420px;
                    display: flex;
                    flex-direction: column;
                    justify-content: space-between;
                    background:
                        linear-gradient(135deg, rgba(255, 255, 255, 0.92), rgba(255, 248, 240, 0.72)),
                        linear-gradient(180deg, rgba(15, 118, 110, 0.04), rgba(201, 111, 50, 0.04));
                }
                .hero-panel::after,
                .content-panel::after {
                    content: "";
                    position: absolute;
                    inset: auto -4rem -4rem auto;
                    width: 12rem;
                    height: 12rem;
                    border-radius: 50%;
                    background: radial-gradient(circle, rgba(15, 118, 110, 0.12), transparent 70%);
                    pointer-events: none;
                }
                .content-panel {
                    padding: 1.6rem;
                    background: var(--surface-strong);
                }
                .eyebrow {
                    display: inline-flex;
                    align-items: center;
                    gap: 0.5rem;
                    width: fit-content;
                    padding: 0.45rem 0.8rem;
                    border-radius: 999px;
                    background: rgba(255, 255, 255, 0.72);
                    border: 1px solid rgba(15, 118, 110, 0.12);
                    color: var(--brand-dark);
                    font-size: 0.8rem;
                    font-weight: 700;
                    letter-spacing: 0.08em;
                    text-transform: uppercase;
                }
                .hero-title {
                    font-size: clamp(2.4rem, 5vw, 5rem);
                    line-height: 0.92;
                    max-width: 10ch;
                }
                .lead {
                    font-size: 1.02rem;
                    color: var(--muted);
                    line-height: 1.7;
                    max-width: 62ch;
                }
                .button-row {
                    display: flex;
                    flex-wrap: wrap;
                    gap: 0.75rem;
                }
                .metric-card,
                .mini-card,
                .info-card {
                    padding: 1.2rem;
                    border-radius: var(--radius-md);
                    border: 1px solid var(--line);
                    background: var(--surface-strong);
                    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.6);
                }
                .metric-card strong,
                .mini-card strong,
                .info-card strong {
                    display: block;
                    margin-bottom: 0.35rem;
                }
                .metric-value {
                    font-family: "Space Grotesk", "Manrope", sans-serif;
                    font-size: clamp(2rem, 4vw, 3rem);
                    line-height: 1;
                    margin-bottom: 0.3rem;
                }
                .muted {
                    color: var(--muted);
                }
                .kicker {
                    font-size: 0.8rem;
                    text-transform: uppercase;
                    letter-spacing: 0.08em;
                    color: var(--muted);
                    margin-bottom: 0.5rem;
                }
                .list-clean {
                    display: grid;
                    gap: 0.85rem;
                    margin: 0;
                    padding: 0;
                    list-style: none;
                }
                .list-item {
                    padding: 1rem 1.1rem;
                    border-radius: var(--radius-md);
                    background: rgba(255, 255, 255, 0.68);
                    border: 1px solid var(--line);
                }
                .page-title {
                    margin-bottom: 0.55rem;
                    font-size: clamp(1.9rem, 4vw, 3rem);
                }
                .info-strip {
                    display: flex;
                    flex-wrap: wrap;
                    gap: 0.75rem;
                    align-items: center;
                }
                label {
                    display: grid;
                    gap: 0.4rem;
                    font-weight: 600;
                }
                input,
                select,
                textarea {
                    width: 100%;
                    padding: 0.9rem 1rem;
                    border-radius: var(--radius-sm);
                    border: 1px solid var(--line);
                    background: rgba(255, 255, 255, 0.92);
                    color: var(--text);
                    font: inherit;
                    transition: border-color 140ms ease, box-shadow 140ms ease, background 140ms ease;
                }
                textarea {
                    resize: vertical;
                }
                input:focus,
                select:focus,
                textarea:focus {
                    outline: none;
                    border-color: rgba(15, 118, 110, 0.36);
                    box-shadow: 0 0 0 4px rgba(15, 118, 110, 0.1);
                    background: #fff;
                }
                form {
                    display: grid;
                    gap: 1rem;
                }
                details {
                    border-radius: var(--radius-md);
                }
                summary {
                    cursor: pointer;
                }
                .status-pair {
                    display: grid;
                    gap: 0.75rem;
                }
                .status-card {
                    display: grid;
                    gap: 0.3rem;
                    padding: 1rem;
                    border-radius: var(--radius-md);
                    border: 1px solid transparent;
                }
                .status-card.warning {
                    background: rgba(180, 83, 9, 0.06);
                    border-color: rgba(180, 83, 9, 0.12);
                }
                .status-card.info {
                    background: rgba(29, 78, 216, 0.06);
                    border-color: rgba(29, 78, 216, 0.12);
                }
                .status-card.danger {
                    background: rgba(180, 35, 24, 0.06);
                    border-color: rgba(180, 35, 24, 0.12);
                }
                .status-card.success {
                    background: rgba(15, 118, 110, 0.06);
                    border-color: rgba(15, 118, 110, 0.12);
                }
                .auth-shell {
                    max-width: 520px;
                    margin: 4rem auto 0;
                }
                @media (max-width: 720px) {
                    .page-shell {
                        width: calc(100% - 1.25rem);
                        padding-top: 1.25rem;
                    }
                    .topbar {
                        position: static;
                        border-radius: 28px;
                        flex-direction: column;
                        align-items: stretch;
                    }
                    .hero-grid {
                        grid-template-columns: 1fr;
                    }
                    .hero-panel {
                        min-height: auto;
                        padding: 1.6rem;
                    }
                    .button-row,
                    .info-strip {
                        flex-direction: column;
                        align-items: stretch;
                    }
                }
            </style>
        {% endblock %}

        {% block javascripts %}
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body class="{% block body_class %}{% endblock %}">
        {% set currentLocale = app.request.locale|default('sv') %}
        {% set localeOptions = available_locales() %}
        <div class="language-switcher" aria-label="{{ t('ui.language') }}">
            <span class="language-switcher-label">{{ t('ui.language') }}</span>
            {% for localeOption in localeOptions %}
                <a class="language-switcher-link {{ currentLocale == localeOption.code ? 'active' : '' }}" href="{{ path('app_locale_switch', { locale: localeOption.code }) }}?returnTo={{ app.request.requestUri|url_encode }}">{{ localeOption.name }}</a>
            {% endfor %}
        </div>
        <div class="page-shell {% block page_shell_class %}{% endblock %}">
            {% block topbar %}
                <div class="topbar">
                    <div class="brand brand-mark">
                        <img class="brand-logo" src="{{ site_branding.logoPath }}" alt="{{ t('brand.logo_alt', {'%name%': site_branding.name}) }}">
                        <span>{{ site_branding.name }}</span>
                    </div>
                    <div class="nav-links">
                        <a class="button secondary" href="{{ path('app_home') }}">{{ t('nav.home') }}</a>
                        {% if app.user %}
                            <a class="button secondary" href="{{ path('app_portal_entry') }}">{{ t('nav.portal') }}</a>
                        {% endif %}
                        {% if app.user %}
                            <a class="button secondary" href="{{ path('app_logout') }}">{{ t('nav.logout') }}</a>
                        {% else %}
                            <a class="button secondary" href="{{ path('app_login') }}">{{ t('nav.login') }}</a>
                        {% endif %}
                    </div>
                </div>
            {% endblock %}

            {% for message in app.flashes('success') %}
                <div class="notice success">{{ message }}</div>
            {% endfor %}

            {% for message in app.flashes('error') %}
                <div class="notice error">{{ message }}</div>
            {% endfor %}

            {% set globalMaintenanceNotice = maintenance_notice() %}
            {% set currentRouteName = app.request.attributes.get('_route')|default('') %}
            {% set hideAdminMaintenanceNotice = currentRouteName starts with 'app_portal_admin' and not is_granted('ROLE_SUPER_ADMIN') %}
            {% if globalMaintenanceNotice and not hideAdminMaintenanceNotice %}
                <div class="notice maintenance">
                    <div class="maintenance-notice-row">
                        <div class="maintenance-notice-copy">
                            <span class="maintenance-notice-eyebrow">{{ globalMaintenanceNotice.eyebrow }}</span>
                            <span class="maintenance-notice-title">{{ globalMaintenanceNotice.title }}</span>
                            <span class="maintenance-notice-summary">{{ globalMaintenanceNotice.summary }}</span>
                            {% if globalMaintenanceNotice.schedule %}
                                <span class="maintenance-notice-schedule">{{ globalMaintenanceNotice.schedule }}</span>
                            {% endif %}
                        </div>
                        {% if globalMaintenanceNotice.href %}
                            <a class="button secondary maintenance-notice-action" href="{{ globalMaintenanceNotice.href }}">{{ globalMaintenanceNotice.linkLabel }}</a>
                        {% endif %}
                    </div>
                </div>
            {% endif %}

            {% block body %}{% endblock %}
        </div>
        {% block page_footer %}{% endblock %}
    </body>
</html>
