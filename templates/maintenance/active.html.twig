{% extends 'base.html.twig' %}

{% block title %}Driftpunkt | Underhållsläge{% endblock %}

{% block page_shell_class %}home-shell{% endblock %}
{% block body_class %}home-landing maintenance-page{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        :root {
            --home-text: #283474;
            --home-text-soft: #54618e;
            --home-surface: rgba(255, 255, 255, 0.82);
            --home-surface-strong: rgba(255, 255, 255, 0.92);
            --home-shadow: 0 24px 60px rgba(87, 101, 177, 0.16);
            --home-blue: #2f59df;
            --home-orange: #f59b41;
            --home-danger: #b93f32;
        }

        body.maintenance-page {
            background:
                radial-gradient(circle at 18% 14%, rgba(148, 162, 255, 0.48), transparent 28%),
                radial-gradient(circle at 86% 12%, rgba(255, 222, 212, 0.66), transparent 24%),
                radial-gradient(circle at 50% 100%, rgba(103, 110, 255, 0.3), transparent 24%),
                linear-gradient(180deg, #7785d6 0%, #a9aff0 16%, #cbc7f5 38%, #d8d0f7 52%, #c7c8f8 67%, #a4aff0 100%);
            color: var(--home-text);
        }

        body.maintenance-page::before {
            background:
                radial-gradient(ellipse at 18% 32%, rgba(255, 255, 255, 0.36), transparent 26%),
                radial-gradient(ellipse at 55% 46%, rgba(255, 255, 255, 0.4), transparent 34%),
                radial-gradient(ellipse at 82% 68%, rgba(255, 255, 255, 0.28), transparent 24%),
                linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0));
            mask-image: none;
            opacity: 1;
        }

        body.maintenance-page::after {
            content: "";
            position: fixed;
            inset: 0;
            pointer-events: none;
            background:
                radial-gradient(circle at 20% 18%, rgba(255, 255, 255, 0.95) 0 2px, transparent 3px),
                radial-gradient(circle at 82% 26%, rgba(255, 255, 255, 0.88) 0 2px, transparent 3px),
                radial-gradient(circle at 14% 74%, rgba(255, 255, 255, 0.7) 0 2px, transparent 3px),
                radial-gradient(circle at 74% 86%, rgba(255, 255, 255, 0.78) 0 2px, transparent 3px);
            opacity: 0.9;
        }

        .home-shell {
            width: calc(100% - 2rem);
            padding: 0 0 2.5rem;
        }

        .home-topbar {
            margin: 0 calc(50% - 50vw);
            background:
                linear-gradient(180deg, rgba(79, 88, 170, 0.92), rgba(71, 80, 156, 0.88)),
                linear-gradient(90deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0));
            border-bottom: 1px solid rgba(255, 255, 255, 0.16);
            box-shadow: 0 14px 36px rgba(56, 63, 125, 0.18);
            backdrop-filter: blur(12px);
        }

        .home-topbar-inner,
        .home-statusbar-inner {
            width: calc(100% - 2rem);
            margin: 0 auto;
        }

        .home-topbar-inner {
            min-height: 68px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1.25rem;
        }

        .home-brand {
            display: inline-flex;
            align-items: center;
            color: #fff;
            text-decoration: none;
        }

        .home-brand-logo {
            height: 2.55rem;
            width: auto;
            display: block;
            filter: drop-shadow(0 12px 20px rgba(14, 39, 119, 0.24));
        }

        .home-nav {
            display: flex;
            align-items: center;
            gap: 1rem;
            color: rgba(255, 255, 255, 0.92);
        }

        .home-nav-link,
        .home-nav .button {
            color: inherit;
            text-decoration: none;
            font-size: 1rem;
            font-weight: 500;
        }

        .home-login-button {
            min-width: 104px;
            padding: 0.74rem 1.28rem;
            border-radius: 11px;
            background: linear-gradient(180deg, #ffbf61 0%, #f49b3c 100%);
            color: #fff;
            border: 1px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 10px 22px rgba(228, 142, 48, 0.32);
        }

        .home-statusbar {
            background: rgba(236, 226, 255, 0.28);
            border-top: 1px solid rgba(255, 255, 255, 0.12);
            border-bottom: 1px solid rgba(113, 117, 195, 0.16);
        }

        .home-statusbar-inner {
            min-height: 38px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.7rem;
            color: #56628f;
            font-size: 0.93rem;
            text-align: center;
        }

        .status-ok-dot {
            width: 1rem;
            height: 1rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            background: rgba(185, 63, 50, 0.14);
            color: var(--home-danger);
            font-size: 0.72rem;
            font-weight: 700;
        }

        .status-sep {
            opacity: 0.55;
        }

        .maintenance-hero {
            position: relative;
            padding: 5.6rem 0 1.5rem;
            text-align: center;
        }

        .maintenance-hero::before,
        .maintenance-hero::after {
            content: "";
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
            width: min(1080px, 100vw);
            pointer-events: none;
            border-radius: 50%;
        }

        .maintenance-hero::before {
            top: 1.1rem;
            height: 196px;
            background: radial-gradient(ellipse at center, rgba(255, 255, 255, 0.64) 0%, rgba(255, 255, 255, 0.18) 58%, transparent 78%);
        }

        .maintenance-hero::after {
            top: 2.5rem;
            height: 138px;
            background: radial-gradient(ellipse at center, rgba(255, 255, 255, 0.46) 0%, rgba(255, 255, 255, 0.1) 60%, transparent 80%);
        }

        .maintenance-pill {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.55rem 0.9rem;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.6);
            color: var(--home-danger);
            font-size: 0.86rem;
            font-weight: 800;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            box-shadow: 0 16px 36px rgba(111, 120, 163, 0.12);
        }

        .maintenance-title {
            margin: 1rem auto 0.85rem;
            max-width: 12ch;
            font-size: clamp(2.8rem, 6vw, 4.9rem);
            line-height: 0.95;
            letter-spacing: -0.04em;
            color: #243168;
        }

        .maintenance-subtitle {
            margin: 0 auto;
            max-width: 58rem;
            font-size: 1.12rem;
            line-height: 1.75;
            color: var(--home-text-soft);
        }

        .maintenance-layout {
            display: grid;
            grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
            gap: 1rem;
            align-items: start;
        }

        .maintenance-card,
        .maintenance-info {
            background: var(--home-surface);
            border: 1px solid rgba(215, 220, 245, 0.88);
            border-radius: 28px;
            box-shadow: var(--home-shadow);
            backdrop-filter: blur(12px);
        }

        .maintenance-card {
            padding: 1.8rem;
        }

        .maintenance-summary {
            display: grid;
            gap: 1rem;
        }

        .maintenance-callout {
            padding: 1rem 1.1rem;
            border-radius: 20px;
            background: linear-gradient(135deg, rgba(255, 244, 241, 0.88), rgba(255, 255, 255, 0.82));
            border: 1px solid rgba(185, 63, 50, 0.12);
            color: #5f4c57;
        }

        .maintenance-callout strong,
        .maintenance-info h2 {
            display: block;
            margin-bottom: 0.35rem;
            color: #233053;
        }

        .maintenance-meta {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 0.8rem;
        }

        .maintenance-meta article {
            padding: 1rem;
            border-radius: 20px;
            background: var(--home-surface-strong);
            border: 1px solid rgba(214, 221, 236, 0.9);
        }

        .maintenance-meta span {
            display: block;
            margin-bottom: 0.3rem;
            color: #66769a;
            font-size: 0.84rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.06em;
        }

        .maintenance-meta strong {
            color: #233053;
            font-size: 1rem;
            line-height: 1.5;
        }

        .maintenance-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
        }

        .maintenance-actions .button.secondary {
            background: rgba(255, 255, 255, 0.7);
            color: #32427d;
            border-color: rgba(80, 101, 219, 0.16);
        }

        .maintenance-info {
            padding: 1.5rem;
        }

        .maintenance-info p,
        .maintenance-callout p {
            margin: 0;
            color: #5a678c;
            line-height: 1.7;
        }

        .maintenance-list {
            margin: 0;
            padding-left: 1.1rem;
            color: #5a678c;
            line-height: 1.8;
        }

        .maintenance-list strong {
            color: #2a3767;
        }

        @media (max-width: 980px) {
            .maintenance-layout,
            .maintenance-meta {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 720px) {
            .home-shell {
                width: calc(100% - 1rem);
            }

            .home-topbar-inner {
                min-height: auto;
                padding: 1rem 0;
                flex-direction: column;
                align-items: stretch;
            }

            .home-nav,
            .home-statusbar-inner {
                flex-wrap: wrap;
                justify-content: center;
            }

            .maintenance-card,
            .maintenance-info {
                border-radius: 22px;
            }
        }
    </style>
{% endblock %}

{% block topbar %}
    <header class="home-topbar">
        <div class="home-topbar-inner">
            <a class="home-brand" href="{{ path('app_home') }}">
                <img class="home-brand-logo" src="/assets/branding/driftpunkt-logo-full.png" alt="Driftpunkt">
            </a>
            <nav class="home-nav" aria-label="Huvudnavigering">
                <a class="home-nav-link" href="{{ path('app_home') }}">Startsida</a>
                <a class="home-nav-link" href="{{ path('app_status_page') }}">Driftstatus</a>
                <a class="home-nav-link" href="{{ path('app_contact') }}">Kontakta oss</a>
                <a class="button home-login-button" href="{{ path('app_login', {role: 'admin'}) }}">Admin login</a>
            </nav>
        </div>
        <div class="home-statusbar">
            <div class="home-statusbar-inner">
                <span class="status-ok-dot" aria-hidden="true">!</span>
                <span>Underhållsläge aktivt</span>
                <span class="status-sep">•</span>
                <span>Kund- och teknikerinloggning är pausad</span>
                <span class="status-sep">•</span>
                <span>Admin kan fortfarande verifiera systemet</span>
            </div>
        </div>
    </header>
{% endblock %}

{% block body %}
    <section class="maintenance-hero">
        <span class="maintenance-pill">Planerat arbete</span>
        <h1 class="maintenance-title">Driftpunkt är tillfälligt i underhållsläge</h1>
        <p class="maintenance-subtitle">
            {{ message ?: 'Driftpunkt genomför just nu planerat arbete. Följ driftinformationen eller kontakta supporten om ni behöver hjälp medan underhållet pågår.' }}
        </p>
    </section>

    <section class="maintenance-layout">
        <article class="maintenance-card">
            <div class="maintenance-summary">
                {% if notice %}
                    <div class="maintenance-callout">
                        <strong>Senaste driftinformation</strong>
                        <p>{{ notice.title }}</p>
                        {% if notice.schedule %}
                            <p>{{ notice.schedule }}</p>
                        {% endif %}
                    </div>
                {% endif %}

                <div class="maintenance-meta">
                    <article>
                        <span>Publika sidor</span>
                        <strong>Startsida, driftstatus och kontakt är fortsatt öppna</strong>
                    </article>
                    <article>
                        <span>Inloggning</span>
                        <strong>Kund och tekniker pausade under arbetet</strong>
                    </article>
                    <article>
                        <span>Verifiering</span>
                        <strong>Admin kan fortfarande logga in och kontrollera läget</strong>
                    </article>
                </div>

                <div class="maintenance-actions">
                    <a class="button" href="{{ path('app_home') }}">Till startsidan</a>
                    <a class="button secondary" href="{{ path('app_status_page') }}">Öppna driftstatus</a>
                    <a class="button secondary" href="{{ path('app_contact') }}">Kontakta support</a>
                </div>
            </div>
        </article>

        <aside class="maintenance-info">
            <h2>Vad fungerar under tiden?</h2>
            <ul class="maintenance-list">
                <li><strong>Startsidan</strong> fortsätter vara öppen för information och länkar vidare.</li>
                <li><strong>Driftstatus</strong> visar senaste läget och planerade fönster.</li>
                <li><strong>Kontakta oss</strong> går att använda om ni behöver nå teamet.</li>
                <li><strong>Admin</strong> kan logga in för verifiering och avstämning.</li>
            </ul>
        </aside>
    </section>
{% endblock %}
