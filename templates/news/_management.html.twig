<section class="surface content-panel admin-surface-pad">
    <div class="hero-grid" style="grid-template-columns: minmax(0, 1.3fr) minmax(280px, 0.85fr);">
        <div>
            <div class="eyebrow">Redaktörsläge</div>
            <h2 style="margin: 0 0 0.5rem;">Publicera startsidans nyheter</h2>
            <p class="lead" style="margin: 0; max-width: 60ch;">Skapa nyheter som visas på startsidan och på den publika nyhetssidan. Publicerade nyheter sorteras med viktiga nyheter först.</p>
        </div>
        <div class="status-pair">
            <div class="status-card info">
                <strong style="color: #1d4ed8;">Teknikerbidrag</strong>
                <span class="muted">{{ newsSettings.technicianContributionsEnabled ? 'Aktivt' : 'Endast admin' }}</span>
            </div>
            <a class="button secondary" href="{{ path('app_news_index') }}">Visa publika nyheter</a>
        </div>
    </div>
</section>

<section class="surface admin-surface-pad">
    <div class="section-stack">
        <form method="post" action="{{ createAction }}" class="admin-form-stack admin-item-card">
            <input type="hidden" name="_token" value="{{ csrf_token(createToken) }}">

            <div class="admin-block-header">
                <h2>Skapa nyhet</h2>
                <span class="muted">Visas på startsidan när den publiceras.</span>
            </div>

            <label style="display: grid; gap: 0.35rem;">
                <span>Titel</span>
                <input type="text" name="title" required>
            </label>

            <label style="display: grid; gap: 0.35rem;">
                <span>Sammanfattning</span>
                <textarea name="summary" rows="3" required style="width: 100%; padding: 0.85rem 1rem; border-radius: 14px; border: 1px solid var(--line); background: #fff; resize: vertical;"></textarea>
            </label>

            <label style="display: grid; gap: 0.35rem;">
                <span>Kategori</span>
                <select name="category" style="width: 100%; padding: 0.85rem 1rem; border-radius: 14px; border: 1px solid var(--line); background: #fff;">
                    <option value="general">Nyhet</option>
                    <option value="planned_maintenance">Planerat underhåll</option>
                </select>
            </label>

            <label style="display: grid; gap: 0.35rem;">
                <span>Bild-URL</span>
                <input type="url" name="image_url" placeholder="https://...">
            </label>

            <div class="admin-split-auto">
                <label style="display: grid; gap: 0.35rem;">
                    <span>Underhåll start</span>
                    <input type="datetime-local" name="maintenance_starts_at">
                </label>
                <label style="display: grid; gap: 0.35rem;">
                    <span>Underhåll slut</span>
                    <input type="datetime-local" name="maintenance_ends_at">
                </label>
            </div>

            <label style="display: grid; gap: 0.35rem;">
                <span>Innehåll</span>
                <textarea name="body" rows="8" required style="width: 100%; padding: 0.85rem 1rem; border-radius: 14px; border: 1px solid var(--line); background: #fff; resize: vertical;"></textarea>
            </label>

            <div class="admin-split-auto">
                <label class="admin-checkbox-card">
                    <input type="checkbox" name="is_published" value="1" checked style="margin-top: 0.15rem;">
                    <span>
                        <strong style="display: block;">Publicera direkt</strong>
                        <span style="color: var(--muted); font-size: 0.92rem;">Om avstängt sparas nyheten som opublicerad.</span>
                    </span>
                </label>

                <label class="admin-checkbox-card">
                    <input type="checkbox" name="is_pinned" value="1" style="margin-top: 0.15rem;">
                    <span>
                        <strong style="display: block;">Markera som viktig</strong>
                        <span style="color: var(--muted); font-size: 0.92rem;">Viktiga nyheter lyfts först i listor och på startsidan.</span>
                    </span>
                </label>
            </div>

            <div>
                <button class="button" type="submit">Spara nyhet</button>
            </div>
        </form>

        <div class="section-stack">
            {% for article in newsArticles %}
                <form method="post" action="{{ path(updateRoute, {id: article.id}) }}" class="admin-form-stack admin-item-card">
                    <input type="hidden" name="_token" value="{{ csrf_token(updateTokenPrefix ~ article.id) }}">

                    <div class="admin-block-header" style="align-items: start;">
                        <div>
                            <strong style="display: block;">{{ article.title }}</strong>
                            <span class="muted">{{ article.publishedAt|date('Y-m-d H:i') }} · {{ article.author ? article.author.displayName : 'Driftpunkt' }} · {{ article.category.label }}</span>
                            {% if article.category.value == 'planned_maintenance' and (article.maintenanceStartsAt or article.maintenanceEndsAt) %}
                                <div class="muted" style="margin-top: 0.2rem;">
                                    {{ article.maintenanceStartsAt ? article.maintenanceStartsAt|date('Y-m-d H:i') : 'Start ej satt' }}
                                    {% if article.maintenanceEndsAt %} - {{ article.maintenanceEndsAt|date('Y-m-d H:i') }}{% endif %}
                                </div>
                            {% endif %}
                        </div>
                        <div class="status-pair">
                            <span class="status-card {{ article.isPublished ? 'success' : 'warning' }}">
                                <strong>{{ article.isPublished ? 'Publicerad' : 'Utkast' }}</strong>
                            </span>
                            {% if article.isPinned %}
                                <span class="status-card info"><strong>Viktig</strong></span>
                            {% endif %}
                        </div>
                    </div>

                    <label style="display: grid; gap: 0.35rem;">
                        <span>Titel</span>
                        <input type="text" name="title" value="{{ article.title }}" required>
                    </label>

                    <label style="display: grid; gap: 0.35rem;">
                        <span>Sammanfattning</span>
                        <textarea name="summary" rows="3" required style="width: 100%; padding: 0.85rem 1rem; border-radius: 14px; border: 1px solid var(--line); background: #fff; resize: vertical;">{{ article.summary }}</textarea>
                    </label>

                    <label style="display: grid; gap: 0.35rem;">
                        <span>Kategori</span>
                        <select name="category" style="width: 100%; padding: 0.85rem 1rem; border-radius: 14px; border: 1px solid var(--line); background: #fff;">
                            <option value="general" {{ article.category.value == 'general' ? 'selected' }}>Nyhet</option>
                            <option value="planned_maintenance" {{ article.category.value == 'planned_maintenance' ? 'selected' }}>Planerat underhåll</option>
                        </select>
                    </label>

                    <label style="display: grid; gap: 0.35rem;">
                        <span>Bild-URL</span>
                        <input type="url" name="image_url" value="{{ article.imageUrl ?? '' }}" placeholder="https://...">
                    </label>

                    <div class="admin-split-auto">
                        <label style="display: grid; gap: 0.35rem;">
                            <span>Underhåll start</span>
                            <input type="datetime-local" name="maintenance_starts_at" value="{{ article.maintenanceStartsAt ? article.maintenanceStartsAt|date('Y-m-d\\TH:i') : '' }}">
                        </label>
                        <label style="display: grid; gap: 0.35rem;">
                            <span>Underhåll slut</span>
                            <input type="datetime-local" name="maintenance_ends_at" value="{{ article.maintenanceEndsAt ? article.maintenanceEndsAt|date('Y-m-d\\TH:i') : '' }}">
                        </label>
                    </div>

                    <label style="display: grid; gap: 0.35rem;">
                        <span>Innehåll</span>
                        <textarea name="body" rows="8" required style="width: 100%; padding: 0.85rem 1rem; border-radius: 14px; border: 1px solid var(--line); background: #fff; resize: vertical;">{{ article.body }}</textarea>
                    </label>

                    <div class="admin-split-auto">
                        <label class="admin-checkbox-card" style="background: var(--surface-strong);">
                            <input type="checkbox" name="is_published" value="1" {{ article.isPublished ? 'checked' }} style="margin-top: 0.15rem;">
                            <span>
                                <strong style="display: block;">Publicerad</strong>
                                <span style="color: var(--muted); font-size: 0.92rem;">Avgör om nyheten visas publikt.</span>
                            </span>
                        </label>

                        <label class="admin-checkbox-card" style="background: var(--surface-strong);">
                            <input type="checkbox" name="is_pinned" value="1" {{ article.isPinned ? 'checked' }} style="margin-top: 0.15rem;">
                            <span>
                                <strong style="display: block;">Viktig nyhet</strong>
                                <span style="color: var(--muted); font-size: 0.92rem;">Lyfts högre upp i listor och på startsidan.</span>
                            </span>
                        </label>
                    </div>

                    <div>
                        <button class="button" type="submit">Uppdatera nyhet</button>
                    </div>
                </form>
            {% else %}
                <div class="notice info">Det finns inga nyheter ännu.</div>
            {% endfor %}
        </div>
    </div>
</section>
