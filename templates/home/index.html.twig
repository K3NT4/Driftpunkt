{% extends 'base.html.twig' %}

{% block title %}{{ site_branding.name }} | {{ t('home.title') }}{% endblock %}

{% block page_shell_class %}home-shell{% endblock %}
{% block body_class %}home-landing{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        :root {
            --home-text: #283474;
            --home-text-soft: #54618e;
            --home-line: rgba(177, 186, 241, 0.42);
            --home-surface: rgba(255, 255, 255, 0.78);
            --home-surface-strong: rgba(255, 255, 255, 0.9);
            --home-shadow: 0 24px 60px rgba(87, 101, 177, 0.16);
            --home-blue: #2f59df;
            --home-purple: #7f42df;
            --home-green: #3aa16b;
            --home-orange: #f59b41;
        }

        body.home-landing {
            background:
                radial-gradient(circle at 18% 14%, rgba(148, 162, 255, 0.48), transparent 28%),
                radial-gradient(circle at 86% 12%, rgba(255, 222, 212, 0.66), transparent 24%),
                radial-gradient(circle at 50% 100%, rgba(103, 110, 255, 0.3), transparent 24%),
                linear-gradient(180deg, #7785d6 0%, #a9aff0 16%, #cbc7f5 38%, #d8d0f7 52%, #c7c8f8 67%, #a4aff0 100%);
            color: var(--home-text);
        }

        body.home-landing::before {
            background:
                radial-gradient(ellipse at 18% 32%, rgba(255, 255, 255, 0.36), transparent 26%),
                radial-gradient(ellipse at 55% 46%, rgba(255, 255, 255, 0.4), transparent 34%),
                radial-gradient(ellipse at 82% 68%, rgba(255, 255, 255, 0.28), transparent 24%),
                linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0));
            mask-image: none;
            opacity: 1;
        }

        body.home-landing::after {
            content: "";
            position: fixed;
            inset: 0;
            pointer-events: none;
            background:
                radial-gradient(circle at 20% 18%, rgba(255, 255, 255, 0.95) 0 2px, transparent 3px),
                radial-gradient(circle at 82% 26%, rgba(255, 255, 255, 0.88) 0 2px, transparent 3px),
                radial-gradient(circle at 14% 74%, rgba(255, 255, 255, 0.7) 0 2px, transparent 3px),
                radial-gradient(circle at 74% 86%, rgba(255, 255, 255, 0.78) 0 2px, transparent 3px);
            opacity: 0.9;
        }

        .home-shell {
            width: calc(100% - 2rem);
            padding: 0 0 2.5rem;
        }

        .home-topbar,
        .home-footer {
            margin: 0 calc(50% - 50vw);
        }

        .home-topbar {
            background:
                linear-gradient(180deg, rgba(79, 88, 170, 0.92), rgba(71, 80, 156, 0.88)),
                linear-gradient(90deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0));
            border-bottom: 1px solid rgba(255, 255, 255, 0.16);
            box-shadow: 0 14px 36px rgba(56, 63, 125, 0.18);
            backdrop-filter: blur(12px);
        }

        .home-topbar-inner,
        .home-statusbar-inner,
        .home-footer-inner {
            width: calc(100% - 2rem);
            margin: 0 auto;
        }

        .home-topbar-inner {
            min-height: 68px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1.25rem;
        }

        .home-brand {
            display: inline-flex;
            align-items: center;
            gap: 0.85rem;
            color: #fff;
            font-family: "Space Grotesk", "Manrope", sans-serif;
            font-size: 1.1rem;
            font-weight: 700;
            text-decoration: none;
            letter-spacing: -0.02em;
        }

        .home-brand-mark {
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .home-brand-logo {
            height: 2.55rem;
            width: auto;
            display: block;
            filter: drop-shadow(0 12px 20px rgba(14, 39, 119, 0.24));
        }

        .home-nav {
            display: flex;
            align-items: center;
            gap: 1.35rem;
            color: rgba(255, 255, 255, 0.9);
        }

        .home-search-form {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
        }

        .home-nav-link,
        .home-search {
            color: inherit;
            text-decoration: none;
            font-size: 1rem;
            font-weight: 500;
        }

        .home-search {
            width: 2.15rem;
            height: 2.15rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: 1px solid rgba(255, 255, 255, 0.18);
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.08);
            font-size: 1rem;
            opacity: 0.92;
            cursor: pointer;
        }

        .home-search-input {
            width: 12rem;
            padding: 0.68rem 0.9rem;
            border-radius: 999px;
            border: 1px solid rgba(255, 255, 255, 0.18);
            background: rgba(255, 255, 255, 0.12);
            color: #fff;
            font: inherit;
        }

        .home-search-input::placeholder {
            color: rgba(255, 255, 255, 0.72);
        }

        .home-login-button {
            min-width: 104px;
            padding: 0.74rem 1.28rem;
            border-radius: 11px;
            background: linear-gradient(180deg, #ffbf61 0%, #f49b3c 100%);
            color: #fff;
            border: 1px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 10px 22px rgba(228, 142, 48, 0.32);
        }

        .home-statusbar {
            background: rgba(236, 226, 255, 0.28);
            border-top: 1px solid rgba(255, 255, 255, 0.12);
            border-bottom: 1px solid rgba(113, 117, 195, 0.16);
        }

        .home-statusbar-inner {
            min-height: 38px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.7rem;
            color: #56628f;
            font-size: 0.93rem;
            text-align: center;
        }

        .status-ok-dot {
            width: 1rem;
            height: 1rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            background: rgba(92, 118, 230, 0.16);
            color: #4e63c7;
            font-size: 0.72rem;
            font-weight: 700;
        }

        .status-sep {
            opacity: 0.55;
        }

        .home-hero {
            position: relative;
            padding: 6rem 0 1.8rem;
            text-align: center;
        }

        .home-hero::before,
        .home-hero::after {
            content: "";
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
            width: min(1080px, 100vw);
            pointer-events: none;
            border-radius: 50%;
            filter: blur(2px);
        }

        .home-hero::before {
            top: 1.1rem;
            height: 196px;
            background:
                radial-gradient(ellipse at center, rgba(255, 255, 255, 0.64) 0%, rgba(255, 255, 255, 0.18) 58%, transparent 78%);
            opacity: 0.95;
        }

        .home-hero::after {
            top: 2.5rem;
            height: 138px;
            background:
                radial-gradient(ellipse at center, rgba(255, 255, 255, 0.46) 0%, rgba(255, 255, 255, 0.1) 60%, transparent 80%);
        }

        .hero-wave {
            position: absolute;
            inset: 2.9rem 0 auto;
            height: 166px;
            overflow: hidden;
            pointer-events: none;
        }

        .hero-wave::before,
        .hero-wave::after {
            content: "";
            position: absolute;
            left: 50%;
            width: min(1100px, 120vw);
            transform: translateX(-50%);
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.24);
        }

        .hero-wave::before {
            top: 0;
            height: 124px;
            clip-path: polygon(0 58%, 10% 45%, 21% 50%, 33% 34%, 47% 44%, 62% 26%, 76% 38%, 100% 20%, 100% 100%, 0 100%);
        }

        .hero-wave::after {
            top: 20px;
            height: 114px;
            background: rgba(255, 255, 255, 0.18);
            clip-path: polygon(0 64%, 14% 48%, 27% 58%, 40% 40%, 58% 54%, 72% 34%, 87% 45%, 100% 30%, 100% 100%, 0 100%);
        }

        .home-title {
            position: relative;
            margin: 0 0 0.75rem;
            font-size: clamp(2.95rem, 5.1vw, 4.4rem);
            line-height: 1.02;
            letter-spacing: -0.04em;
            color: #243174;
        }

        .home-subtitle {
            position: relative;
            margin: 0;
            font-size: clamp(1.14rem, 1.8vw, 1.55rem);
            color: #44517e;
        }

        .login-card-grid {
            display: grid;
            gap: 0.95rem;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            margin-top: 1.8rem;
        }

        .home-card,
        .news-card-wrap,
        .status-section {
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.84) 0%, rgba(249, 247, 255, 0.76) 100%);
            border: 1px solid rgba(181, 190, 241, 0.38);
            border-radius: 20px;
            box-shadow: var(--home-shadow);
            backdrop-filter: blur(16px);
        }

        .home-card {
            padding: 1.75rem 1.15rem 1.1rem;
            text-align: center;
        }

        .role-icon {
            width: 4.8rem;
            height: 4.8rem;
            margin: 0 auto 0.95rem;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            background: linear-gradient(180deg, rgba(245, 245, 255, 0.92), rgba(232, 235, 255, 0.9));
            box-shadow: inset 0 -10px 18px rgba(129, 145, 220, 0.14);
            font-size: 1.85rem;
        }

        .role-icon.blue { color: var(--home-blue); }
        .role-icon.purple { color: var(--home-purple); }
        .role-icon.green { color: var(--home-green); }

        .role-title {
            margin: 0 0 0.5rem;
            font-size: 1.08rem;
            color: #2c3774;
        }

        .role-copy {
            min-height: 3.45rem;
            margin: 0 0 1.1rem;
            color: #4e5987;
            font-size: 0.95rem;
            line-height: 1.46;
        }

        .role-button {
            width: 100%;
            padding-block: 0.74rem;
            border-radius: 9px;
            box-shadow: none;
            font-size: 0.97rem;
        }

        .role-button.blue { background: linear-gradient(180deg, #5782ff 0%, #355fdb 100%); }
        .role-button.purple { background: linear-gradient(180deg, #9a62f7 0%, #723fda 100%); }
        .role-button.green { background: linear-gradient(180deg, #63b985 0%, #3b9c68 100%); }

        .home-link-row {
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            gap: 0.8rem;
            margin: 1.15rem 0 2rem;
            color: #49588f;
            font-size: 0.95rem;
        }

        .home-link-row a {
            text-decoration: none;
        }

        .home-link-row .sep {
            opacity: 0.36;
        }

        .home-center {
            display: grid;
            gap: 1rem;
            grid-template-columns: minmax(0, 1.08fr) minmax(300px, 0.8fr);
            align-items: start;
            margin-inline: auto;
        }

        .news-card-wrap {
            width: 100%;
            padding: 1.15rem;
        }

        .support-side-wrap {
            width: 100%;
            padding: 1.15rem;
        }

        .section-heading {
            display: flex;
            align-items: center;
            gap: 0.7rem;
            margin-bottom: 0.95rem;
        }

        .section-heading h2 {
            margin: 0;
            font-size: clamp(1.75rem, 2.3vw, 2.15rem);
            letter-spacing: -0.03em;
            color: #2b3778;
        }

        .heading-icon {
            width: 1.65rem;
            height: 1.65rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            font-size: 0.84rem;
            color: #fff;
            background: linear-gradient(180deg, #69a8ff, #4172e0);
        }

        .news-card {
            overflow: hidden;
            background: rgba(255, 255, 255, 0.66);
            border: 1px solid rgba(191, 198, 239, 0.42);
            border-radius: 16px;
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.6);
        }

        .news-card-main {
            padding: 0.95rem 1rem 0.85rem;
        }

        .news-card h3 {
            margin: 0 0 0.65rem;
            font-size: clamp(1.4rem, 1.85vw, 1.82rem);
            color: #2d3779;
        }

        .news-meta {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            flex-wrap: wrap;
            margin-bottom: 0.62rem;
            color: #5e698f;
            font-size: 0.92rem;
        }

        .news-tag {
            display: inline-flex;
            align-items: center;
            padding: 0.22rem 0.56rem;
            border-radius: 999px;
            background: #f7ecc6;
            color: #917137;
            font-size: 0.8rem;
        }

        .news-copy {
            margin: 0 0 0.8rem;
            color: #4d5984;
            line-height: 1.55;
            font-size: 0.96rem;
        }

        .news-link {
            color: #2f63e0;
            text-decoration: none;
            font-weight: 600;
        }

        .news-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            padding: 0.72rem 1rem;
            border-top: 1px solid rgba(191, 198, 239, 0.42);
            background: rgba(249, 250, 255, 0.7);
        }

        .news-author {
            display: inline-flex;
            align-items: center;
            gap: 0.8rem;
            color: #2b3778;
            font-weight: 600;
        }

        .avatar {
            width: 1.85rem;
            height: 1.85rem;
            border-radius: 999px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(180deg, #f4b5a9, #db7f71);
            color: #fff;
            font-size: 0.92rem;
        }

        .chevron {
            color: #97a0cb;
            font-size: 1.25rem;
        }

        .status-section {
            margin-top: 1.9rem;
            padding: 1.2rem;
        }

        .search-results {
            margin-top: 1rem;
            padding: 1.2rem;
            border-radius: 20px;
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.84) 0%, rgba(249, 247, 255, 0.76) 100%);
            border: 1px solid rgba(181, 190, 241, 0.38);
            box-shadow: var(--home-shadow);
            backdrop-filter: blur(16px);
        }

        .search-results-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            flex-wrap: wrap;
            margin-bottom: 0.9rem;
        }

        .search-results-head h2 {
            margin: 0;
            color: #2b3778;
            font-size: 1.35rem;
        }

        .search-results-head p {
            margin: 0;
            color: #60708d;
        }

        .search-results-grid {
            display: grid;
            gap: 0.85rem;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        }

        .search-result-card {
            display: grid;
            gap: 0.5rem;
            padding: 1rem;
            border-radius: 16px;
            border: 1px solid rgba(193, 201, 239, 0.42);
            background: rgba(255, 255, 255, 0.76);
            text-decoration: none;
            color: inherit;
        }

        .search-result-section {
            display: inline-flex;
            width: fit-content;
            padding: 0.26rem 0.58rem;
            border-radius: 999px;
            background: rgba(81, 111, 235, 0.12);
            color: #3e56a3;
            font-size: 0.75rem;
            font-weight: 700;
        }

        .search-result-card strong {
            color: #243174;
        }

        .search-result-card span {
            color: #60708d;
            line-height: 1.55;
        }

        .search-empty {
            color: #60708d;
            padding: 0.4rem 0;
        }

        .status-copy {
            margin: 0 0 0.9rem;
            color: #4c5b86;
            font-size: 0.98rem;
        }

        .status-overview-grid {
            display: grid;
            gap: 0.85rem;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        }

        .system-card {
            overflow: hidden;
            background: rgba(255, 255, 255, 0.72);
            border: 1px solid rgba(181, 190, 241, 0.42);
            border-radius: 16px;
        }

        .system-card-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.75rem;
            padding: 0.9rem 0.9rem 0.72rem;
        }

        .system-card-title {
            display: inline-flex;
            align-items: center;
            gap: 0.65rem;
            color: #2d397a;
            font-size: 1.02rem;
            font-weight: 700;
        }

        .system-icon {
            width: 1.6rem;
            height: 1.6rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 0.55rem;
            background: linear-gradient(180deg, #eef1ff, #dfe6ff);
            color: #3763db;
            font-size: 0.82rem;
        }

        .system-pill {
            padding: 0.28rem 0.56rem;
            border-radius: 999px;
            font-size: 0.76rem;
            color: #8c7034;
            background: #fbefc9;
        }

        .system-body {
            padding: 0 0.9rem 0.82rem;
            color: #495887;
        }

        .system-state {
            display: flex;
            align-items: center;
            gap: 0.65rem;
            font-size: 0.92rem;
        }

        .system-state .ok {
            color: #32a163;
            font-weight: 700;
        }

        .system-card-yellow .system-pill,
        .system-state-yellow .ok {
            color: #a76a12;
        }

        .system-card-red .system-pill,
        .system-state-red .ok {
            color: #b93f33;
        }

        .system-card-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            padding: 0.74rem 0.9rem;
            border-top: 1px solid rgba(191, 198, 239, 0.42);
            background: linear-gradient(180deg, rgba(241, 244, 255, 0.7), rgba(233, 238, 255, 0.9));
            color: #4166d8;
            font-size: 0.92rem;
        }

        .system-card-footer a {
            color: inherit;
            text-decoration: none;
        }

        .home-footer {
            margin-top: 1.75rem;
            padding: 0.8rem 0 0;
            background:
                linear-gradient(180deg, rgba(90, 100, 186, 0.42), rgba(98, 110, 198, 0.38)),
                linear-gradient(90deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.02));
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.12);
        }

        .home-footer-inner {
            display: flex;
            align-items: center;
            justify-content: flex-start;
            gap: 0.9rem;
            min-height: 56px;
        }

        .footer-links {
            display: flex;
            align-items: center;
            gap: 1.2rem;
            flex-wrap: wrap;
            color: rgba(255, 255, 255, 0.9);
            font-size: 0.95rem;
        }

        .footer-links a {
            color: inherit;
            text-decoration: none;
        }

        .footer-links .active {
            font-weight: 700;
        }

        .support-help {
            padding: 1.2rem 1.1rem;
            background: rgba(255, 255, 255, 0.84);
            color: var(--home-text);
        }

        .support-side-wrap .support-help {
            border-radius: 16px;
            border: 1px solid rgba(183, 192, 239, 0.5);
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.6);
        }

        .support-help h2 {
            margin: 0 0 0.85rem;
            font-size: clamp(1.8rem, 2.4vw, 2.2rem);
            line-height: 1.06;
            letter-spacing: -0.04em;
        }

        .support-links {
            display: grid;
            gap: 0.6rem;
        }

        .support-link {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            padding: 0.72rem 0.88rem;
            border-radius: 10px;
            border: 1px solid rgba(183, 192, 239, 0.58);
            background: rgba(255, 255, 255, 0.68);
            color: #44518a;
            text-decoration: none;
        }

        .support-link strong {
            display: inline-flex;
            align-items: center;
            gap: 0.75rem;
            font-size: 0.95rem;
            font-weight: 600;
        }

        .support-link .icon {
            width: 1.15rem;
            height: 1.15rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            color: #4466de;
            background: rgba(72, 109, 236, 0.12);
            font-size: 0.68rem;
        }

        .icon-hammer::before { content: "⚒"; }
        .icon-gear::before { content: "⚙"; }
        .icon-chat::before { content: "◌"; font-size: 1.2rem; }
        .icon-display::before { content: "▣"; }
        .icon-db::before { content: "▤"; }
        .icon-api::before { content: "⌘"; font-size: 0.88rem; }
        .icon-spark::before { content: "✦"; }
        .icon-book::before { content: "⌂"; }
        .icon-check::before { content: "✓"; }

        .role-icon,
        .system-icon,
        .support-link .icon {
            position: relative;
        }

        .role-icon::before,
        .system-icon::before,
        .support-link .icon::before {
            line-height: 1;
        }

        @media (max-width: 980px) {
            .home-topbar-inner,
            .home-footer-inner {
                grid-template-columns: 1fr;
            }

            .home-center,
            .login-card-grid,
            .status-overview-grid {
                grid-template-columns: 1fr;
            }

            .home-hero {
                padding-top: 4.6rem;
            }

            .home-footer-inner {
                min-height: auto;
            }
        }

        @media (max-width: 720px) {
            .home-shell {
                width: calc(100% - 1rem);
            }

            .home-topbar-inner {
                min-height: auto;
                padding: 1rem 0;
                flex-direction: column;
                align-items: stretch;
            }

            .home-nav {
                justify-content: space-between;
                flex-wrap: wrap;
                gap: 0.9rem;
            }

            .home-search-form {
                width: 100%;
            }

            .home-search-input {
                width: 100%;
            }

            .home-statusbar-inner {
                padding: 0.7rem 0;
                flex-wrap: wrap;
            }

            .home-title {
                font-size: clamp(2.4rem, 11vw, 3.4rem);
            }

            .home-subtitle {
                font-size: 1.05rem;
            }

            .home-card,
            .news-card-wrap,
            .status-section {
                border-radius: 18px;
            }

            .home-link-row {
                gap: 0.6rem;
                font-size: 0.93rem;
            }

            .section-heading h2,
            .support-help h2 {
                font-size: 1.8rem;
            }

            .support-help {
                padding-top: 1rem;
            }
        }
    </style>
{% endblock %}

{% block topbar %}
    <header class="home-topbar">
        <div class="home-topbar-inner">
            <a class="home-brand" href="{{ path('app_home') }}">
                <span class="home-brand-mark">
                    <img class="home-brand-logo" src="{{ site_branding.logoPath }}" alt="{{ site_branding.name }}">
                </span>
            </a>
            <nav class="home-nav" aria-label="{{ t('nav.search_main') }}">
                <a class="home-nav-link" href="{{ path('app_status_page') }}">{{ t('nav.status') }}</a>
                <a class="home-nav-link" href="{{ path('app_contact') }}">{{ t('nav.support') }}</a>
                <form class="home-search-form" method="get" action="{{ path('app_public_search') }}">
                    <input class="home-search-input" type="search" name="q" value="{{ searchQuery|default('') }}" placeholder="{{ t('home.search_placeholder') }}">
                    <button class="home-search" type="submit" aria-label="{{ t('home.search_aria') }}">⌕</button>
                </form>
                <a class="button home-login-button" href="{{ app.user ? path('app_portal_entry') : path('app_login') }}">{{ t('nav.login') }}</a>
            </nav>
        </div>
        <div class="home-statusbar">
            <div class="home-statusbar-inner">
                <span class="status-ok-dot" aria-hidden="true">{{ topStatus.isHealthy ? '✓' : '!' }}</span>
                <span>{{ topStatus.label }}</span>
                <span class="status-sep">•</span>
                <span>{{ t('home.status.updated') }} <strong>{{ topStatus.updatedLabel }}</strong></span>
                <span class="status-sep">•</span>
                <span>{{ t('home.status.active_tickets') }} <strong>{{ topStatus.activeTicketCount }}</strong></span>
                {% if topStatus.plannedMaintenanceCount > 0 %}
                    <span class="status-sep">•</span>
                    {% if topStatus.plannedMaintenanceHref %}
                        <a href="{{ topStatus.plannedMaintenanceHref }}" style="color: inherit; text-decoration: none;">{{ t('home.status.planned_maintenance') }} <strong>{{ t('home.status.upcoming_count', {'%count%': topStatus.plannedMaintenanceCount}) }}</strong></a>
                    {% else %}
                        <span>{{ t('home.status.planned_maintenance') }} <strong>{{ t('home.status.upcoming_count', {'%count%': topStatus.plannedMaintenanceCount}) }}</strong></span>
                    {% endif %}
                {% endif %}
                <span aria-hidden="true">›</span>
            </div>
        </div>
    </header>
{% endblock %}

{% block body %}
    {% set publicMaintenanceState = maintenance_mode.getState() %}
    {% set publicMaintenanceLocked = publicMaintenanceState.effectiveEnabled %}
    <section class="home-hero">
        <div class="hero-wave" aria-hidden="true"></div>
        <h1 class="home-title">{{ t('home.hero.welcome') }}</h1>
        <p class="home-subtitle">
            {% if publicMaintenanceLocked %}
                {{ t('home.hero.maintenance_active') }}
            {% elseif publicMaintenanceState.isUpcoming %}
                {{ t('home.hero.maintenance_upcoming') }}
            {% else %}
                {{ t('home.hero.default') }}
            {% endif %}
        </p>
    </section>

    {% if searchQuery is not empty %}
        <section class="search-results" aria-label="{{ t('home.search_results.aria') }}">
            <div class="search-results-head">
                <div>
                    <h2>{{ t('home.search_results.title') }}</h2>
                    <p>{{ t('home.search_results.public_hits_for', {'%query%': searchQuery}) }}</p>
                </div>
                <p>{{ searchResults|length == 1 ? t('home.search_results.count', {'%count%': searchResults|length}) : t('home.search_results.count_plural', {'%count%': searchResults|length}) }}</p>
            </div>
            {% if searchResults %}
                <div class="search-results-grid">
                    {% for result in searchResults %}
                        <a class="search-result-card" {% if result.href %}href="{{ result.href }}"{% endif %}>
                            <span class="search-result-section">{{ result.section }}</span>
                            <strong>{{ result.title }}</strong>
                            <span>{{ result.summary }}</span>
                        </a>
                    {% endfor %}
                </div>
            {% else %}
                <div class="search-empty">{{ t('home.search_results.empty') }}</div>
            {% endif %}
        </section>
    {% endif %}

    <section class="login-card-grid" aria-label="{{ t('home.roles.aria') }}">
        <article class="home-card">
            <div class="role-icon blue icon-hammer" aria-hidden="true"></div>
            <h2 class="role-title">{{ t('home.roles.technician.title') }}</h2>
            <p class="role-copy">
                {% if publicMaintenanceLocked %}
                    {{ t('home.roles.technician.maintenance') }}
                {% else %}
                    {{ t('home.roles.technician.copy') }}
                {% endif %}
            </p>
            <a class="button role-button blue" href="{{ publicMaintenanceLocked ? path('app_status_page') : (app.user ? path('app_portal_entry') : path('app_login', {role: 'technician'})) }}">
                {{ publicMaintenanceLocked ? t('home.roles.action.status') : t('home.roles.action.login') }}
            </a>
        </article>
        <article class="home-card">
            <div class="role-icon purple icon-gear" aria-hidden="true"></div>
            <h2 class="role-title">{{ t('home.roles.admin.title') }}</h2>
            <p class="role-copy">{{ t('home.roles.admin.copy') }}</p>
            <a class="button role-button purple" href="{{ app.user ? path('app_portal_entry') : path('app_login', {role: 'admin'}) }}">{{ t('home.roles.action.login') }}</a>
        </article>
        <article class="home-card">
            <div class="role-icon green icon-chat" aria-hidden="true"></div>
            <h2 class="role-title">{{ t('home.roles.customer.title') }}</h2>
            <p class="role-copy">
                {% if publicMaintenanceLocked %}
                    {{ t('home.roles.customer.maintenance') }}
                {% else %}
                    {{ t('home.roles.customer.copy') }}
                {% endif %}
            </p>
            <a class="button role-button green" href="{{ publicMaintenanceLocked ? path('app_status_page') : (app.user ? path('app_portal_entry') : path('app_login', {role: 'customer'})) }}">
                {{ publicMaintenanceLocked ? t('home.roles.action.status') : t('home.roles.action.login') }}
            </a>
        </article>
    </section>

    <nav class="home-link-row" aria-label="{{ t('home.quick_links.aria') }}">
        {% if customerLoginSettings.createAccountEnabled %}
            <a href="{{ path('app_register_customer') }}">{{ t('home.quick_links.create_account') }}</a>
            <span class="sep">|</span>
        {% endif %}
        <a href="{{ path('app_password_reset_request', {role: 'customer'}) }}">{{ t('home.quick_links.forgot_password') }}</a>
        <span class="sep">|</span>
        <a href="{{ path('app_contact') }}">{{ t('nav.support') }}</a>
        <span class="sep">|</span>
        <a href="{{ path('app_status_page') }}">{{ t('home.quick_links.status_info') }}</a>
        {% if knowledgeBaseSettings.publicEnabled %}
            <span class="sep">|</span>
            <a href="{{ path('app_knowledge_base_public') }}">{{ t('home.quick_links.knowledge_base') }}</a>
            <span aria-hidden="true">›</span>
        {% endif %}
    </nav>

    <section class="home-center" aria-label="{{ t('home.news_and_help.aria') }}">
        <div class="news-card-wrap">
            <div class="section-heading">
                <span class="heading-icon" aria-hidden="true">◔</span>
                <h2>{{ t('home.news.heading') }}</h2>
            </div>
            {% set featuredNews = latestNews|first %}
            {% if featuredNews %}
                <article class="news-card">
                    <div class="news-card-main">
                        <h3>{{ featuredNews.title }}</h3>
                        <div class="news-meta">
                            <span>{{ featuredNews.publishedAt|date('Y-m-d') }}</span>
                            <span class="news-tag">{{ featuredNews.category.label }}</span>
                        </div>
                        <p class="news-copy">{{ featuredNews.summary }}</p>
                        <a class="news-link" href="{{ path('app_news_show', {id: featuredNews.id}) }}">{{ t('home.news.read_more') }}</a>
                    </div>
                    <div class="news-footer">
                        <span class="news-author">
                            <span class="avatar" aria-hidden="true">{{ featuredNews.author ? featuredNews.author.firstName|slice(0, 1)|upper : 'D' }}</span>
                            {{ featuredNews.author ? featuredNews.author.displayName : 'Driftpunkt' }}
                        </span>
                        <span class="chevron" aria-hidden="true">›</span>
                    </div>
                </article>
                {% if latestNews|length > 1 %}
                    <div style="display: grid; gap: 0.75rem; margin-top: 0.85rem;">
                        {% for article in latestNews|slice(1) %}
                            <a href="{{ path('app_news_show', {id: article.id}) }}" style="display: flex; justify-content: space-between; gap: 1rem; padding: 0.95rem 1rem; border-radius: 18px; border: 1px solid rgba(214, 221, 236, 0.9); background: rgba(255, 255, 255, 0.78); text-decoration: none; color: inherit;">
                                <span>
                                    <strong style="display: block; color: #233053;">{{ article.title }}</strong>
                                    <span style="color: #60708d; font-size: 0.95rem;">{{ article.category.label }} · {{ article.summary }}</span>
                                </span>
                                <span style="white-space: nowrap; color: #60708d;">{{ article.publishedAt|date('Y-m-d') }}</span>
                            </a>
                        {% endfor %}
                    </div>
                {% endif %}
                <div style="margin-top: 0.9rem;">
                    <a class="news-link" href="{{ path('app_news_index') }}">{{ t('home.news.show_all') }}</a>
                </div>
            {% else %}
                <article class="news-card">
                    <div class="news-card-main">
                        <h3>{{ t('home.news.ready.title') }}</h3>
                        <div class="news-meta">
                            <span>{{ t('home.news.ready.none') }}</span>
                            <span class="news-tag">{{ t('home.news.ready.tag') }}</span>
                        </div>
                        <p class="news-copy">{{ t('home.news.ready.copy') }}</p>
                        <a class="news-link" href="{{ path('app_news_index') }}">{{ t('home.news.ready.link') }}</a>
                    </div>
                </article>
            {% endif %}
        </div>
        <aside class="support-side-wrap">
            <div class="support-help">
                <h2>{{ homeSupportWidget.title }}</h2>
                <p style="margin: 0 0 1rem; color: #62708a; line-height: 1.6;">{{ homeSupportWidget.intro }}</p>
                <div class="support-links">
                    {% for item in homeSupportWidget.links %}
                        <a class="support-link" href="{{ item.url }}">
                            <strong><span class="icon icon-{{ item.icon }}" aria-hidden="true"></span> {{ item.title }}</strong>
                            <span class="chevron" aria-hidden="true">›</span>
                        </a>
                    {% endfor %}
                </div>
            </div>
        </aside>
    </section>

    <section id="systemstatus" class="status-section" aria-label="Systemstatus">
        <div class="section-heading">
            <span class="heading-icon" style="background: linear-gradient(180deg, #46bb76, #32985e);" aria-hidden="true">✓</span>
            <h2>{{ homepageStatusSection.title|default('Systemstatus') }}</h2>
        </div>
        <p class="status-copy">{{ homepageStatusSection.intro|default('Överblick över systemets hälsa.') }}</p>
        <div class="status-overview-grid">
            {% for system in systemStatuses|default([]) %}
                {% set systemLinkHref = system.url ?? null %}
                <article class="system-card system-card-{{ system.health|default('green') }}">
                    <div class="system-card-top">
                        <div class="system-card-title">
                            <span class="system-icon icon-{{ system.icon|default('display') }}" aria-hidden="true"></span>
                            {{ system.name }}
                        </div>
                        {% if system.pill %}
                            <span class="system-pill">{{ system.pill }}</span>
                        {% else %}
                            <span class="chevron" aria-hidden="true">›</span>
                        {% endif %}
                    </div>
                    <div class="system-body">
                        <div class="system-state system-state-{{ system.health|default('green') }}"><span class="ok">{{ system.statusSymbol|default('✓') }}</span> {{ system.status }}</div>
                    </div>
                    <div class="system-card-footer">
                        {% if systemLinkHref and system.linkLabel %}
                            <a href="{{ systemLinkHref }}">{{ system.linkLabel }}</a>
                        {% else %}
                            <span>{{ system.stateLabel|default('Operational') }}</span>
                        {% endif %}
                        <span aria-hidden="true">›</span>
                    </div>
                </article>
            {% endfor %}
        </div>
    </section>
{% endblock %}

{% block page_footer %}
    <footer id="support" class="home-footer">
        <div class="home-footer-inner">
            <nav class="footer-links" aria-label="Sidfot">
                <a class="active" href="{{ path('app_news_index') }}">Senaste Nytt</a>
                <a href="{{ path('app_privacy_policy') }}">Integritetspolicy</a>
                <a href="{{ path('app_terms_page') }}">Användarvillkor</a>
                <a href="{{ path('app_cookie_policy') }}">Cookiepolicy</a>
                <a href="{{ path('app_contact') }}">Kontakta oss</a>
                {% if site_branding.footerText %}
                    <span>{{ site_branding.footerText }}</span>
                {% endif %}
                <span>Version {{ site_branding.appVersion }}</span>
                <a href="{{ site_branding.githubUrl }}" target="_blank" rel="noopener noreferrer">{{ site_branding.copyrightLabel }}</a>
            </nav>

        </div>
    </footer>
{% endblock %}
