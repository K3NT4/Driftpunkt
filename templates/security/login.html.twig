{% extends 'base.html.twig' %}

{% set customerLoginSettings = customerLoginSettings|default({
    tips: [
        'Skriv tydligt i din felbeskrivning för snabbare hjälp.',
        'Bifoga gärna skärmbilder för att visa problemet.',
        'Logga in för att enkelt följa dina ärenden.'
    ],
    faq: [
        { question: 'Jag kan inte logga in, vad gör jag?', answer: 'Kontrollera att du använder rätt e-postadress och prova att återställa ditt lösenord.' },
        { question: 'Hur hittar jag mina fakturauppgifter?', answer: 'Efter inloggning hittar du uppgifterna under din profil eller via supporten.' },
        { question: 'Varför fungerar inte e-posten?', answer: 'Kontrollera skräpposten och att rätt adress finns registrerad på kontot.' },
        { question: 'Hur felsöker jag en VPN-anslutning?', answer: 'Starta om klienten, kontrollera nätverket och skicka gärna felmeddelandet till supporten.' }
    ],
    faqLines: [],
    createAccountEnabled: false
}) %}
{% set knowledgeBaseSettings = knowledgeBaseSettings|default({
    publicEnabled: false,
    customerEnabled: true,
    publicSmartTipsEnabled: true,
    publicFaqEnabled: true,
    customerSmartTipsEnabled: true,
    customerFaqEnabled: true,
    publicTechnicianContributionsEnabled: false,
    customerTechnicianContributionsEnabled: false
}) %}
{% set showKnowledgeBaseTips = loginRole|default('customer') == 'customer' ? knowledgeBaseSettings.publicSmartTipsEnabled : true %}
{% set showKnowledgeBaseFaq = loginRole|default('customer') == 'customer' ? knowledgeBaseSettings.publicFaqEnabled : true %}
{% set activeMaintenanceNotice = maintenance_notice() %}
{% set maintenanceState = maintenance_mode.getState() %}
{% set maintenanceLoginLocked = maintenanceState.effectiveEnabled and loginRole != 'admin' %}

{% set loginThemes = {
    technician: {
        icon: '🛠',
        accent: '#2f63d8',
        accentDark: '#234db3',
        pill: t('login.theme.technician.pill'),
        heading: t('login.theme.technician.heading'),
        intro: t('login.theme.technician.intro'),
        formIntro: t('login.theme.technician.form_intro'),
        helperTitle: t('login.theme.technician.helper_title'),
        helperItems: [
            t('login.theme.technician.helper_item_1'),
            t('login.theme.technician.helper_item_2'),
            t('login.theme.technician.helper_item_3')
        ],
        faqTitle: t('login.theme.technician.faq_title'),
        faqItems: [
            t('login.theme.technician.faq_item_1'),
            t('login.theme.technician.faq_item_2'),
            t('login.theme.technician.faq_item_3')
        ],
        supportTitle: t('login.theme.technician.support_title'),
        supportCopy: t('login.theme.technician.support_copy')
    },
    admin: {
        icon: '⚙',
        accent: '#7a49d1',
        accentDark: '#6437bb',
        pill: t('login.theme.admin.pill'),
        heading: t('login.theme.admin.heading'),
        intro: t('login.theme.admin.intro'),
        formIntro: t('login.theme.admin.form_intro'),
        helperTitle: t('login.theme.admin.helper_title'),
        helperItems: [
            t('login.theme.admin.helper_item_1'),
            t('login.theme.admin.helper_item_2'),
            t('login.theme.admin.helper_item_3')
        ],
        faqTitle: t('login.theme.admin.faq_title'),
        faqItems: [
            t('login.theme.admin.faq_item_1'),
            t('login.theme.admin.faq_item_2'),
            t('login.theme.admin.faq_item_3')
        ],
        supportTitle: t('login.theme.admin.support_title'),
        supportCopy: t('login.theme.admin.support_copy')
    },
    customer: {
        icon: '💬',
        accent: '#39a763',
        accentDark: '#2c8a50',
        pill: t('login.theme.customer.pill'),
        heading: t('login.theme.customer.heading'),
        intro: t('login.theme.customer.intro'),
        formIntro: t('login.theme.customer.form_intro'),
        helperTitle: t('login.theme.customer.helper_title'),
        helperItems: customerLoginSettings.tips,
        faqTitle: t('login.theme.customer.faq_title'),
        faqItems: customerLoginSettings.faq,
        supportTitle: t('login.theme.customer.support_title'),
        supportCopy: t('login.theme.customer.support_copy')
    }
} %}
{% set theme = attribute(loginThemes, loginRole|default('customer')) %}

{% block title %}{{ site_branding.name }} | {{ t('login.title') }}{% endblock %}
{% block page_shell_class %}home-shell{% endblock %}
{% block body_class %}home-landing login-role-page{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        body.login-role-page {
            background:
                radial-gradient(circle at top left, rgba(115, 141, 255, 0.18), transparent 30%),
                radial-gradient(circle at 100% 20%, rgba(255, 255, 255, 0.76), transparent 26%),
                linear-gradient(180deg, #eff2fb 0%, #f8f5fc 52%, #eef1fa 100%);
        }

        body.login-role-page::before {
            background-image:
                radial-gradient(circle at 16% 10%, rgba(122, 145, 255, 0.14), transparent 24%),
                radial-gradient(circle at 84% 34%, rgba(255, 255, 255, 0.84), transparent 16%),
                radial-gradient(circle at 24% 88%, rgba(122, 145, 255, 0.18), transparent 18%);
            background-size: auto;
            mask-image: none;
            opacity: 1;
        }

        .login-page-wrap {
            width: calc(100% - 2rem);
            margin: 0 auto;
            padding: 2rem 0 1rem;
        }

        .login-hero {
            text-align: center;
            margin-bottom: 1.8rem;
        }

        .login-badge {
            width: 6rem;
            height: 6rem;
            margin: 0 auto 1rem;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            background: radial-gradient(circle at 30% 30%, #ffffff, #e7edff 64%);
            box-shadow: 0 16px 36px rgba(112, 127, 189, 0.16);
            font-size: 2.8rem;
        }

        .login-brand-title {
            margin-bottom: 0.9rem;
            font-size: clamp(2.6rem, 5vw, 4.1rem);
            color: #1f2855;
        }

        .login-brand-subtitle {
            margin: 0 auto;
            max-width: 42rem;
            font-size: 1.18rem;
            color: #40496d;
        }

        .role-switcher {
            display: flex;
            justify-content: center;
            gap: 0.75rem;
            flex-wrap: wrap;
            margin: 1.35rem 0 0;
        }

        .role-switcher a {
            text-decoration: none;
        }

        .role-chip {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            padding: 0.72rem 1rem;
            border-radius: 999px;
            border: 1px solid rgba(198, 204, 227, 0.88);
            background: rgba(255, 255, 255, 0.8);
            color: #2b3459;
            font-weight: 700;
            box-shadow: 0 10px 24px rgba(123, 132, 173, 0.08);
        }

        .role-chip.active {
            color: #fff;
            border-color: transparent;
            background: linear-gradient(180deg, {{ theme.accent }} 0%, {{ theme.accentDark }} 100%);
        }

        .login-layout {
            display: grid;
            gap: 1rem;
            grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
            align-items: start;
        }

        .login-layout.simple-mode {
            grid-template-columns: 1fr;
        }

        .maintenance-lock {
            margin-bottom: 1rem;
            padding: 1.25rem;
            border-radius: 22px;
            border: 1px solid rgba(91, 110, 218, 0.18);
            background:
                linear-gradient(135deg, rgba(255, 255, 255, 0.94), rgba(241, 244, 255, 0.92)),
                radial-gradient(circle at right bottom, rgba(96, 116, 239, 0.14), transparent 56%);
            box-shadow: 0 18px 42px rgba(111, 120, 163, 0.14);
        }

        .maintenance-lock h3 {
            margin-bottom: 0.55rem;
            color: #22315c;
        }

        .maintenance-lock p {
            margin-bottom: 0.85rem;
            color: #4d587b;
            line-height: 1.7;
        }

        .maintenance-lock-links {
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
        }

        .login-panel,
        .info-panel,
        .faq-panel,
        .support-panel,
        .search-panel {
            background: rgba(255, 255, 255, 0.9);
            border: 1px solid rgba(210, 214, 233, 0.82);
            border-radius: 24px;
            box-shadow: 0 18px 46px rgba(111, 120, 163, 0.12);
        }

        .login-panel {
            padding: 1.7rem;
        }

        .login-panel.technician-panel {
            overflow: hidden;
            padding: 0;
        }

        .technician-form-block,
        .technician-status-block {
            padding: 1.7rem;
        }

        .technician-status-block {
            border-top: 1px solid rgba(220, 223, 238, 0.84);
            background: linear-gradient(180deg, rgba(249, 250, 255, 0.8) 0%, rgba(243, 246, 255, 0.9) 100%);
        }

        .technician-status-card {
            padding: 1rem;
            border-radius: 18px;
            border: 1px solid rgba(210, 214, 233, 0.82);
            background: rgba(255, 255, 255, 0.7);
        }

        .technician-status-head {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 1rem;
            color: #25305b;
        }

        .technician-status-icon {
            width: 2.2rem;
            height: 2.2rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            background: rgba(45, 174, 124, 0.16);
            color: #2a9e6b;
            font-weight: 800;
        }

        .technician-status-highlight {
            padding: 1rem;
            border-radius: 14px;
            background: linear-gradient(180deg, #f7fbf7 0%, #edf7ee 100%);
            border: 1px solid rgba(177, 218, 184, 0.8);
            color: #245d2d;
        }

        .technician-status-highlight strong {
            display: block;
            margin-bottom: 0.35rem;
            font-size: 1.05rem;
        }

        .technician-status-updated {
            margin-top: 0.9rem;
            padding: 0.8rem 1rem;
            border-radius: 12px;
            background: #eef1ff;
            color: #6873a1;
        }

        .login-panel h2,
        .info-panel h3,
        .faq-panel h3,
        .search-panel h3 {
            margin-bottom: 0.9rem;
            color: #232b57;
        }

        .login-panel p,
        .info-panel p,
        .faq-panel p,
        .search-panel p,
        .support-panel p {
            color: #4a516d;
            line-height: 1.65;
        }

        .login-panel .button {
            width: 100%;
            margin-top: 0.3rem;
            background: linear-gradient(180deg, {{ theme.accent }} 0%, {{ theme.accentDark }} 100%);
            box-shadow: none;
            border-radius: 10px;
        }

        .helper-link {
            color: {{ theme.accentDark }};
            text-decoration: none;
            font-weight: 700;
        }

        .muted-line {
            margin: 1rem 0 0;
            padding-top: 1rem;
            border-top: 1px solid rgba(220, 223, 238, 0.84);
            text-align: center;
            color: #65708a;
        }

        .info-stack {
            display: grid;
            gap: 1rem;
        }

        .info-panel,
        .faq-panel,
        .support-panel,
        .search-panel {
            padding: 1.35rem;
        }

        .tip-list,
        .faq-list {
            display: grid;
            gap: 0.75rem;
            margin: 0;
            padding: 0;
            list-style: none;
        }

        .tip-list li,
        .faq-list li {
            display: flex;
            gap: 0.7rem;
            align-items: start;
            color: #2d3457;
        }

        .tip-check,
        .faq-dot {
            flex: 0 0 auto;
            width: 1.3rem;
            height: 1.3rem;
            margin-top: 0.15rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            font-size: 0.85rem;
            font-weight: 800;
        }

        .tip-check {
            background: rgba(57, 167, 99, 0.14);
            color: #27824a;
        }

        .faq-dot {
            background: rgba(122, 145, 255, 0.12);
            color: #5168c9;
        }

        .faq-list details {
            border-radius: 14px;
            border: 1px solid rgba(222, 225, 239, 0.86);
            background: rgba(255, 255, 255, 0.78);
            overflow: hidden;
        }

        .faq-list summary {
            display: flex;
            justify-content: space-between;
            gap: 1rem;
            padding: 0.9rem 1rem;
            list-style: none;
            cursor: pointer;
        }

        .faq-list summary::-webkit-details-marker {
            display: none;
        }

        .faq-item-text {
            display: flex;
            gap: 0.7rem;
            align-items: flex-start;
            padding-right: 1rem;
        }

        .faq-arrow {
            color: {{ theme.accentDark }};
            font-weight: 800;
            transition: transform 140ms ease;
        }

        .faq-list details[open] .faq-arrow {
            transform: rotate(90deg);
        }

        .faq-answer {
            padding: 0 1rem 1rem 2.7rem;
            color: #58627e;
            line-height: 1.65;
        }

        .search-row {
            display: grid;
            grid-template-columns: 1fr auto;
            gap: 0.75rem;
            align-items: center;
        }

        .search-button {
            min-width: 72px;
            background: linear-gradient(180deg, {{ theme.accent }} 0%, {{ theme.accentDark }} 100%);
            border-radius: 10px;
            box-shadow: none;
        }

        .support-visual {
            min-height: 160px;
            margin: 1rem 0 1rem;
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 1rem;
            background:
                radial-gradient(circle at 20% 20%, rgba(255, 255, 255, 0.8), transparent 30%),
                linear-gradient(180deg, rgba(237, 241, 255, 0.96) 0%, rgba(249, 250, 255, 0.98) 100%);
            font-size: 4rem;
        }

        .support-panel .button {
            width: 100%;
            background: linear-gradient(180deg, {{ theme.accent }} 0%, {{ theme.accentDark }} 100%);
            box-shadow: none;
            border-radius: 10px;
        }

        .login-footer-links {
            display: flex;
            justify-content: space-between;
            gap: 1rem;
            flex-wrap: wrap;
            margin-top: 2.2rem;
            padding: 1.4rem 0 0;
            border-top: 1px solid rgba(211, 216, 237, 0.72);
            color: #505a7a;
        }

        .login-footer-links a {
            text-decoration: none;
            color: inherit;
        }

        @media (max-width: 860px) {
            .login-layout {
                grid-template-columns: 1fr;
            }
        }

        :root {
            --home-text: #283474;
            --home-shadow: 0 24px 60px rgba(87, 101, 177, 0.16);
            --home-surface-strong: rgba(255, 255, 255, 0.9);
        }

        body.home-landing.login-role-page {
            background:
                radial-gradient(circle at 18% 14%, rgba(148, 162, 255, 0.48), transparent 28%),
                radial-gradient(circle at 86% 12%, rgba(255, 222, 212, 0.66), transparent 24%),
                radial-gradient(circle at 50% 100%, rgba(103, 110, 255, 0.3), transparent 24%),
                linear-gradient(180deg, #7785d6 0%, #a9aff0 16%, #cbc7f5 38%, #d8d0f7 52%, #c7c8f8 67%, #a4aff0 100%);
            color: var(--home-text);
        }

        body.home-landing.login-role-page::before {
            background:
                radial-gradient(ellipse at 18% 32%, rgba(255, 255, 255, 0.36), transparent 26%),
                radial-gradient(ellipse at 55% 46%, rgba(255, 255, 255, 0.4), transparent 34%),
                radial-gradient(ellipse at 82% 68%, rgba(255, 255, 255, 0.28), transparent 24%),
                linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0));
        }

        body.home-landing.login-role-page::after {
            content: "";
            position: fixed;
            inset: 0;
            pointer-events: none;
            background:
                radial-gradient(circle at 20% 18%, rgba(255, 255, 255, 0.95) 0 2px, transparent 3px),
                radial-gradient(circle at 82% 26%, rgba(255, 255, 255, 0.88) 0 2px, transparent 3px),
                radial-gradient(circle at 14% 74%, rgba(255, 255, 255, 0.7) 0 2px, transparent 3px),
                radial-gradient(circle at 74% 86%, rgba(255, 255, 255, 0.78) 0 2px, transparent 3px);
            opacity: 0.9;
            pointer-events: none;
        }

        .home-shell {
            width: calc(100% - 2rem);
            padding: 0 0 2.5rem;
        }

        .home-topbar,
        .home-statusbar {
            margin: 0 calc(50% - 50vw);
        }

        .home-topbar {
            background:
                linear-gradient(180deg, rgba(79, 88, 170, 0.92), rgba(71, 80, 156, 0.88)),
                linear-gradient(90deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0));
            border-bottom: 1px solid rgba(255, 255, 255, 0.16);
            box-shadow: 0 14px 36px rgba(56, 63, 125, 0.18);
            backdrop-filter: blur(12px);
        }

        .home-topbar-inner,
        .home-statusbar-inner {
            width: calc(100% - 2rem);
            margin: 0 auto;
        }

        .home-topbar-inner {
            min-height: 68px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1.25rem;
        }

        .home-brand {
            display: inline-flex;
            align-items: center;
            gap: 0.85rem;
            color: #fff;
            font-family: "Space Grotesk", "Manrope", sans-serif;
            font-size: 1.1rem;
            font-weight: 700;
            text-decoration: none;
            letter-spacing: -0.02em;
        }

        .home-brand-logo {
            height: 2.55rem;
            width: auto;
            display: block;
            filter: drop-shadow(0 12px 20px rgba(14, 39, 119, 0.24));
        }

        .home-nav {
            display: flex;
            align-items: center;
            gap: 1.35rem;
            color: rgba(255, 255, 255, 0.9);
        }

        .home-nav-link {
            color: inherit;
            text-decoration: none;
            font-size: 1rem;
            font-weight: 500;
        }

        .home-login-button {
            min-width: 104px;
            padding: 0.74rem 1.28rem;
            border-radius: 11px;
            background: linear-gradient(180deg, #ffbf61 0%, #f49b3c 100%);
            color: #fff;
            border: 1px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 10px 22px rgba(228, 142, 48, 0.32);
        }

        .home-statusbar {
            background: rgba(236, 226, 255, 0.28);
            border-top: 1px solid rgba(255, 255, 255, 0.12);
            border-bottom: 1px solid rgba(113, 117, 195, 0.16);
        }

        .home-statusbar-inner {
            min-height: 38px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.7rem;
            color: #56628f;
            font-size: 0.93rem;
            text-align: center;
        }

        .status-ok-dot {
            width: 1rem;
            height: 1rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            background: rgba(92, 118, 230, 0.16);
            color: #4e63c7;
            font-size: 0.72rem;
            font-weight: 700;
        }

        .status-sep {
            opacity: 0.55;
        }

        .login-page-wrap {
            padding-top: 3.5rem;
        }

        .login-hero {
            position: relative;
            padding: 3rem 2rem 2.5rem;
            border-radius: 34px;
            border: 1px solid rgba(215, 223, 255, 0.84);
            background:
                linear-gradient(135deg, rgba(255, 255, 255, 0.92), rgba(243, 246, 255, 0.84)),
                radial-gradient(circle at 18% 18%, rgba(255, 255, 255, 0.78), transparent 26%);
            box-shadow: var(--home-shadow);
            overflow: hidden;
        }

        .login-hero::before {
            content: "";
            position: absolute;
            inset: auto -3rem -4rem auto;
            width: 16rem;
            height: 16rem;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(123, 138, 255, 0.16), transparent 70%);
            pointer-events: none;
        }

        .hero-wave {
            position: absolute;
            left: 50%;
            top: 1rem;
            transform: translateX(-50%);
            width: min(1040px, 96vw);
            height: 180px;
            border-radius: 50%;
            background: radial-gradient(ellipse at center, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0) 72%);
            pointer-events: none;
        }

        .login-brand-subtitle {
            max-width: 46rem;
            color: #58648f;
            line-height: 1.7;
        }

        .role-chip {
            background: rgba(255, 255, 255, 0.88);
        }

        .login-panel,
        .info-panel,
        .faq-panel,
        .support-panel,
        .search-panel {
            background: var(--home-surface-strong);
            border-radius: 26px;
            box-shadow: var(--home-shadow);
        }

        .login-footer-links .active {
            font-weight: 700;
        }

        @media (max-width: 720px) {
            .home-shell {
                width: calc(100% - 1rem);
            }

            .home-topbar-inner {
                min-height: auto;
                padding: 1rem 0;
                flex-direction: column;
                align-items: stretch;
            }

            .home-nav {
                justify-content: space-between;
                flex-wrap: wrap;
                gap: 0.9rem;
            }

            .home-statusbar-inner {
                padding: 0.7rem 0;
                flex-wrap: wrap;
            }

            .login-page-wrap {
                width: calc(100% - 1rem);
                padding-top: 2rem;
            }

            .login-hero {
                padding: 2.3rem 1.2rem 2rem;
                border-radius: 22px;
            }
        }
    </style>
{% endblock %}

{% block topbar %}
    <header class="home-topbar">
        <div class="home-topbar-inner">
            <a class="home-brand" href="{{ path('app_home') }}">
                <img class="home-brand-logo" src="{{ site_branding.logoPath }}" alt="{{ site_branding.name }}">
            </a>
            <nav class="home-nav" aria-label="{{ t('nav.search_main') }}">
                <a class="home-nav-link" href="{{ path('app_home') }}">{{ t('nav.home') }}</a>
                <a class="home-nav-link" href="{{ path('app_news_index') }}">{{ t('nav.news') }}</a>
                <a class="home-nav-link" href="{{ path('app_contact') }}">{{ t('nav.contact') }}</a>
                <a class="button home-login-button" href="{{ app.user ? path('app_portal_entry') : path('app_login', {role: loginRole|default('customer')}) }}">{{ t('nav.login') }}</a>
            </nav>
        </div>
    </header>
    <div class="home-statusbar">
        <div class="home-statusbar-inner">
            <span class="status-ok-dot" aria-hidden="true">{{ activeMaintenanceNotice ? '!' : '✓' }}</span>
            {% if activeMaintenanceNotice %}
                <span>{{ activeMaintenanceNotice.title }}</span>
                <span class="status-sep">•</span>
                <a href="{{ activeMaintenanceNotice.href ?: path('app_status_page') }}" style="color: inherit; text-decoration: none;">{{ activeMaintenanceNotice.linkLabel|default(t('login.nav.status_link')) }}</a>
            {% else %}
                <span>{{ t('login.nav.support_available') }}</span>
                <span class="status-sep">•</span>
                <span>{{ t('login.nav.response_time') }}</span>
                <span class="status-sep">•</span>
                <a href="{{ path('app_status_page') }}" style="color: inherit; text-decoration: none;">{{ t('login.nav.status_overview') }}</a>
            {% endif %}
        </div>
    </div>
{% endblock %}

{% block body %}
    <div class="login-page-wrap">
        <section class="login-hero">
            <div class="hero-wave" aria-hidden="true"></div>
            <div class="login-badge">{{ theme.icon }}</div>
            <h1 class="login-brand-title">{{ site_branding.name }}</h1>
            <h2 class="page-title" style="margin-bottom: 0.8rem;">{{ theme.heading }}</h2>
            <p class="login-brand-subtitle">{{ theme.intro }}</p>

            <div class="role-switcher">
                <a href="{{ path('app_login', {role: 'technician'}) }}">
                    <span class="role-chip {{ loginRole == 'technician' ? 'active' }}">
                        <span>🛠</span>
                        <span>{{ t('login.roles.technician') }}</span>
                    </span>
                </a>
                <a href="{{ path('app_login', {role: 'admin'}) }}">
                    <span class="role-chip {{ loginRole == 'admin' ? 'active' }}">
                        <span>⚙</span>
                        <span>{{ t('login.roles.admin') }}</span>
                    </span>
                </a>
                <a href="{{ path('app_login', {role: 'customer'}) }}">
                    <span class="role-chip {{ loginRole == 'customer' ? 'active' }}">
                        <span>💬</span>
                        <span>{{ t('login.roles.customer') }}</span>
                    </span>
                </a>
            </div>
        </section>

        <section class="login-layout {{ loginRole != 'customer' ? 'simple-mode' }}">
            {% if loginRole != 'customer' %}
                <article class="login-panel technician-panel">
                    <div class="technician-form-block">
                        <h2>{{ t('login.heading') }}</h2>
                        <p>{{ theme.formIntro }}</p>

                        {% if maintenanceLoginLocked %}
                            <div class="maintenance-lock">
                                <h3>{{ t('login.maintenance_paused_title') }}</h3>
                                <p>
                                    {{ t('login.maintenance_paused_copy') }}
                                    {% if activeMaintenanceNotice %}
                                        {{ activeMaintenanceNotice.summary }}
                                    {% endif %}
                                </p>
                                <div class="maintenance-lock-links">
                                    {% if activeMaintenanceNotice and activeMaintenanceNotice.href %}
                                        <a class="button secondary" href="{{ activeMaintenanceNotice.href }}">{{ t('login.maintenance_read_status') }}</a>
                                    {% endif %}
                                    <a class="button secondary" href="{{ path('app_contact') }}">{{ t('login.contact_support') }}</a>
                                </div>
                            </div>
                        {% endif %}

                        {% if error %}
                            <div class="notice error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                        {% endif %}

                        <form method="post">
                            <label>
                                <span>{{ t('login.email') }}</span>
                                <input
                                    type="email"
                                    name="_username"
                                    value="{{ last_username }}"
                                    autocomplete="email"
                                    placeholder="{{ t('login.email_placeholder') }}"
                                    required
                                    autofocus
                                    {{ maintenanceLoginLocked ? 'disabled' }}
                                >
                            </label>

                            <label>
                                <span>{{ t('login.password') }}</span>
                                <input
                                    type="password"
                                    name="_password"
                                    autocomplete="current-password"
                                    placeholder="{{ t('login.password_placeholder') }}"
                                    required
                                    {{ maintenanceLoginLocked ? 'disabled' }}
                                >
                            </label>

                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                            <button class="button" type="submit" {{ maintenanceLoginLocked ? 'disabled' }}>
                                {{ maintenanceLoginLocked ? t('login.action.paused') : t('login.action.submit') }}
                            </button>
                        </form>

                        <div style="margin-top: 1rem;">
                            <a class="helper-link" href="{{ path('app_password_reset_request', {role: loginRole}) }}">{{ t('login.forgot_password') }}</a>
                        </div>
                    </div>

                    <div class="technician-status-block">
                        <div class="technician-status-card">
                            <div class="technician-status-head">
                                <span class="technician-status-icon">✓</span>
                                <h3 style="margin: 0;">{{ t('login.current_status') }}</h3>
                            </div>
                            <div class="technician-status-highlight">
                                <strong>{{ t('login.current_status.ok') }}</strong>
                                <span>{{ t('login.current_status.ok_copy') }}</span>
                            </div>
                            <div class="technician-status-updated">{{ t('login.current_status.updated') }}</div>
                        </div>
                    </div>
                </article>
            {% else %}
                <div class="info-stack">
                    <article class="login-panel">
                        <div class="eyebrow" style="margin-bottom: 1rem; color: {{ theme.accentDark }}; border-color: color-mix(in srgb, {{ theme.accent }} 25%, white);">
                            {{ theme.pill }}
                        </div>
                        <h2>{{ t('login.heading') }}</h2>
                        <p>{{ theme.formIntro }}</p>

                        {% if maintenanceLoginLocked %}
                            <div class="maintenance-lock">
                                <h3>{{ t('login.maintenance_paused_title') }}</h3>
                                <p>
                                    {{ t('login.maintenance_paused_copy') }}
                                    {% if activeMaintenanceNotice %}
                                        {{ activeMaintenanceNotice.summary }}
                                    {% endif %}
                                </p>
                                <div class="maintenance-lock-links">
                                    {% if activeMaintenanceNotice and activeMaintenanceNotice.href %}
                                        <a class="button secondary" href="{{ activeMaintenanceNotice.href }}">{{ t('login.maintenance_read_status') }}</a>
                                    {% endif %}
                                    <a class="button secondary" href="{{ path('app_contact') }}">{{ t('login.contact_support') }}</a>
                                </div>
                            </div>
                        {% endif %}

                        {% if error %}
                            <div class="notice error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                        {% endif %}

                        <form method="post">
                            <label>
                                <span>{{ t('login.email') }}</span>
                                <input
                                    type="email"
                                    name="_username"
                                    value="{{ last_username }}"
                                    autocomplete="email"
                                    placeholder="{{ t('login.email_placeholder') }}"
                                    required
                                    autofocus
                                    {{ maintenanceLoginLocked ? 'disabled' }}
                                >
                            </label>

                            <label>
                                <span>{{ t('login.password') }}</span>
                                <input
                                    type="password"
                                    name="_password"
                                    autocomplete="current-password"
                                    placeholder="{{ t('login.password_placeholder') }}"
                                    required
                                    {{ maintenanceLoginLocked ? 'disabled' }}
                                >
                            </label>

                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                            <button class="button" type="submit" {{ maintenanceLoginLocked ? 'disabled' }}>
                                {{ maintenanceLoginLocked ? t('login.action.paused') : t('login.action.submit') }}
                            </button>
                        </form>

                        <div style="margin-top: 1rem;">
                            <a class="helper-link" href="{{ path('app_password_reset_request', {role: loginRole}) }}">{{ t('login.forgot_password') }}</a>
                        </div>

                        {% if customerLoginSettings.createAccountEnabled %}
                            <div class="muted-line">
                                {{ t('login.no_account') }} <a class="helper-link" href="{{ path('app_register_customer') }}">{{ t('login.create_account') }}</a>
                            </div>
                        {% endif %}
                    </article>

                    {% if knowledgeBaseSettings.publicEnabled %}
                        <article class="search-panel">
                            <h3>{{ t('login.search_help_first') }}</h3>
                            <form method="get" action="{{ path('app_knowledge_base_public') }}">
                                <div class="search-row">
                                    <input type="text" name="q" placeholder="{{ t('login.search_help_placeholder') }}">
                                    <button class="button search-button" type="submit">{{ t('login.search_help_button') }}</button>
                                </div>
                            </form>
                            <p style="margin: 0.9rem 0 0;">{{ t('login.search_help_copy') }}</p>
                        </article>
                    {% endif %}

                    <article class="support-panel">
                        <div class="support-visual">
                            {% if loginRole == 'admin' %}
                                <span>🧠</span><span>🗂</span>
                            {% else %}
                                <span>🧑‍💼</span><span>💬</span>
                            {% endif %}
                        </div>
                        <p style="text-align: center; margin-bottom: 1rem;">
                            <strong>{{ theme.supportTitle }}</strong><br>
                            {{ theme.supportCopy }}
                        </p>
                        <a class="button" href="{{ path('app_contact') }}">{{ t('login.contact_support') }}</a>
                    </article>
                </div>

                <div class="info-stack">
                    {% if showKnowledgeBaseTips %}
                        <article class="info-panel">
                            <h3>{{ theme.helperTitle }}</h3>
                            <ul class="tip-list">
                                {% for item in theme.helperItems %}
                                    <li>
                                        <span class="tip-check">✓</span>
                                        <span>{{ item }}</span>
                                    </li>
                                {% endfor %}
                            </ul>
                        </article>
                    {% endif %}

                    {% if showKnowledgeBaseFaq %}
                        <article class="faq-panel">
                            <h3>{{ theme.faqTitle }}</h3>
                            <ul class="faq-list">
                                {% for item in theme.faqItems %}
                                    <li>
                                        <details {{ loop.first ? 'open' }}>
                                            <summary>
                                                <span class="faq-item-text">
                                                    <span class="faq-dot">•</span>
                                                    <span>{{ item.question }}</span>
                                                </span>
                                                <span class="faq-arrow">›</span>
                                            </summary>
                                            <div class="faq-answer">{{ item.answer }}</div>
                                        </details>
                                    </li>
                                {% endfor %}
                            </ul>
                        </article>
                    {% endif %}
                </div>
            {% endif %}
        </section>

        <div class="login-footer-links">
            <a href="{{ path('app_home') }}">{{ t('auth.footer.back_home') }}</a>
            <a href="{{ path('app_privacy_policy') }}">{{ t('login.footer.privacy') }}</a>
            <a href="{{ path('app_terms_page') }}">Användarvillkor</a>
            <a href="{{ path('app_cookie_policy') }}">Cookiepolicy</a>
            <a href="{{ path('app_contact') }}">{{ t('auth.footer.support') }}</a>
            {% if site_branding.footerText %}
                <span>{{ site_branding.footerText }}</span>
            {% endif %}
            <span>{{ t('auth.footer.version') }} {{ site_branding.appVersion }}</span>
            <a href="{{ site_branding.githubUrl }}" target="_blank" rel="noopener noreferrer">{{ site_branding.copyrightLabel }}</a>
        </div>
    </div>
{% endblock %}
