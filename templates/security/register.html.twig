{% extends 'base.html.twig' %}

{% set customerLoginSettings = customerLoginSettings|default({
    tips: [
        'Skriv tydligt i din felbeskrivning för snabbare hjälp.',
        'Bifoga gärna skärmbilder för att visa problemet.',
        'Logga in för att enkelt följa dina ärenden.'
    ],
    faq: [
        { question: 'Jag kan inte logga in, vad gör jag?', answer: 'Kontrollera att du använder rätt e-postadress och prova att återställa ditt lösenord.' },
        { question: 'Hur hittar jag mina fakturauppgifter?', answer: 'Efter inloggning hittar du uppgifterna under din profil eller via supporten.' },
        { question: 'Varför fungerar inte e-posten?', answer: 'Kontrollera skräpposten och att rätt adress finns registrerad på kontot.' },
        { question: 'Hur felsöker jag en VPN-anslutning?', answer: 'Starta om klienten, kontrollera nätverket och skicka gärna felmeddelandet till supporten.' }
    ],
    faqLines: [],
    createAccountEnabled: false
}) %}
{% set knowledgeBaseSettings = knowledgeBaseSettings|default({
    publicEnabled: false,
    customerEnabled: true,
    publicSmartTipsEnabled: true,
    publicFaqEnabled: true,
    customerSmartTipsEnabled: true,
    customerFaqEnabled: true,
    publicTechnicianContributionsEnabled: false,
    customerTechnicianContributionsEnabled: false
}) %}

{% set authMaintenanceNotice = maintenance_notice() %}
{% block title %}{{ site_branding.name }} | {{ t('register.page_title') }}{% endblock %}
{% block page_shell_class %}home-shell auth-shell{% endblock %}
{% block body_class %}home-landing login-role-page{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        body.login-role-page {
            background:
                radial-gradient(circle at top left, rgba(115, 141, 255, 0.18), transparent 30%),
                radial-gradient(circle at 100% 20%, rgba(255, 255, 255, 0.76), transparent 26%),
                linear-gradient(180deg, #eff2fb 0%, #f8f5fc 52%, #eef1fa 100%);
        }

        body.login-role-page::before {
            background-image:
                radial-gradient(circle at 16% 10%, rgba(122, 145, 255, 0.14), transparent 24%),
                radial-gradient(circle at 84% 34%, rgba(255, 255, 255, 0.84), transparent 16%),
                radial-gradient(circle at 24% 88%, rgba(122, 145, 255, 0.18), transparent 18%);
            background-size: auto;
            mask-image: none;
            opacity: 1;
        }

        .register-page-wrap {
            width: calc(100% - 2rem);
            margin: 0 auto;
            padding: 2rem 0 1rem;
        }

        .register-hero {
            text-align: center;
            margin-bottom: 1.8rem;
        }

        .register-badge {
            width: 6rem;
            height: 6rem;
            margin: 0 auto 1rem;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            background: radial-gradient(circle at 30% 30%, #ffffff, #e7edff 64%);
            box-shadow: 0 16px 36px rgba(112, 127, 189, 0.16);
            font-size: 2.8rem;
        }

        .register-brand-title {
            margin-bottom: 0.9rem;
            font-size: clamp(2.4rem, 5vw, 4rem);
            color: #1f2855;
        }

        .register-subtitle {
            margin: 0 auto;
            max-width: 42rem;
            font-size: 1.12rem;
            color: #40496d;
        }

        .register-layout {
            display: grid;
            gap: 1rem;
            grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.85fr);
            align-items: start;
        }

        .register-panel,
        .register-side-panel,
        .register-support-panel,
        .register-search-panel {
            background: rgba(255, 255, 255, 0.9);
            border: 1px solid rgba(210, 214, 233, 0.82);
            border-radius: 24px;
            box-shadow: 0 18px 46px rgba(111, 120, 163, 0.12);
        }

        .register-panel,
        .register-side-panel,
        .register-support-panel,
        .register-search-panel {
            padding: 1.45rem;
        }

        .register-panel h2,
        .register-side-panel h3,
        .register-search-panel h3 {
            margin-bottom: 0.9rem;
            color: #232b57;
        }

        .register-panel p,
        .register-side-panel p,
        .register-search-panel p,
        .register-support-panel p {
            color: #4a516d;
            line-height: 1.65;
        }

        .register-grid-two {
            display: grid;
            gap: 0.9rem;
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .register-panel .button,
        .register-search-button,
        .register-support-panel .button {
            width: 100%;
            background: linear-gradient(180deg, #39a763 0%, #2c8a50 100%);
            box-shadow: none;
            border-radius: 10px;
        }

        .register-link {
            color: #2c8a50;
            text-decoration: none;
            font-weight: 700;
        }

        .register-muted-line {
            margin: 1rem 0 0;
            padding-top: 1rem;
            border-top: 1px solid rgba(220, 223, 238, 0.84);
            text-align: center;
            color: #65708a;
        }

        .register-stack {
            display: grid;
            gap: 1rem;
        }

        .register-tip-list,
        .register-faq-list {
            display: grid;
            gap: 0.75rem;
            margin: 0;
            padding: 0;
            list-style: none;
        }

        .register-tip-list li,
        .register-faq-list li {
            color: #2d3457;
        }

        .register-tip-list li {
            display: flex;
            gap: 0.7rem;
            align-items: start;
        }

        .register-tip-check,
        .register-faq-dot {
            flex: 0 0 auto;
            width: 1.3rem;
            height: 1.3rem;
            margin-top: 0.15rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            font-size: 0.85rem;
            font-weight: 800;
        }

        .register-tip-check {
            background: rgba(57, 167, 99, 0.14);
            color: #27824a;
        }

        .register-faq-list details {
            border-radius: 14px;
            border: 1px solid rgba(222, 225, 239, 0.86);
            background: rgba(255, 255, 255, 0.78);
            overflow: hidden;
        }

        .register-faq-list summary {
            display: flex;
            justify-content: space-between;
            gap: 1rem;
            padding: 0.9rem 1rem;
            list-style: none;
            cursor: pointer;
        }

        .register-faq-list summary::-webkit-details-marker {
            display: none;
        }

        .register-faq-item-text {
            display: flex;
            gap: 0.7rem;
            align-items: flex-start;
            padding-right: 1rem;
        }

        .register-faq-dot {
            background: rgba(122, 145, 255, 0.12);
            color: #5168c9;
        }

        .register-faq-arrow {
            color: #2c8a50;
            font-weight: 800;
            transition: transform 140ms ease;
        }

        .register-faq-list details[open] .register-faq-arrow {
            transform: rotate(90deg);
        }

        .register-faq-answer {
            padding: 0 1rem 1rem 2.7rem;
            color: #58627e;
            line-height: 1.65;
        }

        .register-search-row {
            display: grid;
            grid-template-columns: 1fr auto;
            gap: 0.75rem;
            align-items: center;
        }

        .register-search-button {
            min-width: 72px;
        }

        .register-support-visual {
            min-height: 150px;
            margin: 1rem 0;
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 1rem;
            background:
                radial-gradient(circle at 20% 20%, rgba(255, 255, 255, 0.8), transparent 30%),
                linear-gradient(180deg, rgba(237, 241, 255, 0.96) 0%, rgba(249, 250, 255, 0.98) 100%);
            font-size: 4rem;
        }

        .register-footer-links {
            display: flex;
            justify-content: space-between;
            gap: 1rem;
            flex-wrap: wrap;
            margin-top: 2.2rem;
            padding: 1.4rem 0 0;
            border-top: 1px solid rgba(211, 216, 237, 0.72);
            color: #505a7a;
        }

        .register-footer-links a {
            text-decoration: none;
            color: inherit;
        }

        @media (max-width: 860px) {
            .register-layout {
                grid-template-columns: 1fr;
            }

            .register-grid-two {
                grid-template-columns: 1fr;
            }
        }

        :root {
            --home-text: #283474;
            --home-shadow: 0 24px 60px rgba(87, 101, 177, 0.16);
            --home-surface-strong: rgba(255, 255, 255, 0.9);
        }

        body.home-landing.login-role-page {
            background:
                radial-gradient(circle at 18% 14%, rgba(148, 162, 255, 0.48), transparent 28%),
                radial-gradient(circle at 86% 12%, rgba(255, 222, 212, 0.66), transparent 24%),
                radial-gradient(circle at 50% 100%, rgba(103, 110, 255, 0.3), transparent 24%),
                linear-gradient(180deg, #7785d6 0%, #a9aff0 16%, #cbc7f5 38%, #d8d0f7 52%, #c7c8f8 67%, #a4aff0 100%);
            color: var(--home-text);
        }

        body.home-landing.login-role-page::before {
            background:
                radial-gradient(ellipse at 18% 32%, rgba(255, 255, 255, 0.36), transparent 26%),
                radial-gradient(ellipse at 55% 46%, rgba(255, 255, 255, 0.4), transparent 34%),
                radial-gradient(ellipse at 82% 68%, rgba(255, 255, 255, 0.28), transparent 24%),
                linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0));
        }

        body.home-landing.login-role-page::after {
            content: "";
            position: fixed;
            inset: 0;
            pointer-events: none;
            background:
                radial-gradient(circle at 20% 18%, rgba(255, 255, 255, 0.95) 0 2px, transparent 3px),
                radial-gradient(circle at 82% 26%, rgba(255, 255, 255, 0.88) 0 2px, transparent 3px),
                radial-gradient(circle at 14% 74%, rgba(255, 255, 255, 0.7) 0 2px, transparent 3px),
                radial-gradient(circle at 74% 86%, rgba(255, 255, 255, 0.78) 0 2px, transparent 3px);
            opacity: 0.9;
            pointer-events: none;
        }

        .home-shell {
            width: calc(100% - 2rem);
            padding: 0 0 2.5rem;
        }

        .home-topbar,
        .home-statusbar {
            margin: 0 calc(50% - 50vw);
        }

        .home-topbar {
            background:
                linear-gradient(180deg, rgba(79, 88, 170, 0.92), rgba(71, 80, 156, 0.88)),
                linear-gradient(90deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0));
            border-bottom: 1px solid rgba(255, 255, 255, 0.16);
            box-shadow: 0 14px 36px rgba(56, 63, 125, 0.18);
            backdrop-filter: blur(12px);
        }

        .home-topbar-inner,
        .home-statusbar-inner {
            width: calc(100% - 2rem);
            margin: 0 auto;
        }

        .home-topbar-inner {
            min-height: 68px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1.25rem;
        }

        .home-brand {
            display: inline-flex;
            align-items: center;
            gap: 0.85rem;
            color: #fff;
            font-family: "Space Grotesk", "Manrope", sans-serif;
            font-size: 1.1rem;
            font-weight: 700;
            text-decoration: none;
            letter-spacing: -0.02em;
        }

        .home-brand-logo {
            height: 2.55rem;
            width: auto;
            display: block;
            filter: drop-shadow(0 12px 20px rgba(14, 39, 119, 0.24));
        }

        .home-nav {
            display: flex;
            align-items: center;
            gap: 1.35rem;
            color: rgba(255, 255, 255, 0.9);
        }

        .home-nav-link {
            color: inherit;
            text-decoration: none;
            font-size: 1rem;
            font-weight: 500;
        }

        .home-login-button {
            min-width: 104px;
            padding: 0.74rem 1.28rem;
            border-radius: 11px;
            background: linear-gradient(180deg, #ffbf61 0%, #f49b3c 100%);
            color: #fff;
            border: 1px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 10px 22px rgba(228, 142, 48, 0.32);
        }

        .home-statusbar {
            background: rgba(236, 226, 255, 0.28);
            border-top: 1px solid rgba(255, 255, 255, 0.12);
            border-bottom: 1px solid rgba(113, 117, 195, 0.16);
        }

        .home-statusbar-inner {
            min-height: 38px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.7rem;
            color: #56628f;
            font-size: 0.93rem;
            text-align: center;
        }

        .status-ok-dot {
            width: 1rem;
            height: 1rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            background: rgba(92, 118, 230, 0.16);
            color: #4e63c7;
            font-size: 0.72rem;
            font-weight: 700;
        }

        .status-sep {
            opacity: 0.55;
        }

        .register-page-wrap {
            padding-top: 3.5rem;
        }

        .register-hero {
            position: relative;
            padding: 3rem 2rem 2.5rem;
            border-radius: 34px;
            border: 1px solid rgba(215, 223, 255, 0.84);
            background:
                linear-gradient(135deg, rgba(255, 255, 255, 0.92), rgba(243, 246, 255, 0.84)),
                radial-gradient(circle at 18% 18%, rgba(255, 255, 255, 0.78), transparent 26%);
            box-shadow: var(--home-shadow);
            overflow: hidden;
        }

        .register-hero::before {
            content: "";
            position: absolute;
            inset: auto -3rem -4rem auto;
            width: 16rem;
            height: 16rem;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(123, 138, 255, 0.16), transparent 70%);
            pointer-events: none;
        }

        .hero-wave {
            position: absolute;
            left: 50%;
            top: 1rem;
            transform: translateX(-50%);
            width: min(1040px, 96vw);
            height: 180px;
            border-radius: 50%;
            background: radial-gradient(ellipse at center, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0) 72%);
            pointer-events: none;
        }

        .register-subtitle {
            max-width: 46rem;
            color: #58648f;
            line-height: 1.7;
        }

        .register-panel,
        .register-side-panel,
        .register-support-panel,
        .register-search-panel {
            background: var(--home-surface-strong);
            border-radius: 26px;
            box-shadow: var(--home-shadow);
        }

        @media (max-width: 720px) {
            .home-shell {
                width: calc(100% - 1rem);
            }

            .home-topbar-inner {
                min-height: auto;
                padding: 1rem 0;
                flex-direction: column;
                align-items: stretch;
            }

            .home-nav {
                justify-content: space-between;
                flex-wrap: wrap;
                gap: 0.9rem;
            }

            .home-statusbar-inner {
                padding: 0.7rem 0;
                flex-wrap: wrap;
            }

            .register-page-wrap {
                width: calc(100% - 1rem);
                padding-top: 2rem;
            }

            .register-hero {
                padding: 2.3rem 1.2rem 2rem;
                border-radius: 22px;
            }
        }
    </style>
{% endblock %}

{% block topbar %}
    <header class="home-topbar">
        <div class="home-topbar-inner">
            <a class="home-brand" href="{{ path('app_home') }}">
                <img class="home-brand-logo" src="{{ site_branding.logoPath }}" alt="{{ site_branding.name }}">
            </a>
            <nav class="home-nav" aria-label="{{ t('nav.search_main') }}">
                <a class="home-nav-link" href="{{ path('app_home') }}">{{ t('nav.home') }}</a>
                <a class="home-nav-link" href="{{ path('app_news_index') }}">{{ t('nav.news') }}</a>
                <a class="home-nav-link" href="{{ path('app_contact') }}">{{ t('nav.contact') }}</a>
                <a class="button home-login-button" href="{{ app.user ? path('app_portal_entry') : path('app_login', {role: 'customer'}) }}">{{ t('nav.login') }}</a>
            </nav>
        </div>
    </header>
    <div class="home-statusbar">
        <div class="home-statusbar-inner">
            <span class="status-ok-dot" aria-hidden="true">{{ authMaintenanceNotice ? '!' : '✓' }}</span>
            {% if authMaintenanceNotice %}
                <span>{{ authMaintenanceNotice.title }}</span>
                <span class="status-sep">•</span>
                <a href="{{ authMaintenanceNotice.href ?: path('app_status_page') }}" style="color: inherit; text-decoration: none;">{{ authMaintenanceNotice.linkLabel|default(t('auth.status.view_status')) }}</a>
            {% else %}
                <span>{{ t('login.nav.support_available') }}</span>
                <span class="status-sep">•</span>
                <span>{{ t('auth.status.account_follow') }}</span>
                <span class="status-sep">•</span>
                <a href="{{ path('app_status_page') }}" style="color: inherit; text-decoration: none;">{{ t('login.nav.status_overview') }}</a>
            {% endif %}
        </div>
    </div>
{% endblock %}

{% block body %}
    <div class="register-page-wrap">
        <section class="register-hero">
            <div class="hero-wave" aria-hidden="true"></div>
            <div class="register-badge">💬</div>
            <h1 class="register-brand-title">{{ site_branding.name }}</h1>
            <h2 class="page-title" style="margin-bottom: 0.8rem;">{{ t('register.title') }}</h2>
            <p class="register-subtitle">{{ t('register.subtitle') }}</p>
        </section>

        <section class="register-layout">
            <div class="register-stack">
                <article class="register-panel">
                    <h2>{{ t('register.form.title') }}</h2>
                    <p>{{ t('register.form.copy') }}</p>

                    <form method="post">
                        <input type="hidden" name="_token" value="{{ csrf_token('customer_register') }}">

                        <div class="register-grid-two">
                            <label>
                                <span>{{ t('register.first_name') }}</span>
                                <input type="text" name="first_name" required>
                            </label>
                            <label>
                                <span>{{ t('register.last_name') }}</span>
                                <input type="text" name="last_name" required>
                            </label>
                        </div>

                        <label>
                            <span>{{ t('register.email') }}</span>
                            <input type="email" name="email" autocomplete="email" placeholder="{{ t('register.email_placeholder') }}" required>
                        </label>

                        <div class="register-grid-two">
                            <label>
                                <span>{{ t('register.password') }}</span>
                                <input type="password" name="password" autocomplete="new-password" placeholder="{{ t('register.password_placeholder') }}" required>
                            </label>
                            <label>
                                <span>{{ t('register.password_confirm') }}</span>
                                <input type="password" name="password_confirm" autocomplete="new-password" placeholder="{{ t('register.password_confirm_placeholder') }}" required>
                            </label>
                        </div>

                        <label style="display: flex; gap: 0.7rem; align-items: start; padding: 0.95rem 1rem; border-radius: 16px; border: 1px solid var(--line); background: #fff;">
                            <input type="checkbox" name="email_notifications_enabled" value="1" checked style="margin-top: 0.15rem;">
                            <span>
                                <strong style="display: block;">{{ t('register.email_notifications') }}</strong>
                                <span class="muted" style="font-size: 0.92rem;">{{ t('register.email_notifications_copy') }}</span>
                            </span>
                        </label>

                        <button class="button" type="submit">{{ t('register.submit') }}</button>
                    </form>

                    <div class="register-muted-line">
                        {{ t('register.have_account') }} <a class="register-link" href="{{ path('app_login', {role: 'customer'}) }}">{{ t('nav.login') }}</a>
                    </div>
                </article>

                {% if knowledgeBaseSettings.publicEnabled %}
                    <article class="register-search-panel">
                        <h3>{{ t('register.search_help_title') }}</h3>
                        <form method="get" action="{{ path('app_knowledge_base_public') }}" class="register-search-row">
                            <input type="text" name="q" placeholder="{{ t('register.search_help_placeholder') }}">
                            <button class="button register-search-button" type="submit">{{ t('register.search_help_button') }}</button>
                        </form>
                        <p style="margin: 0.9rem 0 0;">{{ t('register.search_help_copy') }}</p>
                    </article>
                {% endif %}
            </div>

            <div class="register-stack">
                {% if knowledgeBaseSettings.publicSmartTipsEnabled %}
                    <article class="register-side-panel">
                        <h3>Smarta Tips</h3>
                        <ul class="register-tip-list">
                            {% for item in customerLoginSettings.tips %}
                                <li>
                                    <span class="register-tip-check">✓</span>
                                    <span>{{ item }}</span>
                                </li>
                            {% endfor %}
                        </ul>
                    </article>
                {% endif %}

                {% if knowledgeBaseSettings.publicFaqEnabled %}
                    <article class="register-side-panel">
                        <h3>Vanliga Frågor</h3>
                        <ul class="register-faq-list">
                            {% for item in customerLoginSettings.faq %}
                                <li>
                                    <details {{ loop.first ? 'open' }}>
                                        <summary>
                                            <span class="register-faq-item-text">
                                                <span class="register-faq-dot">•</span>
                                                <span>{{ item.question }}</span>
                                            </span>
                                            <span class="register-faq-arrow">›</span>
                                        </summary>
                                        <div class="register-faq-answer">{{ item.answer }}</div>
                                    </details>
                                </li>
                            {% endfor %}
                        </ul>
                    </article>
                {% endif %}

                <article class="register-support-panel">
                    <div class="register-support-visual">
                        <span>🧑‍💼</span><span>💬</span>
                    </div>
                    <p style="text-align: center; margin-bottom: 1rem;">
                        <strong>{{ t('register.support_title') }}</strong><br>
                        {{ t('register.support_copy') }}
                    </p>
                    <a class="button" href="{{ path('app_contact') }}">{{ t('register.support_button') }}</a>
                </article>
            </div>
        </section>

        <div class="register-footer-links">
            <a href="{{ path('app_home') }}">{{ t('auth.footer.back_home') }}</a>
            <a href="{{ path('app_privacy_policy') }}">Integritetspolicy</a>
            <a href="{{ path('app_terms_page') }}">Användarvillkor</a>
            <a href="{{ path('app_cookie_policy') }}">Cookiepolicy</a>
            <a href="{{ path('app_contact') }}">{{ t('auth.footer.support') }}</a>
            {% if site_branding.footerText %}
                <span>{{ site_branding.footerText }}</span>
            {% endif %}
            <span>{{ t('auth.footer.version') }} {{ site_branding.appVersion }}</span>
            <a href="{{ site_branding.githubUrl }}" target="_blank" rel="noopener noreferrer">{{ site_branding.copyrightLabel }}</a>
        </div>
    </div>
{% endblock %}
