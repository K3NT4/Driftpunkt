{% extends 'base.html.twig' %}

{% set loginThemes = {
    technician: {
        icon: '🛠',
        accent: '#2f63d8',
        accentDark: '#234db3',
        pill: 'Teknikerportal'
    },
    admin: {
        icon: '⚙',
        accent: '#7a49d1',
        accentDark: '#6437bb',
        pill: 'Adminportal'
    },
    customer: {
        icon: '💬',
        accent: '#39a763',
        accentDark: '#2c8a50',
        pill: 'Kundportal'
    }
} %}
{% set theme = attribute(loginThemes, loginRole|default('customer')) %}

{% set authMaintenanceNotice = maintenance_notice() %}
{% block title %}Driftpunkt | Välj nytt lösenord{% endblock %}
{% block page_shell_class %}home-shell auth-shell{% endblock %}
{% block body_class %}home-landing login-role-page{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        body.login-role-page {
            background:
                radial-gradient(circle at top left, rgba(115, 141, 255, 0.18), transparent 30%),
                radial-gradient(circle at 100% 20%, rgba(255, 255, 255, 0.76), transparent 26%),
                linear-gradient(180deg, #eff2fb 0%, #f8f5fc 52%, #eef1fa 100%);
        }

        body.login-role-page::before {
            background-image:
                radial-gradient(circle at 16% 10%, rgba(122, 145, 255, 0.14), transparent 24%),
                radial-gradient(circle at 84% 34%, rgba(255, 255, 255, 0.84), transparent 16%),
                radial-gradient(circle at 24% 88%, rgba(122, 145, 255, 0.18), transparent 18%);
            background-size: auto;
            mask-image: none;
            opacity: 1;
        }

        .reset-wrap {
            width: calc(100% - 2rem);
            margin: 0 auto;
            padding: 2rem 0 1rem;
        }

        .reset-panel {
            padding: 1.7rem;
            background: rgba(255, 255, 255, 0.9);
            border: 1px solid rgba(210, 214, 233, 0.82);
            border-radius: 24px;
            box-shadow: 0 18px 46px rgba(111, 120, 163, 0.12);
        }

        .reset-hero {
            text-align: center;
            margin-bottom: 1.4rem;
        }

        .reset-badge {
            width: 6rem;
            height: 6rem;
            margin: 0 auto 1rem;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            background: radial-gradient(circle at 30% 30%, #ffffff, #e7edff 64%);
            box-shadow: 0 16px 36px rgba(112, 127, 189, 0.16);
            font-size: 2.8rem;
        }

        .reset-panel h1 {
            margin-bottom: 0.9rem;
            color: #1f2855;
            text-align: center;
        }

        .reset-panel p {
            color: #4a516d;
            line-height: 1.65;
        }

        .reset-panel .button {
            width: 100%;
            border-radius: 10px;
            box-shadow: none;
            background: linear-gradient(180deg, {{ theme.accent }} 0%, {{ theme.accentDark }} 100%);
        }

        .reset-footer {
            margin-top: 1rem;
            text-align: center;
        }

        .reset-footer a {
            color: {{ theme.accentDark }};
            text-decoration: none;
            font-weight: 700;
        }

        :root {
            --home-text: #283474;
            --home-shadow: 0 24px 60px rgba(87, 101, 177, 0.16);
            --home-surface-strong: rgba(255, 255, 255, 0.9);
        }

        body.home-landing.login-role-page {
            background:
                radial-gradient(circle at 18% 14%, rgba(148, 162, 255, 0.48), transparent 28%),
                radial-gradient(circle at 86% 12%, rgba(255, 222, 212, 0.66), transparent 24%),
                radial-gradient(circle at 50% 100%, rgba(103, 110, 255, 0.3), transparent 24%),
                linear-gradient(180deg, #7785d6 0%, #a9aff0 16%, #cbc7f5 38%, #d8d0f7 52%, #c7c8f8 67%, #a4aff0 100%);
            color: var(--home-text);
        }

        body.home-landing.login-role-page::before {
            background:
                radial-gradient(ellipse at 18% 32%, rgba(255, 255, 255, 0.36), transparent 26%),
                radial-gradient(ellipse at 55% 46%, rgba(255, 255, 255, 0.4), transparent 34%),
                radial-gradient(ellipse at 82% 68%, rgba(255, 255, 255, 0.28), transparent 24%),
                linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0));
        }

        body.home-landing.login-role-page::after {
            content: "";
            position: fixed;
            inset: 0;
            pointer-events: none;
            background:
                radial-gradient(circle at 20% 18%, rgba(255, 255, 255, 0.95) 0 2px, transparent 3px),
                radial-gradient(circle at 82% 26%, rgba(255, 255, 255, 0.88) 0 2px, transparent 3px),
                radial-gradient(circle at 14% 74%, rgba(255, 255, 255, 0.7) 0 2px, transparent 3px),
                radial-gradient(circle at 74% 86%, rgba(255, 255, 255, 0.78) 0 2px, transparent 3px);
            opacity: 0.9;
        }

        .home-shell {
            width: calc(100% - 2rem);
            padding: 0 0 2.5rem;
        }

        .home-topbar,
        .home-statusbar {
            margin: 0 calc(50% - 50vw);
        }

        .home-topbar {
            background:
                linear-gradient(180deg, rgba(79, 88, 170, 0.92), rgba(71, 80, 156, 0.88)),
                linear-gradient(90deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0));
            border-bottom: 1px solid rgba(255, 255, 255, 0.16);
            box-shadow: 0 14px 36px rgba(56, 63, 125, 0.18);
            backdrop-filter: blur(12px);
        }

        .home-topbar-inner,
        .home-statusbar-inner {
            width: calc(100% - 2rem);
            margin: 0 auto;
        }

        .home-topbar-inner {
            min-height: 68px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1.25rem;
        }

        .home-brand {
            display: inline-flex;
            align-items: center;
            gap: 0.85rem;
            color: #fff;
            font-family: "Space Grotesk", "Manrope", sans-serif;
            font-size: 1.1rem;
            font-weight: 700;
            text-decoration: none;
            letter-spacing: -0.02em;
        }

        .home-brand-logo {
            height: 2.55rem;
            width: auto;
            display: block;
            filter: drop-shadow(0 12px 20px rgba(14, 39, 119, 0.24));
        }

        .home-nav {
            display: flex;
            align-items: center;
            gap: 1.35rem;
            color: rgba(255, 255, 255, 0.9);
        }

        .home-nav-link {
            color: inherit;
            text-decoration: none;
            font-size: 1rem;
            font-weight: 500;
        }

        .home-login-button {
            min-width: 104px;
            padding: 0.74rem 1.28rem;
            border-radius: 11px;
            background: linear-gradient(180deg, #ffbf61 0%, #f49b3c 100%);
            color: #fff;
            border: 1px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 10px 22px rgba(228, 142, 48, 0.32);
        }

        .home-statusbar {
            background: rgba(236, 226, 255, 0.28);
            border-top: 1px solid rgba(255, 255, 255, 0.12);
            border-bottom: 1px solid rgba(113, 117, 195, 0.16);
        }

        .home-statusbar-inner {
            min-height: 38px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.7rem;
            color: #56628f;
            font-size: 0.93rem;
            text-align: center;
        }

        .status-ok-dot {
            width: 1rem;
            height: 1rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            background: rgba(92, 118, 230, 0.16);
            color: #4e63c7;
            font-size: 0.72rem;
            font-weight: 700;
        }

        .status-sep {
            opacity: 0.55;
        }

        .reset-wrap {
            padding-top: 3.5rem;
        }

        .reset-panel {
            position: relative;
            padding: 2rem 1.8rem;
            background: var(--home-surface-strong);
            border-radius: 26px;
            box-shadow: var(--home-shadow);
        }

        .reset-hero {
            position: relative;
            padding: 3rem 2rem 2.5rem;
            border-radius: 34px;
            border: 1px solid rgba(215, 223, 255, 0.84);
            background:
                linear-gradient(135deg, rgba(255, 255, 255, 0.92), rgba(243, 246, 255, 0.84)),
                radial-gradient(circle at 18% 18%, rgba(255, 255, 255, 0.78), transparent 26%);
            box-shadow: var(--home-shadow);
            overflow: hidden;
        }

        .reset-hero::before {
            content: "";
            position: absolute;
            inset: auto -3rem -4rem auto;
            width: 16rem;
            height: 16rem;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(123, 138, 255, 0.16), transparent 70%);
            pointer-events: none;
        }

        .hero-wave {
            position: absolute;
            left: 50%;
            top: 1rem;
            transform: translateX(-50%);
            width: min(1040px, 96vw);
            height: 180px;
            border-radius: 50%;
            background: radial-gradient(ellipse at center, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0) 72%);
            pointer-events: none;
        }

        .reset-panel h1,
        .reset-panel p {
            position: relative;
            z-index: 1;
        }

        @media (max-width: 720px) {
            .home-shell {
                width: calc(100% - 1rem);
            }

            .home-topbar-inner {
                min-height: auto;
                padding: 1rem 0;
                flex-direction: column;
                align-items: stretch;
            }

            .home-nav {
                justify-content: space-between;
                flex-wrap: wrap;
                gap: 0.9rem;
            }

            .home-statusbar-inner {
                padding: 0.7rem 0;
                flex-wrap: wrap;
            }

            .reset-wrap {
                width: calc(100% - 1rem);
                padding-top: 2rem;
            }

            .reset-hero {
                padding: 2.3rem 1.2rem 2rem;
                border-radius: 22px;
            }
        }
    </style>
{% endblock %}

{% block topbar %}
    <header class="home-topbar">
        <div class="home-topbar-inner">
            <a class="home-brand" href="{{ path('app_home') }}">
                <img class="home-brand-logo" src="/assets/branding/driftpunkt-logo-full.png" alt="Driftpunkt">
            </a>
            <nav class="home-nav" aria-label="Huvudnavigering">
                <a class="home-nav-link" href="{{ path('app_home') }}">Startsida</a>
                <a class="home-nav-link" href="{{ path('app_news_index') }}">Nyheter</a>
                <a class="home-nav-link" href="{{ path('app_contact') }}">Kontakta oss</a>
                <a class="button home-login-button" href="{{ app.user ? path('app_portal_entry') : path('app_login', {role: loginRole|default('customer')}) }}">Logga in</a>
            </nav>
        </div>
    </header>
    <div class="home-statusbar">
        <div class="home-statusbar-inner">
            <span class="status-ok-dot" aria-hidden="true">{{ authMaintenanceNotice ? '!' : '✓' }}</span>
            {% if authMaintenanceNotice %}
                <span>{{ authMaintenanceNotice.title }}</span>
                <span class="status-sep">•</span>
                <a href="{{ authMaintenanceNotice.href ?: path('app_status_page') }}" style="color: inherit; text-decoration: none;">{{ authMaintenanceNotice.linkLabel|default('Visa driftstatus') }}</a>
            {% else %}
                <span>Säkert byte av lösenord</span>
                <span class="status-sep">•</span>
                <span>Nytt lösenord kräver minst 12 tecken</span>
                <span class="status-sep">•</span>
                <a href="{{ path('app_status_page') }}" style="color: inherit; text-decoration: none;">Se driftstatus</a>
            {% endif %}
        </div>
    </div>
{% endblock %}

{% block body %}
    <div class="reset-wrap">
        <section class="reset-hero">
            <div class="hero-wave" aria-hidden="true"></div>
            <div class="reset-badge">{{ theme.icon }}</div>
        </section>

        <article class="reset-panel">
            <div class="eyebrow" style="margin-bottom: 1rem; color: {{ theme.accentDark }}; border-color: color-mix(in srgb, {{ theme.accent }} 25%, white);">
                {{ theme.pill }}
            </div>
            <h1>Välj ett nytt lösenord</h1>
            <p style="text-align: center; margin-bottom: 1.2rem;">
                Uppdaterar lösenord för <strong>{{ email }}</strong>. Välj ett nytt lösenord med minst 12 tecken.
            </p>

            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="notice {{ label == 'error' ? 'error' : 'success' }}">{{ message }}</div>
                {% endfor %}
            {% endfor %}

            <form method="post">
                <label>
                    <span>Nytt lösenord</span>
                    <input
                        type="password"
                        name="password"
                        autocomplete="new-password"
                        placeholder="Minst 12 tecken"
                        required
                        autofocus
                    >
                </label>

                <label>
                    <span>Bekräfta nytt lösenord</span>
                    <input
                        type="password"
                        name="password_confirm"
                        autocomplete="new-password"
                        placeholder="Upprepa lösenordet"
                        required
                    >
                </label>

                <input type="hidden" name="_token" value="{{ csrf_token('password_reset_confirm') }}">

                <button class="button" type="submit">Spara nytt lösenord</button>
            </form>

            <div class="reset-footer">
                <a href="{{ path('app_login', {role: loginRole}) }}">Tillbaka till inloggning</a>
            </div>
        </article>
    </div>
{% endblock %}
