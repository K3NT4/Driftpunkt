{% extends 'base.html.twig' %}

{% set searchRoute = pageMode == 'customer' ? 'app_portal_customer_knowledge_base' : 'app_knowledge_base_public' %}
{% set backRoute = pageMode == 'customer' ? path('app_portal_customer') : path('app_home') %}
{% set backLabel = pageMode == 'customer' ? 'Till kundportalen' : 'Till startsidan' %}

{% block title %}{{ site_branding.name }} | {{ pageTitle }}{% endblock %}
{% block page_shell_class %}knowledge-shell{% endblock %}
{% block body_class %}home-landing knowledge-base-page{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        :root {
            --knowledge-text: #20315f;
            --knowledge-text-soft: #5c6a8d;
            --knowledge-line: rgba(156, 174, 225, 0.38);
            --knowledge-surface: rgba(255, 255, 255, 0.84);
            --knowledge-surface-strong: rgba(255, 255, 255, 0.94);
            --knowledge-shadow: 0 24px 54px rgba(58, 77, 138, 0.14);
            --knowledge-blue: #355fdb;
            --knowledge-blue-soft: #eef3ff;
            --knowledge-green: #2f9461;
            --knowledge-amber: #d9912a;
            --knowledge-violet: #6f5ce7;
        }

        body.knowledge-base-page {
            background:
                radial-gradient(circle at 14% 12%, rgba(120, 141, 255, 0.32), transparent 24%),
                radial-gradient(circle at 86% 10%, rgba(255, 222, 193, 0.44), transparent 22%),
                radial-gradient(circle at 50% 100%, rgba(120, 128, 255, 0.2), transparent 26%),
                linear-gradient(180deg, #8a98e5 0%, #bac3f5 22%, #d8dcfb 54%, #c8d4f7 100%);
            color: var(--knowledge-text);
        }

        body.knowledge-base-page::before {
            background:
                radial-gradient(ellipse at 18% 30%, rgba(255, 255, 255, 0.22), transparent 24%),
                radial-gradient(ellipse at 56% 42%, rgba(255, 255, 255, 0.28), transparent 30%),
                linear-gradient(180deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0));
            mask-image: none;
            opacity: 1;
        }

        body.knowledge-base-page::after {
            content: "";
            position: fixed;
            inset: 0;
            pointer-events: none;
            background:
                radial-gradient(circle at 20% 18%, rgba(255, 255, 255, 0.95) 0 2px, transparent 3px),
                radial-gradient(circle at 82% 26%, rgba(255, 255, 255, 0.88) 0 2px, transparent 3px),
                radial-gradient(circle at 14% 74%, rgba(255, 255, 255, 0.7) 0 2px, transparent 3px),
                radial-gradient(circle at 74% 86%, rgba(255, 255, 255, 0.78) 0 2px, transparent 3px);
            opacity: 0.9;
        }

        .knowledge-shell {
            width: calc(100% - 2rem);
            padding: 0 0 2.5rem;
        }

        .knowledge-page-wrap {
            margin: 0 auto;
            padding: 0 0 1.5rem;
        }

        .knowledge-customer-layout {
            width: calc(100% - 2rem);
            margin: 1rem auto 0;
            display: grid;
            gap: 1rem;
            grid-template-columns: clamp(210px, 16vw, 280px) minmax(0, 1fr);
            align-items: start;
        }

        .knowledge-customer-main {
            min-width: 0;
        }

        .customer-portal-sidebar {
            display: grid;
            gap: 1rem;
            position: sticky;
            top: 1rem;
        }

        .customer-nav-card,
        .customer-sidepanel-card {
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.88) 0%, rgba(248, 247, 255, 0.8) 100%);
            border: 1px solid var(--knowledge-line);
            border-radius: 22px;
            box-shadow: var(--knowledge-shadow);
            backdrop-filter: blur(16px);
        }

        .customer-nav-card {
            padding: 1rem;
        }

        .customer-account-card {
            position: relative;
            overflow: hidden;
            padding: 1.05rem;
            background:
                linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(246, 247, 255, 0.84)),
                radial-gradient(circle at top right, rgba(97, 118, 238, 0.12), transparent 38%);
        }

        .customer-nav-title {
            margin-bottom: 0.85rem;
            color: #2a3777;
            font-weight: 800;
            font-size: 1rem;
        }

        .customer-nav-list,
        .customer-focus-list,
        .customer-sidepanel-list {
            display: grid;
            gap: 0.5rem;
        }

        .customer-nav-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.75rem;
            padding: 0.72rem 0.82rem;
            border-radius: 14px;
            color: var(--knowledge-text);
            text-decoration: none;
            background: rgba(255, 255, 255, 0.5);
            border: 1px solid rgba(177, 186, 241, 0.28);
            font-weight: 700;
            font-size: 0.93rem;
        }

        .customer-nav-item.active {
            background: linear-gradient(180deg, rgba(79, 115, 255, 0.16), rgba(79, 115, 255, 0.08));
            color: #3047af;
            border-color: rgba(79, 115, 255, 0.34);
        }

        .customer-account-eyebrow,
        .customer-eyebrow {
            display: inline-flex;
            width: fit-content;
            align-items: center;
            gap: 0.45rem;
            padding: 0.34rem 0.66rem;
            border-radius: 999px;
            background: rgba(89, 107, 227, 0.1);
            color: #4253b8;
            font-size: 0.73rem;
            font-weight: 800;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .customer-account-name,
        .customer-sidepanel-title {
            color: #253173;
            font-weight: 800;
        }

        .customer-account-name {
            margin-top: 0.8rem;
            font-size: 1.05rem;
            line-height: 1.2;
        }

        .customer-account-email,
        .customer-nav-note,
        .customer-account-note,
        .customer-sidepanel-text,
        .customer-focus-item-text,
        .customer-focus-meta,
        .customer-sidepanel-item p,
        .customer-sidepanel-item span {
            color: var(--knowledge-text-soft);
            line-height: 1.55;
        }

        .customer-account-summary {
            display: grid;
            gap: 0.65rem;
            margin-top: 0.85rem;
            padding-top: 0.95rem;
            border-top: 1px solid rgba(177, 186, 241, 0.34);
        }

        .customer-account-summary-row,
        .customer-focus-item-header,
        .customer-focus-meta {
            display: flex;
            align-items: baseline;
            justify-content: space-between;
            gap: 0.75rem;
        }

        .customer-account-summary-label {
            color: var(--knowledge-text-soft);
            font-size: 0.82rem;
        }

        .customer-account-summary-value {
            color: #243174;
            font-size: 0.88rem;
            font-weight: 800;
            text-align: right;
        }

        .customer-sidepanel-card {
            padding: 1rem 1rem 1.05rem;
        }

        .customer-focus-item,
        .customer-sidepanel-item {
            padding: 0.85rem 0.9rem;
            border-radius: 14px;
            background: rgba(255, 255, 255, 0.66);
            border: 1px solid rgba(177, 186, 241, 0.35);
        }

        .customer-badge {
            display: inline-flex;
            align-items: center;
            padding: 0.28rem 0.58rem;
            border-radius: 999px;
            font-size: 0.76rem;
            font-weight: 800;
        }

        .customer-sidebar-link {
            color: var(--knowledge-blue);
            font-weight: 700;
            text-decoration: none;
        }

        .knowledge-topbar {
            margin: 0 calc(50% - 50vw) 1.4rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 1.25rem;
            min-height: 68px;
            padding: 0.8rem 0;
            background:
                linear-gradient(180deg, rgba(57, 75, 152, 0.92), rgba(67, 88, 173, 0.88)),
                linear-gradient(90deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0));
            color: #fff;
            border-bottom: 1px solid rgba(255, 255, 255, 0.16);
            box-shadow: 0 14px 36px rgba(56, 63, 125, 0.18);
            backdrop-filter: blur(12px);
        }

        .knowledge-topbar-inner,
        .knowledge-statusbar-inner {
            width: calc(100% - 2rem);
            margin: 0 auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1.25rem;
        }

        .knowledge-topbar a {
            color: inherit;
            text-decoration: none;
        }

        .knowledge-brand {
            display: inline-flex;
            align-items: center;
            gap: 0.85rem;
            color: #fff;
            font-family: "Space Grotesk", "Manrope", sans-serif;
            font-weight: 700;
            font-size: 1.1rem;
            letter-spacing: -0.02em;
        }

        .knowledge-brand-mark {
            display: inline-flex;
            align-items: center;
        }

        .knowledge-brand-logo {
            height: 2.55rem;
            width: auto;
            display: block;
            filter: drop-shadow(0 12px 20px rgba(14, 39, 119, 0.24));
        }

        .knowledge-topbar-nav {
            display: flex;
            align-items: center;
            gap: 0.9rem;
            flex-wrap: wrap;
            color: rgba(255, 255, 255, 0.92);
            font-size: 0.98rem;
            font-weight: 500;
        }

        .knowledge-pill-link {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 2.25rem;
            padding: 0.55rem 1rem;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.18);
            cursor: pointer;
            position: relative;
            z-index: 1;
        }

        .knowledge-login-button {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 104px;
            padding: 0.74rem 1.28rem;
            border-radius: 11px;
            background: linear-gradient(180deg, #ffbf61 0%, #f49b3c 100%);
            color: #fff;
            border: 1px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 10px 22px rgba(228, 142, 48, 0.32);
            cursor: pointer;
            position: relative;
            z-index: 1;
        }

        .knowledge-statusbar {
            margin: 0 calc(50% - 50vw);
            background: rgba(243, 247, 255, 0.42);
            border-top: 1px solid rgba(255, 255, 255, 0.12);
            border-bottom: 1px solid rgba(113, 117, 195, 0.16);
        }

        .knowledge-statusbar-inner {
            min-height: 38px;
            justify-content: center;
            color: #56628f;
            font-size: 0.93rem;
            text-align: center;
        }

        .knowledge-status-dot {
            width: 1.4rem;
            height: 1.4rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            background: rgba(92, 118, 230, 0.14);
            color: #4e63c7;
            font-size: 0.62rem;
            font-weight: 700;
        }

        .knowledge-status-sep {
            opacity: 0.55;
        }

        .knowledge-hero {
            position: relative;
            padding: 3.4rem 0 0;
        }

        .knowledge-hero::before,
        .knowledge-hero::after {
            content: "";
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
            width: 100vw;
            pointer-events: none;
            border-radius: 50%;
            filter: blur(2px);
        }

        .knowledge-hero::before {
            top: 0.3rem;
            height: 220px;
            background:
                radial-gradient(ellipse at center, rgba(255, 255, 255, 0.52) 0%, rgba(255, 255, 255, 0.16) 58%, transparent 78%);
            opacity: 0.92;
        }

        .knowledge-hero::after {
            top: 1.7rem;
            height: 148px;
            background:
                radial-gradient(ellipse at center, rgba(255, 255, 255, 0.36) 0%, rgba(255, 255, 255, 0.08) 60%, transparent 80%);
        }

        .knowledge-hero-wave {
            position: absolute;
            inset: 1.7rem 0 auto;
            height: 176px;
            overflow: hidden;
            pointer-events: none;
        }

        .knowledge-hero-wave::before,
        .knowledge-hero-wave::after {
            content: "";
            position: absolute;
            left: 50%;
            width: min(1100px, 120vw);
            transform: translateX(-50%);
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.24);
        }

        .knowledge-hero-wave::before {
            top: 0;
            height: 124px;
            clip-path: polygon(0 58%, 10% 45%, 21% 50%, 33% 34%, 47% 44%, 62% 26%, 76% 38%, 100% 20%, 100% 100%, 0 100%);
        }

        .knowledge-hero-wave::after {
            top: 20px;
            height: 114px;
            background: rgba(255, 255, 255, 0.18);
            clip-path: polygon(0 64%, 14% 48%, 27% 58%, 40% 40%, 58% 54%, 72% 34%, 87% 45%, 100% 30%, 100% 100%, 0 100%);
        }

        .knowledge-hero-content {
            position: relative;
            z-index: 1;
            display: grid;
            gap: 1.4rem;
        }

        .knowledge-eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            padding: 0.52rem 0.9rem;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.58);
            color: #4658ac;
            font-weight: 700;
            box-shadow: 0 12px 28px rgba(103, 116, 197, 0.14);
        }

        .knowledge-hero-intro {
            display: grid;
            gap: 1rem;
            justify-items: center;
            text-align: center;
        }

        .knowledge-title {
            position: relative;
            margin: 0;
            color: #243174;
            font-size: clamp(3rem, 5vw, 4.35rem);
            line-height: 1.02;
            letter-spacing: -0.04em;
        }

        .knowledge-subtitle {
            position: relative;
            max-width: 50rem;
            margin: 0 auto;
            color: #44517e;
            font-size: clamp(1.08rem, 1.8vw, 1.45rem);
            line-height: 1.62;
        }

        .knowledge-hero-panel,
        .knowledge-search-card,
        .knowledge-section,
        .knowledge-empty,
        .knowledge-sidebar-card {
            padding: 1.4rem;
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.84) 0%, rgba(249, 247, 255, 0.76) 100%);
            border: 1px solid var(--knowledge-line);
            border-radius: 24px;
            box-shadow: var(--knowledge-shadow);
            backdrop-filter: blur(16px);
        }

        .knowledge-hero-panel {
            display: grid;
            gap: 1.15rem;
            max-width: 1180px;
            margin: 0 auto;
        }

        .knowledge-search-card {
            padding: 0;
            background: transparent;
            border: 0;
            box-shadow: none;
            backdrop-filter: none;
        }

        .knowledge-search-card-head,
        .knowledge-section-head,
        .knowledge-sidebar-head {
            display: flex;
            justify-content: space-between;
            gap: 1rem;
            align-items: end;
        }

        .knowledge-heading {
            display: flex;
            align-items: center;
            gap: 0.7rem;
            margin-bottom: 0.95rem;
        }

        .knowledge-heading h2 {
            margin: 0;
            font-size: clamp(1.75rem, 2.3vw, 2.15rem);
            letter-spacing: -0.03em;
            color: #2b3778;
        }

        .knowledge-heading-icon {
            width: 2rem;
            height: 2rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            font-size: 0.84rem;
            color: #fff;
            background: linear-gradient(180deg, #6d99ff, #416de0);
        }

        .knowledge-search-form {
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            gap: 0.8rem;
            align-items: center;
        }

        .knowledge-search-input {
            width: 100%;
            min-height: 3.55rem;
            padding: 0.82rem 1.1rem;
            border-radius: 999px;
            border: 1px solid rgba(136, 147, 214, 0.32);
            background: rgba(255, 255, 255, 0.86);
            color: #243174;
            font: inherit;
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.72);
        }

        .knowledge-search-input::placeholder {
            color: #7380aa;
        }

        .knowledge-search-button {
            min-width: 136px;
            min-height: 3.55rem;
            border-radius: 999px;
            border: 1px solid rgba(255, 255, 255, 0.2);
            background: linear-gradient(180deg, #5782ff 0%, #355fdb 100%);
            color: #fff;
            box-shadow: 0 12px 24px rgba(66, 99, 211, 0.26);
        }

        .knowledge-search-notes,
        .knowledge-overview-grid,
        .knowledge-content-shell {
            display: grid;
            gap: 1rem;
        }

        .knowledge-search-notes {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .knowledge-search-note,
        .knowledge-overview-card,
        .knowledge-nav-link,
        .knowledge-tip-card,
        .knowledge-article-card,
        .knowledge-faq-list details {
            border: 1px solid rgba(191, 198, 239, 0.42);
            background: rgba(255, 255, 255, 0.7);
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.6);
        }

        .knowledge-search-note {
            display: grid;
            gap: 0.35rem;
            padding: 1rem 1.05rem;
            border-radius: 18px;
        }

        .knowledge-search-note strong,
        .knowledge-overview-card strong,
        .knowledge-nav-link strong,
        .knowledge-tip-card strong,
        .knowledge-article-card h3,
        .knowledge-sidebar-card h3 {
            color: #233267;
        }

        .knowledge-search-note span,
        .knowledge-overview-card p,
        .knowledge-nav-link span,
        .knowledge-sidebar-card p,
        .knowledge-section p,
        .knowledge-empty p,
        .knowledge-search-card p,
        .knowledge-article-card p {
            color: #4c5b7b;
            line-height: 1.65;
        }

        .knowledge-overview-grid {
            grid-template-columns: repeat(4, minmax(0, 1fr));
        }

        .knowledge-overview-card {
            display: grid;
            gap: 0.45rem;
            padding: 1.1rem;
            border-radius: 20px;
        }

        .knowledge-overview-value {
            font-size: clamp(1.7rem, 2.4vw, 2.25rem);
            line-height: 1;
            font-weight: 800;
            color: #233267;
            letter-spacing: -0.04em;
        }

        .knowledge-overview-label {
            font-size: 0.92rem;
            color: #607094;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            font-weight: 700;
        }

        .knowledge-content-shell {
            margin-top: 1.2rem;
            grid-template-columns: minmax(0, 1.65fr) minmax(280px, 0.75fr);
            align-items: start;
        }

        .knowledge-main-stack,
        .knowledge-sidebar {
            display: grid;
            gap: 1rem;
        }

        .knowledge-sidebar {
            position: sticky;
            top: 1rem;
        }

        .knowledge-nav-list,
        .knowledge-card-list,
        .knowledge-faq-list,
        .knowledge-article-list {
            display: grid;
            gap: 0.85rem;
            margin-top: 1rem;
        }

        .knowledge-nav-link {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.9rem;
            padding: 1rem 1.05rem;
            border-radius: 18px;
            text-decoration: none;
        }

        .knowledge-nav-link:hover {
            border-color: rgba(88, 113, 224, 0.42);
            transform: translateY(-1px);
            transition: transform 140ms ease, border-color 140ms ease;
        }

        .knowledge-nav-link-badge {
            flex: 0 0 auto;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 2rem;
            height: 2rem;
            padding: 0 0.65rem;
            border-radius: 999px;
            background: var(--knowledge-blue-soft);
            color: #355fdb;
            font-size: 0.84rem;
            font-weight: 800;
        }

        .knowledge-grid {
            display: grid;
            gap: 1rem;
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .knowledge-tip-card,
        .knowledge-article-card,
        .knowledge-faq-list details {
            padding: 1rem 1.05rem;
            border-radius: 18px;
        }

        .knowledge-tip-card {
            display: flex;
            gap: 0.8rem;
            align-items: flex-start;
        }

        .knowledge-tip-icon,
        .knowledge-faq-icon {
            flex: 0 0 auto;
            width: 2.1rem;
            height: 2.1rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            font-size: 0.94rem;
            font-weight: 800;
        }

        .knowledge-tip-icon {
            background: linear-gradient(180deg, rgba(107, 198, 139, 0.22), rgba(76, 168, 109, 0.16));
            color: var(--knowledge-green);
        }

        .knowledge-faq-icon {
            background: linear-gradient(180deg, rgba(132, 155, 255, 0.22), rgba(74, 104, 221, 0.16));
            color: #5168c9;
        }

        .knowledge-guide-icon {
            background: linear-gradient(180deg, rgba(246, 191, 111, 0.22), rgba(235, 154, 44, 0.14));
            color: var(--knowledge-amber);
        }

        .knowledge-faq-list summary {
            display: flex;
            justify-content: space-between;
            gap: 1rem;
            cursor: pointer;
            list-style: none;
        }

        .knowledge-faq-list summary::-webkit-details-marker {
            display: none;
        }

        .knowledge-faq-question {
            display: flex;
            gap: 0.75rem;
            padding-right: 1rem;
            color: #273c86;
            font-weight: 600;
        }

        .knowledge-faq-arrow {
            color: #3153ba;
            font-weight: 800;
            transition: transform 140ms ease;
        }

        .knowledge-faq-list details[open] .knowledge-faq-arrow {
            transform: rotate(90deg);
        }

        .knowledge-faq-answer {
            padding-top: 0.9rem;
            padding-left: 2.45rem;
            color: #57637f;
            line-height: 1.7;
        }

        .knowledge-article-card-header {
            display: flex;
            gap: 0.85rem;
            align-items: flex-start;
            margin-bottom: 0.7rem;
        }

        .knowledge-article-card h3,
        .knowledge-section h2,
        .knowledge-search-card h2 {
            margin: 0;
            color: #232b57;
        }

        .knowledge-meta {
            color: #6a7697;
            font-size: 0.92rem;
        }

        .knowledge-audience-pill {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            padding: 0.34rem 0.7rem;
            border-radius: 999px;
            background: rgba(111, 92, 231, 0.1);
            color: var(--knowledge-violet);
            font-size: 0.78rem;
            font-weight: 800;
        }

        .knowledge-text-preview {
            margin: 0;
        }

        .knowledge-meta-pill {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            padding: 0.26rem 0.62rem;
            border-radius: 999px;
            background: rgba(255, 245, 219, 0.92);
            color: #917137;
            font-size: 0.8rem;
            font-weight: 700;
        }

        .knowledge-empty {
            display: grid;
            gap: 1rem;
        }

        .knowledge-empty-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 0.7rem;
        }

        .knowledge-empty-chip {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 2.5rem;
            padding: 0.55rem 0.95rem;
            border-radius: 999px;
            text-decoration: none;
            color: #3457c7;
            background: rgba(235, 241, 255, 0.9);
            border: 1px solid rgba(164, 181, 234, 0.55);
            font-weight: 700;
        }

        .knowledge-footer {
            display: flex;
            justify-content: space-between;
            gap: 1rem;
            flex-wrap: wrap;
            margin-top: 2rem;
            padding: 1.35rem 0 0;
            border-top: 1px solid rgba(211, 216, 237, 0.72);
            color: #eef2ff;
        }

        .knowledge-footer a {
            color: inherit;
            text-decoration: none;
        }

        .knowledge-footer-link {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 2.6rem;
            padding: 0.65rem 1rem;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.16);
            cursor: pointer;
            position: relative;
            z-index: 1;
        }

        .knowledge-footer-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 0.9rem;
            align-items: center;
        }

        .knowledge-sidebar-card ul {
            margin: 0;
            padding-left: 1.1rem;
            color: #4c5b7b;
            line-height: 1.7;
        }

        @media (max-width: 900px) {
            .knowledge-customer-layout {
                width: calc(100% - 1rem);
                grid-template-columns: 1fr;
            }

            .customer-portal-sidebar {
                position: static;
            }

            .knowledge-search-notes,
            .knowledge-overview-grid,
            .knowledge-content-shell,
            .knowledge-grid {
                grid-template-columns: 1fr;
            }

            .knowledge-search-form {
                grid-template-columns: 1fr;
            }

            .knowledge-topbar-inner {
                flex-direction: column;
                align-items: stretch;
            }

            .knowledge-topbar {
                padding-block: 0.95rem;
            }

            .knowledge-topbar-nav,
            .knowledge-statusbar-inner,
            .knowledge-search-card-head,
            .knowledge-section-head,
            .knowledge-sidebar-head {
                flex-direction: column;
                align-items: stretch;
            }

            .knowledge-hero {
                padding-top: 2.6rem;
            }
        }
    </style>
{% endblock %}

{% block topbar %}
    <div class="topbar">
        <div class="brand brand-mark">
            <img class="brand-logo" src="{{ site_branding.logoPath }}" alt="{{ t('brand.logo_alt', {'%name%': site_branding.name}) }}">
            <span>{{ site_branding.name }}</span>
        </div>
        <div class="nav-links">
            {% if pageMode != 'customer' %}
                <a class="button secondary" href="{{ path('app_home') }}">{{ t('nav.home') }}</a>
            {% endif %}
            {% if app.user %}
                <a class="button secondary" href="{{ path('app_portal_entry') }}">{{ t('nav.portal') }}</a>
                <a class="button secondary" href="{{ path('app_logout') }}">{{ t('nav.logout') }}</a>
            {% else %}
                <a class="button secondary" href="{{ path('app_login') }}">{{ t('nav.login') }}</a>
            {% endif %}
        </div>
    </div>
{% endblock %}

{% block body %}
    {% set totalKnowledgeHits = entries.tips|length + entries.faq|length + entries.articles|length %}
    <div class="knowledge-page-wrap">
        <div class="knowledge-topbar">
            <div class="knowledge-topbar-inner">
                <a class="knowledge-brand" href="{{ pageMode == 'customer' ? path('app_portal_customer') : path('app_home') }}">
                    <span class="knowledge-brand-mark">
                        <img class="knowledge-brand-logo" src="{{ site_branding.logoPath }}" alt="{{ site_branding.name }}">
                    </span>
                    <span>{{ t('knowledge.brand') }}</span>
                </a>
                <div class="knowledge-topbar-nav">
                    <a class="knowledge-pill-link" href="#knowledge-search">{{ t('knowledge.search_again') }}</a>
                    <a class="{{ pageMode == 'customer' ? 'knowledge-pill-link' : 'knowledge-login-button' }}" href="{{ backRoute }}">{{ backLabel }}</a>
                </div>
            </div>
        </div>

        <div class="knowledge-statusbar">
            <div class="knowledge-statusbar-inner">
                <span class="knowledge-status-dot">●</span>
                <span>{{ pageMode == 'customer' ? t('knowledge.status.customer_mode') : t('knowledge.status.public_mode') }}</span>
                <span class="knowledge-status-sep">•</span>
                <span>{{ searchQuery is not empty ? t('knowledge.status.filtered_on', {'%query%': searchQuery}) : t('knowledge.status.search_hint') }}</span>
            </div>
        </div>

        {% if pageMode == 'customer' %}
        <div class="knowledge-customer-layout">
            {% include 'portal/_customer_portal_sidebar.html.twig' %}
            <div class="knowledge-customer-main">
        {% endif %}

        <section class="knowledge-hero">
            <div class="knowledge-hero-wave" aria-hidden="true"></div>
            <div class="knowledge-hero-content">
                <div class="knowledge-hero-intro">
                    <div class="knowledge-eyebrow">{{ pageMode == 'customer' ? t('knowledge.hero.customer') : t('knowledge.hero.public') }}</div>
                    <h1 class="knowledge-title">{{ pageTitle }}</h1>
                    <p class="knowledge-subtitle">{{ pageSubtitle }}</p>
                </div>

                <section id="knowledge-search" class="knowledge-hero-panel">
                    <div class="knowledge-search-card">
                        <div class="knowledge-search-card-head">
                            <div>
                                <div class="knowledge-heading">
                                    <span class="knowledge-heading-icon">⌕</span>
                                    <h2>{{ t('knowledge.search.title') }}</h2>
                                </div>
                                <p style="margin: 0.2rem 0 0;">{{ pageMode == 'customer' ? t('knowledge.search.customer_copy') : t('knowledge.search.public_copy') }}</p>
                            </div>
                            <span class="knowledge-meta-pill">{{ totalKnowledgeHits == 1 ? t('knowledge.count', {'%count%': totalKnowledgeHits}) : t('knowledge.count_plural', {'%count%': totalKnowledgeHits}) }}</span>
                        </div>
                        <form method="get" action="{{ path(searchRoute) }}" class="knowledge-search-form">
                            <input class="knowledge-search-input" type="text" name="q" value="{{ searchQuery }}" placeholder="{{ t('knowledge.search.placeholder') }}">
                            <button class="button knowledge-search-button" type="submit">{{ t('search.search_aria') }}</button>
                        </form>
                    </div>

                    <div class="knowledge-search-notes">
                        <div class="knowledge-search-note">
                            <strong>{{ t('knowledge.summary.guides_title') }}</strong>
                            <span>{{ t('knowledge.summary.guides_copy') }}</span>
                        </div>
                        <div class="knowledge-search-note">
                            <strong>{{ t('knowledge.summary.faq_title') }}</strong>
                            <span>{{ t('knowledge.summary.faq_copy') }}</span>
                        </div>
                        <div class="knowledge-search-note">
                            <strong>{{ t('knowledge.summary.tips_title') }}</strong>
                            <span>{{ t('knowledge.summary.tips_copy') }}</span>
                        </div>
                    </div>

                    <div class="knowledge-overview-grid">
                        <div class="knowledge-overview-card">
                            <span class="knowledge-overview-label">{{ t('knowledge.overview.total') }}</span>
                            <span class="knowledge-overview-value">{{ totalKnowledgeHits }}</span>
                            <p style="margin: 0;">{{ t('knowledge.overview.total_copy') }}</p>
                        </div>
                        <div class="knowledge-overview-card">
                            <span class="knowledge-overview-label">{{ t('knowledge.section.guides') }}</span>
                            <span class="knowledge-overview-value">{{ entries.articles|length }}</span>
                            <p style="margin: 0;">{{ t('knowledge.overview.guides_copy') }}</p>
                        </div>
                        <div class="knowledge-overview-card">
                            <span class="knowledge-overview-label">{{ t('knowledge.section.faq') }}</span>
                            <span class="knowledge-overview-value">{{ entries.faq|length }}</span>
                            <p style="margin: 0;">{{ t('knowledge.overview.faq_copy') }}</p>
                        </div>
                        <div class="knowledge-overview-card">
                            <span class="knowledge-overview-label">{{ t('knowledge.section.tips') }}</span>
                            <span class="knowledge-overview-value">{{ entries.tips|length }}</span>
                            <p style="margin: 0;">{{ t('knowledge.overview.tips_copy') }}</p>
                        </div>
                    </div>
                </section>
            </div>
        </section>

        <div class="knowledge-content-shell">
            <div class="knowledge-main-stack">
                {% if entries.tips is not empty or entries.faq is not empty %}
                    <div class="knowledge-grid">
                        {% if entries.tips is not empty %}
                            <section id="knowledge-tips" class="knowledge-section">
                                <div class="knowledge-section-head">
                                    <div>
                                        <div class="knowledge-heading">
                                            <span class="knowledge-heading-icon">✓</span>
                                            <h2>{{ t('knowledge.section.tips') }}</h2>
                                        </div>
                                        <p style="margin: 0.45rem 0 0;">{{ t('knowledge.section.tips_copy') }}</p>
                                    </div>
                                    <span class="knowledge-meta">{{ entries.tips|length }} {{ t('knowledge.meta.tips') }}</span>
                                </div>
                                <div class="knowledge-card-list">
                                    {% for entry in entries.tips %}
                                        <article class="knowledge-tip-card">
                                            <span class="knowledge-tip-icon">✓</span>
                                            <div>
                                                <strong style="display: block;">{{ entry.title }}</strong>
                                                <p class="knowledge-text-preview" style="margin-top: 0.35rem;">{{ entry.body|replace({"\n": " "})|slice(0, 220) }}{% if entry.body|length > 220 %}…{% endif %}</p>
                                            </div>
                                        </article>
                                    {% endfor %}
                                </div>
                            </section>
                        {% endif %}

                        {% if entries.faq is not empty %}
                            <section id="knowledge-faq" class="knowledge-section">
                                <div class="knowledge-section-head">
                                    <div>
                                        <div class="knowledge-heading">
                                            <span class="knowledge-heading-icon">?</span>
                                            <h2>{{ t('knowledge.section.faq') }}</h2>
                                        </div>
                                        <p style="margin: 0.45rem 0 0;">{{ t('knowledge.section.faq_copy') }}</p>
                                    </div>
                                    <span class="knowledge-meta">{{ entries.faq|length }} {{ t('knowledge.meta.questions') }}</span>
                                </div>
                                <div class="knowledge-faq-list">
                                    {% for entry in entries.faq %}
                                        <details {{ loop.first ? 'open' }}>
                                            <summary>
                                                <span class="knowledge-faq-question">
                                                    <span class="knowledge-faq-icon">?</span>
                                                    <span>{{ entry.title }}</span>
                                                </span>
                                                <span class="knowledge-faq-arrow">›</span>
                                            </summary>
                                            <div class="knowledge-faq-answer">{{ entry.body|nl2br }}</div>
                                        </details>
                                    {% endfor %}
                                </div>
                            </section>
                        {% endif %}
                    </div>
                {% endif %}

                {% if entries.articles is not empty %}
                    <section id="knowledge-guides" class="knowledge-section">
                        <div class="knowledge-section-head">
                            <div>
                                <div class="knowledge-heading">
                                    <span class="knowledge-heading-icon">✦</span>
                                    <h2>{{ t('knowledge.section.guides') }}</h2>
                                </div>
                                <p style="margin: 0.45rem 0 0;">{{ t('knowledge.section.guides_copy') }}</p>
                            </div>
                            <span class="knowledge-meta">{{ entries.articles|length }} {{ t('knowledge.meta.articles') }}</span>
                        </div>
                        <div class="knowledge-article-list">
                            {% for entry in entries.articles %}
                                <article class="knowledge-article-card">
                                    <div class="knowledge-article-card-header">
                                        <span class="knowledge-faq-icon knowledge-guide-icon">✦</span>
                                        <div>
                                            <h3>{{ entry.title }}</h3>
                                            <div class="knowledge-meta" style="margin-top: 0.45rem;">
                                                <span class="knowledge-audience-pill">
                                                    {{ t('knowledge.audience.label') }}
                                                    {% if entry.audience.value == 'public' %}
                                                        {{ t('knowledge.audience.public') }}
                                                    {% elseif entry.audience.value == 'customer' %}
                                                        {{ t('knowledge.audience.customer') }}
                                                    {% else %}
                                                        {{ t('knowledge.audience.both') }}
                                                    {% endif %}
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                    <p class="knowledge-text-preview">{{ entry.body|nl2br }}</p>
                                </article>
                            {% endfor %}
                        </div>
                    </section>
                {% endif %}

                {% if entries.tips is empty and entries.faq is empty and entries.articles is empty %}
                    <section class="knowledge-empty">
                        <div class="knowledge-heading">
                            <span class="knowledge-heading-icon">!</span>
                            <h2 style="margin: 0; color: #232b57;">{{ t('knowledge.empty.title') }}</h2>
                        </div>
                        <p style="margin: 0;">{{ t('knowledge.empty.copy') }}</p>
                        <div class="knowledge-empty-actions">
                            <a class="knowledge-empty-chip" href="{{ path(searchRoute, {q: 'lösenord'}) }}">{{ t('knowledge.empty.suggestion.password') }}</a>
                            <a class="knowledge-empty-chip" href="{{ path(searchRoute, {q: 'e-post'}) }}">{{ t('knowledge.empty.suggestion.mail') }}</a>
                            <a class="knowledge-empty-chip" href="{{ path(searchRoute, {q: 'vpn'}) }}">{{ t('knowledge.empty.suggestion.vpn') }}</a>
                        </div>
                    </section>
                {% endif %}
            </div>

            <aside class="knowledge-sidebar">
                <section class="knowledge-sidebar-card">
                    <div class="knowledge-sidebar-head">
                        <div class="knowledge-heading">
                            <span class="knowledge-heading-icon">≡</span>
                            <h2>{{ t('knowledge.sidebar.browse_title') }}</h2>
                        </div>
                    </div>
                    <p style="margin: 0;">{{ t('knowledge.sidebar.browse_copy') }}</p>
                    <div class="knowledge-nav-list">
                        {% if entries.articles is not empty %}
                            <a class="knowledge-nav-link" href="#knowledge-guides">
                                <span>
                                    <strong>{{ t('knowledge.section.guides') }}</strong>
                                    <span style="display: block;">{{ t('knowledge.sidebar.guides_copy') }}</span>
                                </span>
                                <span class="knowledge-nav-link-badge">{{ entries.articles|length }}</span>
                            </a>
                        {% endif %}
                        {% if entries.faq is not empty %}
                            <a class="knowledge-nav-link" href="#knowledge-faq">
                                <span>
                                    <strong>{{ t('knowledge.section.faq') }}</strong>
                                    <span style="display: block;">{{ t('knowledge.sidebar.faq_copy') }}</span>
                                </span>
                                <span class="knowledge-nav-link-badge">{{ entries.faq|length }}</span>
                            </a>
                        {% endif %}
                        {% if entries.tips is not empty %}
                            <a class="knowledge-nav-link" href="#knowledge-tips">
                                <span>
                                    <strong>{{ t('knowledge.section.tips') }}</strong>
                                    <span style="display: block;">{{ t('knowledge.sidebar.tips_copy') }}</span>
                                </span>
                                <span class="knowledge-nav-link-badge">{{ entries.tips|length }}</span>
                            </a>
                        {% endif %}
                    </div>
                </section>

                <section class="knowledge-sidebar-card">
                    <div class="knowledge-heading">
                        <span class="knowledge-heading-icon">i</span>
                        <h2>{{ t('knowledge.sidebar.search_help_title') }}</h2>
                    </div>
                    <p style="margin: 0;">{{ t('knowledge.sidebar.search_help_copy') }}</p>
                    <ul>
                        <li>{{ t('knowledge.sidebar.search_help_1') }}</li>
                        <li>{{ t('knowledge.sidebar.search_help_2') }}</li>
                        <li>{{ t('knowledge.sidebar.search_help_3') }}</li>
                    </ul>
                </section>
            </aside>
        </div>

        <div class="knowledge-footer">
            <a class="knowledge-footer-link" href="{{ pageMode == 'customer' ? path('app_portal_customer') : path('app_home') }}">{{ pageMode == 'customer' ? t('knowledge.footer.customer_portal') : t('nav.home') }}</a>
            <a class="knowledge-footer-link" href="{{ pageMode == 'customer' ? path('app_portal_customer') : path('app_login', {role: 'customer'}) }}">{{ pageMode == 'customer' ? t('knowledge.footer.customer_portal') : t('knowledge.footer.customer_login') }}</a>
            <a class="knowledge-footer-link" href="#knowledge-search">{{ t('knowledge.search_again') }}</a>
            <div class="knowledge-footer-meta">
                {% if site_branding.footerText %}
                    <span>{{ site_branding.footerText }}</span>
                {% endif %}
                <span>{{ t('search.footer.version') }} {{ site_branding.appVersion }}</span>
                <a class="knowledge-footer-link" href="{{ site_branding.githubUrl }}" target="_blank" rel="noopener noreferrer">{{ site_branding.copyrightLabel }}</a>
            </div>
        </div>

        {% if pageMode == 'customer' %}
            </div>
        </div>
        {% endif %}
    </div>
{% endblock %}
